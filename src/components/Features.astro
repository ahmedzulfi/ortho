---
/**
 * Features Section
 * Cleaned up and migrated to Tailwind CSS
 */
---

<section class="w-full lg:h-[380px] flex items-center justify-center pt-[15px] relative overflow-hidden">
  <div class="w-full max-w-[1470px] px-4 md:px-[15px] lg:pb-0 lg:absolute bottom-0 left-1/2 lg:-translate-x-1/2 flex flex-col lg:flex-row items-stretch lg:items-end justify-start gap-4 md:gap-[15px] z-[1]">
    
    <!-- Left Box -->
    <div class="flex-1 relative flex flex-col md:flex-row items-start justify-start gap-8 md:gap-12 lg:gap-[70px] bg-white rounded-[20px] p-6 md:p-10 lg:pl-[55px]">
      
      <!-- Text + Links -->
      <div class="flex-1 max-w-full md:max-w-[405px] flex flex-col justify-between items-start gap-4">
        
        <div class="w-full md:max-w-[245px] flex flex-col justify-start">
          <h3 class="m-0 font-['Inter'] font-normal text-black text-sm md:text-base leading-[1.2em]">
            We provide expert 3D planning tailored to your case.
          </h3>
        </div>
        
        <div class="w-full flex justify-start items-start mt-2">
          <div class="w-full md:max-w-[300px] flex flex-wrap gap-1 md:gap-[5px] justify-start items-start">
            
            {/* Start Service List */}
            {["Aligners Planning", "3D Designing", "Manufacturing", "Case Management", "STL Outsourcing", "Digital Repair"].map(service => (
              <div class="relative h-auto">
                <a href="/services" class="flex flex-row items-center justify-center gap-[10px] px-3 py-1 bg-transparent rounded-[60px] no-underline cursor-pointer transition-colors hover:bg-gray-100">
                  <p class="m-0 font-['Inter'] font-normal text-black text-[13px] md:text-base leading-[1.2em]">{service}</p>
                </a>
              </div>
            ))}
          </div>
        </div>

      </div>
      
      <!-- Right feature box -->
      <div class="flex-1 max-w-full md:max-w-[325px] flex flex-col items-start justify-center gap-6 md:gap-[80px]">
        <div class="flex flex-col items-start justify-center gap-3 md:gap-4">
          <h3 class="m-0 font-['Inter'] font-normal text-black text-sm md:text-base leading-[1.2em]">
            Why Orthodontics Align?
          </h3>
          <div class="w-[125px] md:w-[155px] relative">
            <div class="flex items-center justify-start w-full relative h-[30px] md:h-[35px]">
              {[1, 2, 3, 4, 5].map((_, i) => (
                <div 
                  class="w-[30px] h-[30px] md:w-[35px] md:h-[35px] overflow-hidden rounded-full border-2 border-white absolute z-[5]"
                  style={`left: ${i * 20}px; z-index: ${5 - i};`}
                >
                  <img src={`https://framerusercontent.com/images/${["zyLihMsmSSdiL5g5jHJn4e6zQ", "0YT123QRbremRM1AgxCueBx7IRY", "yWUGDZMAYtE216zWWnYBZ0LBoRo", "BcSdxaffL9NSUbnZMFbwTXGgdcc", "puGp4Hi5DUcsbLLVVYEhrdP1lg"][i]}.jpg`} class="w-full h-full object-cover" alt="Client"/>
                </div>
              ))}
            </div>
          </div>
        </div>
        <div class="w-full">
          <p class="m-0 font-['Inter'] font-normal text-black text-[13px] md:text-base leading-[1.2em]">
            Whether you're submitting a simple alignment or a complex malocclusion, we ensure your treatment plan is handled with expert precision.
          </p>
        </div>
      </div>
      
    </div>
    
    <!-- Right Box (Image + Overlay) -->
    <div class="flex-1 max-w-full lg:max-w-[400px] z-[1] flex h-[250px] md:h-[300px] lg:h-[450px]">
      <a href="/services" class="w-full flex flex-col justify-between items-start p-5 relative no-underline rounded-[20px] group">
        <div class="absolute inset-0 rounded-[20px] overflow-hidden pointer-events-none brightness-75">
          <img src="https://framerusercontent.com/images/dWARlvTfJvZGsuaCnPbV2hIzCRs.png" class="w-full h-full object-cover object-center transition-transform duration-500 group-hover:scale-105" alt="Woman"/>
        </div>
        <div class="absolute right-[-1px] bottom-[-1px] w-16 h-16 md:w-[88px] md:h-[88px] overflow-hidden pointer-events-none z-[1]">
          <img src="https://framerusercontent.com/images/qEaFLfaDBsyXxc2u4OMLrist4c.svg" class="w-full h-full object-cover" alt="Corner Image"/>
        </div>
        
        <div class="relative z-10">
          <h3 class="m-0 font-['Inter'] font-normal text-white text-sm md:text-base leading-[1.2em]">
            Services
          </h3>
        </div>
        
        <div class="w-[90%] md:w-[86%] relative z-10 pb-4 lg:pb-6">
          <p class="m-0 font-['Inter'] font-normal text-white text-[13px] md:text-base leading-[1.2em]">
            We offer a comprehensive range of 3D planning services designed for every partner.
          </p>
        </div>
        
        <div class="absolute bottom-0 right-[64px] md:right-[88px] translate-x-1/2 p-2 z-[1]">
          <div class="bg-white rounded-full w-10 h-10 md:w-[44px] md:h-[44px] flex items-center justify-center">
            <div class="w-3 h-3 md:w-4 md:h-4 overflow-hidden relative">
              <img src="https://framerusercontent.com/images/ZJoGKeaTsLbbmJdVa1ci5AE43AI.svg" class="w-full h-full object-cover" alt="Arrow"/>
            </div>
          </div>
        </div>
      </a>
    </div>

  </div>
</section>
