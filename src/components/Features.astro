---
/**
 * Features Section
 * Cleaned up and migrated to Tailwind CSS
 */
---

---
/**
 * Features Section
 * Pivoted to ValidMVPs - High-execution tech features.
 */
---

<section class="w-full lg:h-[380px] flex items-center justify-center pt-[15px] relative overflow-hidden bg-white">
  <div class="w-full max-w-[1440px] px-6 md:px-[50px] lg:pb-0 lg:absolute bottom-0 left-1/2 lg:-translate-x-1/2 flex flex-col lg:flex-row items-stretch lg:items-end justify-start gap-4 md:gap-[15px] z-[1]">
    
    <!-- Left Box -->
    <div class="flex-1 relative flex flex-col md:flex-row items-start justify-start gap-8 md:gap-12 lg:gap-[70px] bg-[#F6F7FF] rounded-[20px] p-6 md:p-10 lg:pl-[55px] border border-[rgba(13,27,21,0.05)]">
      
      <!-- Text + Links -->
      <div class="flex-1 max-w-full md:max-w-[405px] flex flex-col justify-between items-start gap-4">
        
        <div class="w-full md:max-w-[245px] flex flex-col justify-start">
          <h3 class="m-0 font-['Bricolage_Grotesque'] font-medium text-[var(--color-spring-green-8)] text-lg md:text-xl leading-tight">
            Comprehensive MVP execution tailored to your vision.
          </h3>
        </div>
        
        <div class="w-full flex justify-start items-start mt-2">
          <div class="w-full md:max-w-[320px] flex flex-wrap gap-1.5 md:gap-2 justify-start items-start">
            
            {/* Start Service List */}
            {["Full-Stack Build", "AI Integration", "Product Strategy", "Cloud Scaling", "Auth & Security", "UI/UX Design"].map(service => (
              <div class="relative h-auto">
                <a href="/services/" class="flex flex-row items-center justify-center gap-2 px-3 py-1.5 bg-white border border-[rgba(13,27,21,0.1)] rounded-full no-underline cursor-pointer transition-all hover:bg-[var(--color-chartreuse-green-72)] hover:border-transparent group">
                  <p class="m-0 font-['Inter'] font-medium text-[var(--color-spring-green-8)] text-[12px] md:text-sm leading-none">{service}</p>
                </a>
              </div>
            ))}
          </div>
        </div>

      </div>
      
      <!-- Right feature box -->
      <div class="flex-1 max-w-full md:max-w-[325px] flex flex-col items-start justify-center gap-6 md:gap-[80px]">
        <div class="flex flex-col items-start justify-center gap-3 md:gap-4">
          <h3 class="m-0 font-['Bricolage_Grotesque'] font-medium text-[var(--color-spring-green-8)] text-lg md:text-xl leading-tight">
            Why ValidMVPs?
          </h3>
          <div class="w-[125px] md:w-[155px] relative">
            <div class="flex items-center justify-start w-full relative h-[30px] md:h-[35px]">
              {[1, 2, 3, 4, 5].map((_, i) => (
                <div 
                  class="w-[30px] h-[30px] md:w-[35px] md:h-[35px] overflow-hidden rounded-full border-2 border-white absolute z-[5]"
                  style={`left: ${i * 20}px; z-index: ${5 - i};`}
                >
                  <img src={`https://images.pexels.com/photos/${[3184611, 3184291, 3184296, 3184339, 3184360][i]}/pexels-photo-${[3184611, 3184291, 3184296, 3184339, 3184360][i]}.jpeg?auto=compress&cs=tinysrgb&w=100`} class="w-full h-full object-cover" alt="Founder Success"/>
                </div>
              ))}
            </div>
          </div>
        </div>
        <div class="w-full">
          <p class="m-0 font-['Inter'] font-normal text-[var(--color-grey-36)] text-sm md:text-base leading-relaxed">
            Whether you're moving from a prototype or starting from scratch, we ensure your technical roadmap is handled with precision.
          </p>
        </div>
      </div>
      
    </div>
    
    <!-- Right Box (Image + Overlay) -->
    <div class="flex-1 max-w-full lg:max-w-[400px] z-[1] flex h-[250px] md:h-[300px] lg:h-[450px]">
      <a href="/services/" class="w-full flex flex-col justify-between items-start p-6 relative no-underline rounded-[20px] group overflow-hidden">
        <div class="absolute inset-0 rounded-[20px] overflow-hidden pointer-events-none brightness-75">
          <img src="https://images.pexels.com/photos/3184339/pexels-photo-3184339.jpeg?auto=compress&cs=tinysrgb&w=800" class="w-full h-full object-cover object-center transition-transform duration-500 group-hover:scale-105" alt="Tech Strategy"/>
        </div>
        
        <div class="relative z-10">
          <h3 class="m-0 font-['Bricolage_Grotesque'] font-medium text-white text-lg md:text-xl leading-tight">
            Our Services
          </h3>
        </div>
        
        <div class="w-full relative z-10 pb-4">
          <p class="m-0 font-['Inter'] font-normal text-white text-sm md:text-base leading-relaxed max-w-[280px]">
            We offer a comprehensive suite of development services designed for modern founders.
          </p>
        </div>
        
        <div class="absolute bottom-6 right-6 p-2 z-[1]">
          <div class="bg-[var(--color-chartreuse-green-72)] rounded-full w-10 h-10 md:w-12 md:h-12 flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
             <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </div>
        </div>
      </a>
    </div>

  </div>
</section>
