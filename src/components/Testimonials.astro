---
const testimonials = [
  {
    author: "Dr. David Miles",
    service: "Partner Dentist",
    quote: "“Wonderful Accuracy!”",
    text: "The 24-hour turnaround on case setups is a game changer for my clinic. The accuracy of the 3D movement calculations is unmatched, making my aligner treatments more predictable than ever.",
    image: "https://framerusercontent.com/images/BobOk65j6uDzBORMNee0gKRWGk.jpg",
    badgePosition: "bottom", // bottom or top
  },
  {
    author: "Dr. Sarah Dalen",
    service: "Clinical Director",
    quote: "“Highly Recommended!”",
    text: "Abdul Sami and his team made our digital transition smooth and stress-free. They handle all our complex digital movement calculations, letting us focus entirely on our patients. Top-notch planning service!",
    image: "https://framerusercontent.com/images/cPnLmzkyXcZEojXUlOLK54T0yw.jpg",
    badgePosition: "top",
  },
  {
    author: "Dr. Anna Frost",
    service: "Dental Lab Owner",
    quote: "“Amazing Workflow!”",
    text: "The STL quality and automated labeling have streamlined our entire production cycle. Even our most complex cases are handled with extreme precision. I’m grateful for the excellent support we receive!",
    image: "https://framerusercontent.com/images/G45vgYrNZfse4JlMfG3uP8wg.jpg",
    badgePosition: "bottom",
  }
];
---

<section class="box-border flex flex-row items-center justify-center w-full pt-12 md:pt-[75px] relative bg-transparent">
  <div class="w-full max-w-[1540px] px-6 md:px-[50px] flex justify-center">
    <div class="w-full bg-white rounded-[20px] py-12 md:pt-[80px] px-6 md:px-[40px] md:pb-[130px] flex flex-col items-center gap-12 md:gap-[100px] relative">
      
      <!-- Header -->
      <div class="flex flex-col items-center gap-5 w-full text-center">
        <p class="m-0 text-[var(--color-spring-green-8)] text-base font-['Inter'] font-normal">Testimonials</p>
        <h2 class="m-0 text-[var(--color-spring-green-8)] text-3xl md:text-[48px] font-['Bricolage_Grotesque'] font-medium">What our partners say.</h2>
      </div>

      <!-- Testimonials Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-4 lg:gap-[15px] gap-y-6 md:gap-y-24 w-full pb-10 md:pb-0">
        {testimonials.map((t, index) => (
          <div class="relative w-full">
            <!-- Card -->
            <div class="bg-[#f6f7ff] rounded-[20px] p-6 md:p-[30px] flex flex-col gap-4 md:gap-5 min-h-0 md:min-h-[280px]">
              <div class="flex flex-col gap-3">
                <h4 class="m-0 text-[18px] md:text-[20px] font-['Bricolage_Grotesque'] font-medium text-[var(--color-spring-green-8)]">{t.quote}</h4>
                <p class="m-0 text-[14px] md:text-[16px] font-['Inter'] text-[var(--color-grey-36)] leading-relaxed md:leading-[1.6]">{t.text}</p>
              </div>

              <!-- Author Info (Mobile Only - Integrated) -->
              <div class="flex md:hidden items-center gap-3 pt-4 border-t border-black/5">
                <div class="w-10 h-10 rounded-full overflow-hidden">
                  <img src={t.image} alt={t.author} class="w-full h-full object-cover" />
                </div>
                <div class="flex flex-col gap-0.5">
                  <h6 class="m-0 text-[15px] font-['Inter'] font-semibold text-[var(--color-spring-green-8)]">{t.author}</h6>
                  <p class="m-0 text-[12px] font-['Inter'] text-[var(--color-grey-36)]">{t.service}</p>
                </div>
              </div>
            </div>

            <!-- Floating Badge (Desktop Only) -->
            <div class={`
              hidden md:flex absolute bg-white rounded-[60px] pl-[10px] pr-[30px] py-[10px] items-center gap-3 z-10 shadow-[0px_4px_34px_0px_rgba(64,65,209,0.1)]
              ${t.badgePosition === 'bottom' ? 'md:-bottom-[50px] md:left-[40px]' : 'md:-top-[55px] md:right-[30px]'}
            `}>
              <div class="w-[46px] h-[46px] rounded-full overflow-hidden">
                <img src={t.image} alt={t.author} class="w-full h-full object-cover" />
              </div>
              <div class="flex flex-col gap-1">
                <h6 class="m-0 text-[16px] font-['Inter'] font-semibold text-[var(--color-spring-green-8)]">{t.author}</h6>
                <p class="m-0 text-[13px] font-['Inter'] text-[var(--color-grey-36)]">{t.service}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
