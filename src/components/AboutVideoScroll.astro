<div class="video-scroll-container bg-[#F6F7FF] h-[250vh] relative w-full">
  <div
    class="sticky-wrapper sticky top-0 h-screen w-full flex items-center justify-center overflow-hidden"
  >
    <!-- Animation Layer (Centered 1440px container) -->
    <div class="animation-content relative w-full h-full flex items-center justify-center pointer-events-none max-w-[1440px] mx-auto">
      <!-- Side Text Left (Absolute) -->
      <div class="sliding-text text-left absolute left-0 pr-8 lg:pr-12 pointer-events-none z-[5]">
        <h3 class="font-bricolage text-(--color-spring-green-8) font-medium text-4xl lg:text-5xl whitespace-nowrap">©2025</h3>
      </div>

      <!-- Centered Video Container -->
      <div class="expanding-video-frame pointer-events-auto bg-white rounded-2xl shadow-[0_40px_100px_rgba(0,0,0,0.1)] overflow-hidden shrink-0 w-[255px] h-[120px] transition-shadow duration-500 ease-in-out z-10">
        <video
          id="scroll-video"
          class="w-full h-full object-cover"
          loop
          muted
          playsinline
          preload="metadata"
          src="https://framerusercontent.com/assets/iCYvdsdQu2TD6Hdibd0CQ34AxfM.mp4"
        ></video>

        <!-- Main Play Button Overlay -->
        <div
          class="play-button-overlay absolute inset-0 flex items-center justify-center bg-black/10 opacity-0 transition-opacity duration-500 cursor-pointer pointer-events-none"
        >
          <div
            class="w-16 h-16 bg-white rounded-full flex items-center justify-center shadow-2xl"
          >
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="var(--color-spring-green-8)"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M7 6L17 12L7 18V6Z"
                stroke="var(--color-spring-green-8)"
                stroke-width="2"
                stroke-linejoin="round"></path>
            </svg>
          </div>
        </div>

        <!-- Secondary Control Button (Pause icon) -->
        <div id="video-controls" class="absolute bottom-4 right-4 cursor-pointer opacity-0 transition-opacity duration-300 pointer-events-none w-6 h-6 z-[15]">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6">
            <circle cx="12" cy="12" r="12" fill="rgb(166,226,36)"/>
            <path d="M11.25 6.75L11.25 17.25L7.5 17.25L7.5 6.75Z" fill="rgb(12,81,55)"/>
            <path d="M16.5 6.75L16.5 17.25L12.75 17.25L12.75 6.75Z" fill="rgb(12,81,55)"/>
          </svg>
        </div>
      </div>

      <!-- Side Text Right (Absolute) -->
      <div class="sliding-text text-right absolute right-0 pl-8 lg:pl-12 pointer-events-none z-[5]">
        <h3 class="font-bricolage text-(--color-spring-green-8) font-medium text-4xl lg:text-5xl whitespace-nowrap">Teeth Whitening</h3>
      </div>
    </div>

    <!-- Background Fallback -->
    <div class="absolute inset-0 bg-[#F6F7FF] -z-10"></div>
  </div>
</div>

<script>
  function initVideoScroll() {
    const container = document.querySelector(".video-scroll-container");
    const videoFrame = document.querySelector(".expanding-video-frame") as HTMLElement;
    const playOverlay = document.querySelector(".play-button-overlay") as HTMLElement;
    const controls = document.getElementById("video-controls") as HTMLElement;
    const leftText = document.querySelector(".text-left") as HTMLElement;
    const rightText = document.querySelector(".text-right") as HTMLElement;
    const video = document.getElementById("scroll-video") as HTMLVideoElement;

    if (!container || !videoFrame || !leftText || !rightText || !playOverlay || !controls) return;

    let ticking = false;
    window.addEventListener("scroll", () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        ticking = false;
        const rect = container.getBoundingClientRect();
        const scrollHeight = rect.height - window.innerHeight;
        const progress = Math.max(0, Math.min(1, -rect.top / scrollHeight));

        const expansion = Math.min(1, progress / 0.7);
        
        const isMobile = window.innerWidth < 768;
        const finalWidth = isMobile ? window.innerWidth * 0.95 : 1440;
        const initialWidth = isMobile ? 180 : 255;
        const finalHeight = isMobile ? (window.innerWidth * 0.95 * 0.56) : 678;
        const initialHeight = isMobile ? 100 : 120;
        
        const currentWidth = initialWidth + (finalWidth - initialWidth) * expansion;
        const currentHeight = initialHeight + (finalHeight - initialHeight) * expansion;
        
        videoFrame.style.width = `${currentWidth}px`;
        videoFrame.style.height = `${currentHeight}px`;

        const textOffset = isMobile ? 200 : 400;
        const textProgress = Math.min(1, progress * 1.5);
        leftText.style.transform = `translateX(${-textProgress * textOffset}px)`;
        leftText.style.opacity = `${Math.max(0, 1 - textProgress * 2.5)}`;
        
        rightText.style.transform = `translateX(${textProgress * textOffset}px)`;
        rightText.style.opacity = `${Math.max(0, 1 - textProgress * 2.5)}`;

        if (progress > 0.8) {
          const overlayFade = Math.min(1, (progress - 0.8) / 0.2);
          // Only show play button if paused
          if (video.paused) {
            playOverlay.style.opacity = `${overlayFade}`;
            playOverlay.style.pointerEvents = "auto";
            controls.style.opacity = "0";
            controls.style.pointerEvents = "none";
          } else {
            playOverlay.style.opacity = "0";
            playOverlay.style.pointerEvents = "none";
            controls.style.opacity = `${overlayFade}`;
            controls.style.pointerEvents = "auto";
          }
          videoFrame.style.boxShadow = "0 60px 120px rgba(0,0,0,0.15)";
        } else {
          playOverlay.style.opacity = "0";
          playOverlay.style.pointerEvents = "none";
          controls.style.opacity = "0";
          controls.style.pointerEvents = "none";
          videoFrame.style.boxShadow = "0 40px 100px rgba(0,0,0,0.1)";
        }
      });
    }, { passive: true });

    playOverlay.addEventListener("click", (e) => {
      e.stopPropagation();
      video.play();
      playOverlay.style.opacity = "0";
      playOverlay.style.pointerEvents = "none";
      controls.style.opacity = "1";
      controls.style.pointerEvents = "auto";
    });

    controls.addEventListener("click", (e) => {
      e.stopPropagation();
      video.pause();
      controls.style.opacity = "0";
      controls.style.pointerEvents = "none";
      playOverlay.style.opacity = "1";
      playOverlay.style.pointerEvents = "auto";
    });
  }

  initVideoScroll();
  document.addEventListener("astro:after-swap", initVideoScroll);
</script>

<style>
  .video-scroll-container {
    /* Ensure no scrollbars inside the sticky module */
    -webkit-overflow-scrolling: touch;
  }

  .expanding-video-frame {
    /* Smooth transitions for the styles if needed, though scroll listener handles most */
    transition: box-shadow 0.3s ease;
    box-shadow: 0 40px 100px rgba(0, 0, 0, 0.1);
  }

  @media (max-width: 768px) {
    .animation-content {
      flex-direction: column;
      gap: 20px;
    }
    .expanding-video-frame {
      max-width: 90vw;
    }
  }
</style>
