---
/**
 * Blog Hero Component
 * Minimal, light-themed hero based on the requested design.
 */
---

<section
  class="w-full bg-[#F6F7FF] pt-[180px] pb-[80px] flex flex-col items-center justify-center overflow-hidden"
>
  <div class="w-full max-w-[1540px] px-[50px] mx-auto flex flex-col items-center text-center gap-5">
    
    <!-- Label: Blog -->
    <div class="reveal-on-scroll">
      <p class="m-0 text-(--color-spring-green-8) font-inter text-base font-normal leading-[1.2]">
        Blog
      </p>
    </div>

    <!-- Heading: Journey to a healthier, brighter smile. -->
    <div class="w-full max-w-[800px] reveal-on-scroll stagger-1">
      <h1 class="m-0 text-(--color-spring-green-8) font-bricolage text-[56px] lg:text-[72px] font-medium leading-[1.1] tracking-tight italic-free">
        Stay Updated with 3D Treatment Planning.
      </h1>
    </div>

  </div>
</section>
