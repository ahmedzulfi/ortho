---
/**
 * Hero Banner Section
 * Video background with brightness filter and bottom-aligned content.
 */
---

<section
  id="banner"
  class="relative w-full min-h-[510px] flex flex-row items-center justify-center pt-[220px] px-0 pb-[80px] box-border overflow-visible"
>
  {/* Video Background Container */}
  <div class="absolute inset-0 z-0 brightness-[0.5] pointer-events-none overflow-hidden">
    <video
      autoplay
      loop
      muted
      playsinline
      poster="https://framerusercontent.com/images/QZcT8U16OIs9tqgJachnJ2ZZZH0.png"
      preload="auto"
      src="https://videos.pexels.com/video-files/4490311/4490311-uhd_2560_1440_25fps.mp4"
      class="w-full h-full object-cover object-center block"
    ></video>
  </div>

  {/* Content Layer */}
  <div
    class="relative z-10 w-full max-w-[1540px] px-[50px] flex flex-row items-end justify-start gap-[70px] box-border"
  >
    {/* Headline Column */}
    <div class="flex-1 max-w-[460px] flex flex-col justify-start shrink-0 whitespace-pre-wrap break-words outline-none opacity-100 transform-none reveal-on-scroll">
      <h1 class="text-white text-[clamp(40px,7vw,64px)] font-normal leading-[1.2em] m-0 italic-free">
        Exceptional dental care.
      </h1>
    </div>

    {/* Description & Button Column */}
    <div class="flex-1 max-w-[325px] flex flex-col items-start justify-start gap-[40px] box-border reveal-on-scroll stagger-1">
      <div class="w-full flex flex-col justify-start shrink-0 whitespace-pre-wrap break-words outline-none opacity-100 transform-none">
        <p class="text-white text-[18px] leading-[1.2em] font-normal m-0">
          Our team is committed to delivering top-quality, compassionate treatments in a comfortable environment.
        </p>
      </div>

      <div class="relative w-auto h-auto opacity-100 transform-none">
        <a
          href="/contact-us"
          class="flex flex-col items-center justify-center p-[20px_30px] bg-[#F6F7FF] rounded-[60px] no-underline cursor-pointer"
        >
          <div class="relative w-auto h-auto flex flex-col justify-start shrink-0 whitespace-pre opacity-100 transform-none outline-none">
            <p class="text-[16px] leading-[1.2em] font-normal text-[#000] m-0">Book Now</p>
          </div>
        </a>
      </div>
    </div>
  </div>
</section>
