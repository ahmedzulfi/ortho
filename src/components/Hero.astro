---
/**
 * Hero Banner Section
 * Video background with brightness filter and bottom-aligned content.
 */
---

<section
  id="banner"
  class="relative w-full min-h-[510px] flex flex-col items-center justify-center pt-24 md:pt-[220px] px-0 pb-12 md:pb-[80px] box-border overflow-hidden"
>
  {/* Video Background Container */}
  <div class="absolute inset-0 z-0 brightness-[0.5] pointer-events-none overflow-hidden">
    <video
      autoplay
      loop
      muted
      playsinline
      poster="/hero_aligner_tray_close_up_1776503491227.png"
      preload="metadata"
      src="https://videos.pexels.com/video-files/4490311/4490311-uhd_2560_1440_25fps.mp4"
      class="w-full h-full object-cover object-center block"
    ></video>
  </div>

  {/* Content Layer */}
  <div
    class="relative z-10 w-full max-w-[1540px] px-6 md:px-[50px] flex flex-col md:flex-row items-start md:items-end justify-start gap-4 md:gap-[70px] box-border"
  >
    {/* Headline Column */}
    <div class="flex-1 max-w-full md:max-w-[550px] flex flex-col justify-start shrink-0 whitespace-pre-wrap break-words outline-none opacity-100 transform-none reveal-on-scroll">
      <h1 class="text-white text-[clamp(32px,10vw,64px)] font-normal leading-[0.95] md:leading-[1.1] m-0 italic-free tracking-tighter">
        Premium Dental Aligner Manufacturing
      </h1>
    </div>

    {/* Description & Button Column */}
    <div class="flex-1 max-w-full md:max-w-[325px] flex flex-col items-start justify-start gap-4 md:gap-[40px] box-border reveal-on-scroll stagger-1">
      <div class="w-full flex flex-col justify-start shrink-0 whitespace-pre-wrap break-words outline-none opacity-100 transform-none">
        <p class="text-white text-[16px] md:text-[18px] leading-[1.4] md:leading-[1.2em] font-normal m-0 opacity-90">
          Precision-engineered clear aligners and expert 3D treatment planning, designed to empower dental professionals with high-accuracy results and rapid turnaround.
        </p>
      </div>

      <div class="relative w-auto h-auto opacity-100 transform-none">
        <a
          href="/contact"
          class="flex flex-col items-center justify-center p-[20px_30px] bg-[#F6F7FF] rounded-[60px] no-underline cursor-pointer"
        >
          <div class="relative w-auto h-auto flex flex-col justify-start shrink-0 whitespace-pre opacity-100 transform-none outline-none">
            <p class="text-[16px] leading-[1.2em] font-normal text-[#000] m-0">Get Started</p>
          </div>
        </a>
      </div>
    </div>
  </div>
</section>
