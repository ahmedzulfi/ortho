---
import Ballpit from "./Ballpit.astro";
---

<section
  id="banner"
  class="relative w-full min-h-[690px] flex flex-col items-center justify-center pt-24 md:pt-[30px] px-0 pb-12 md:pb-[80px] box-border overflow-hidden bg-black"
>
  {/* Ballpit Background Container */}
  <div
    class="hidden md:block absolute inset-0 z-0 pointer-events-auto overflow-hidden"
  >
    <Ballpit
      count={30}
      gravity={1}
      friction={0.99}
      wallBounce={0.65}
      maxVelocity={0.8}
      followCursor={true}
      colors={[0xffffff, 0xd1fc71, 0xffffff, 0xd1fc71]}
    />
  </div>

  {/* Content Layer */}
  <div
    class="relative z-10 w-full max-w-[1440px] px-6 md:px-[50px] mx-auto flex flex-col md:flex-row items-center justify-between gap-8 md:gap-[70px] h-full pointer-events-none"
  >
    <div
      class="flex-1 max-w-full md:max-w-[750px] flex flex-col justify-start reveal-on-scroll"
    >
      <h1
        class="text-white text-[clamp(32px,10vw,84px)] font-normal leading-[0.95] md:leading-[1.1] m-0 italic-free tracking-tighter"
      >
        We Build Your SaaS In Weeks Not Months
      </h1>
    </div>

    <div
      class="flex-1 max-w-full md:max-w-[420px] flex flex-col items-start justify-start gap-6 reveal-on-scroll stagger-1"
    >
      <p
        class="text-white/80 text-lg md:text-xl font-['Inter'] leading-relaxed mt-2"
      >
        We partner with ambitious founders to architect, build, and deploy
        high-performance, production-grade software systems in weeks, not
        months.
      </p>

      <div class="mt-2 pointer-events-auto">
        <a
          href="/contact"
          class="btn-premium-morph inline-flex items-center justify-center py-4 px-10 bg-[#D1FC71] rounded-full no-underline transition-transform hover:scale-[0.98]"
        >
          <span class="text-base font-['Inter'] font-semibold text-[#0A0F1E]"
            >Start Your Build</span
          >
        </a>
      </div>
    </div>
  </div>
</section>
