---
/**
 * Footer Component - Orthodontics Align
 * Featuring "Let's Connect" section and comprehensive navigation.
 */
---

<footer class="w-full bg-[var(--color-spring-green-8,#0D1B15)] overflow-hidden flex flex-col items-center box-border">
  <div class="w-full max-w-[1440px] pt-12 md:pt-[120px] px-6 md:px-[50px] pb-10 md:pb-[80px] flex flex-col justify-center items-center gap-10 md:gap-16 box-border">
    
    <!-- Top Row: Let's Connect & Email -->
    <div class="reveal-on-scroll self-stretch min-h-[124px] flex flex-wrap justify-between items-end gap-10">
      <div class="flex flex-col justify-center items-start gap-3">
        <div class="flex flex-col justify-center items-start">
          <div class="self-stretch pb-0 flex flex-col justify-start items-start">
            <h2 class="m-0 text-white text-3xl md:text-[48px] font-['Bricolage_Grotesque'] font-medium leading-[1.2]">Let's Connect</h2>
          </div>
        </div>
        <div class="self-stretch flex flex-col justify-center items-start">
          <div class="flex flex-col gap-1">
            <a href="tel:+923219473647" class="hover-lift text-white text-base font-['Inter'] font-normal leading-[1.7] no-underline">+92 321 9473647</a>
            <div class="text-white text-base font-['Inter'] font-normal leading-[1.7]">We are open 24/7</div>
          </div>
        </div>
      </div>

      <div class="flex flex-col justify-center items-start gap-3">
        <div class="text-white text-sm md:text-base font-['Inter'] font-normal leading-[1.7]">Reach out to us at:</div>
        <a href="mailto:info.orthodonticsalign@gmail.com" class="hover-lift text-white text-[22px] md:text-[48px] font-['Bricolage_Grotesque'] font-medium leading-[1.2] no-underline break-all">info.orthodonticsalign@gmail.com</a>
        <div class="flex gap-3 md:gap-4 mt-4 md:mt-6">
          <!-- Instagram -->
          <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="hover-lift w-10 h-10 md:w-12 md:h-12 bg-white/5 rounded-full flex items-center justify-center no-underline">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
          </a>
          <!-- LinkedIn -->
          <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="hover-lift w-10 h-10 md:w-12 md:h-12 bg-white/5 rounded-full flex items-center justify-center no-underline">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
          </a>
          <!-- Facebook -->
          <a href="https://facebook.com" target="_blank" rel="noopener noreferrer" class="hover-lift w-10 h-10 md:w-12 md:h-12 bg-white/5 rounded-full flex items-center justify-center no-underline">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="self-stretch h-[1px] bg-white/10 my-10 md:my-[60px]"></div>

    <!-- Links Grid -->
    <div class="self-stretch flex justify-between items-start flex-wrap gap-8 md:gap-[60px]">
      
      <!-- Nav Columns Group -->
      <div class="reveal-on-scroll stagger-1 flex gap-8 md:gap-[100px] flex-wrap">
        <!-- Menu -->
        <div class="flex flex-col justify-start items-start gap-6">
          <div class="text-[var(--color-grey-78,#C9CBC5)] text-base font-['Inter'] font-normal">Menu</div>
          <div class="flex flex-col justify-start items-start gap-3">
            <a href="/" class="text-[var(--color-chartreuse-green-72,#D1FC71)] text-base font-['Inter'] no-underline">Home</a>
            <a href="/about" class="text-white text-base font-['Inter'] no-underline opacity-80">About</a>
            <a href="/services" class="text-white text-base font-['Inter'] no-underline opacity-80">Services</a>
            <a href="/#doctors" class="text-white text-base font-['Inter'] no-underline opacity-80">Doctors</a>
            <a href="/contact" class="text-white text-base font-['Inter'] no-underline opacity-80">Contact</a>
          </div>
        </div>

        <!-- Services -->
        <div class="flex flex-col justify-start items-start gap-6">
          <div class="text-[var(--color-grey-78,#C9CBC5)] text-base font-['Inter'] font-normal">Services</div>
          <div class="flex flex-col justify-start items-start gap-3">
            <a href="/services/3d-treatment-planning" class="text-white text-base font-['Inter'] no-underline opacity-80">3D Treatment Planning</a>
            <a href="/services/aligner-design" class="text-white text-base font-['Inter'] no-underline opacity-80">CAD/CAM Aligner Design</a>
            <a href="/services/aligner-fabrication" class="text-white text-base font-['Inter'] no-underline opacity-80">Precision Manufacturing</a>
            <a href="/services/practice-workflow" class="text-white text-base font-['Inter'] no-underline opacity-80">Scan-to-Print Setup</a>
            <a href="/services/case-consultation" class="text-white text-base font-['Inter'] no-underline opacity-80">Complex Case Consulting</a>
          </div>
        </div>
      </div>

      <!-- Opening Hours & Socials -->
      <div class="reveal-on-scroll stagger-2 flex gap-10 md:gap-[80px] flex-wrap">
        <div class="flex flex-col justify-start items-start gap-6">
          <div class="text-[var(--color-grey-78,#C9CBC5)] text-base font-['Inter'] font-normal">Opening Hours</div>
          <div class="text-white text-base font-['Inter'] no-underline opacity-80">Clinically Open 24/7</div>
        </div>

        <div class="flex flex-col justify-start items-start gap-6">
          <div class="text-[var(--color-grey-78,#C9CBC5)] text-base font-['Inter'] font-normal">Connect</div>
          <div class="flex flex-col justify-start items-start gap-3">
            <a href="tel:+923219473647" class="text-white text-base font-['Inter'] no-underline opacity-80">+92 321 9473647</a>
            <a href="mailto:support@orthoalign.com" class="text-white text-base font-['Inter'] no-underline opacity-80">support@orthoalign.com</a>
            <div class="text-white text-sm font-['Inter'] no-underline opacity-60 leading-[1.5] max-w-[200px]">Lahore, Pakistan<br/>Serving Global Practices</div>
          </div>
        </div>
      </div>

      <!-- Legal Links -->
      <div class="reveal-on-scroll stagger-3 flex gap-10 flex-wrap">
        <div class="flex flex-col justify-start items-start gap-6">
          <div class="text-[var(--color-grey-78,#C9CBC5)] text-base font-['Inter'] font-normal">Legal</div>
          <div class="flex flex-col justify-start items-start gap-3">
            <a href="/privacy" class="text-white text-base font-['Inter'] no-underline opacity-80">Privacy Policy</a>
            <a href="/terms" class="text-white text-base font-['Inter'] no-underline opacity-80">Terms of Service</a>
          </div>
        </div>
      </div>

    </div>

    <!-- Bottom Row: Copyright & Large Brand Signature -->
    <div class="reveal-on-scroll stagger-3 self-stretch pt-12 border-t border-white/5 flex flex-col md:flex-row justify-between items-center md:items-end gap-8 md:gap-10">
      <div class="text-white text-sm md:text-base font-['Inter'] font-normal opacity-60 text-center md:text-left">
        Copyright © 2026 Orthodontics Align. All rights reserved
      </div>
      
      <div class="flex-1 flex justify-center md:justify-end">
        <h2 class="m-0 font-['Bricolage_Grotesque'] text-[32px] md:text-[clamp(60px,8vw,120px)] font-medium text-white tracking-[-0.04em] leading-[0.9] pointer-events-none select-none whitespace-nowrap">
          Orthodontics Align
        </h2>
      </div>
    </div>

  </div>
</footer>
