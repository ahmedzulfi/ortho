---
/**
 * Footer Component - ValidMVPs
 * Featuring "Let's Connect" section and comprehensive navigation.
 */
---

<footer
  class="w-full bg-[var(--color-spring-green-8,#0D1B15)] overflow-hidden flex flex-col items-center box-border"
>
  <div
    class="w-full max-w-[1440px] pt-12 md:pt-[120px] px-6 md:px-[50px] pb-10 md:pb-[80px] flex flex-col justify-center items-center gap-10 md:gap-16 box-border"
  >
    <!-- Top Row: Let's Connect & Email -->
    <div
      class="reveal-on-scroll self-stretch min-h-[124px] flex flex-wrap justify-between items-end gap-10"
    >
      <div class="flex flex-col justify-center items-start gap-3">
        <div class="flex flex-col justify-center items-start">
          <div
            class="self-stretch pb-0 flex flex-col justify-start items-start"
          >
            <h2
              class="m-0 text-white text-3xl md:text-[48px] font-['Bricolage_Grotesque'] font-medium leading-[1.2]"
            >
              Let's Build
            </h2>
          </div>
        </div>
        <div class="self-stretch flex flex-col justify-center items-start">
          <div class="flex flex-col gap-1">
            <div
              class="text-white text-base font-['Inter'] font-normal leading-[1.7]"
            >
              Fast execution for founders
            </div>
            <div
              class="text-white text-base font-['Inter'] font-normal leading-[1.7]"
            >
              Zero to One in record time
            </div>
          </div>
        </div>
      </div>

      <div class="flex flex-col justify-center items-start gap-3">
        <div
          class="text-white text-sm md:text-base font-['Inter'] font-normal leading-[1.7]"
        >
          Reach out to us at:
        </div>
        <a
          href="mailto:hello@validmvps.com"
          class="hover-lift text-white text-[22px] md:text-[48px] font-['Bricolage_Grotesque'] font-medium leading-[1.2] no-underline break-all"
          >hello@validmvps.com</a
        >
        <div class="flex gap-3 md:gap-4 mt-4 md:mt-6">
          <!-- Instagram -->
          <a
            href="https://www.instagram.com/mvpdevs/"
            target="_blank"
            rel="noopener noreferrer"
            class="hover-lift w-10 h-10 md:w-12 md:h-12 bg-white/5 rounded-full flex items-center justify-center no-underline"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="white"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><rect x="2" y="2" width="20" height="20" rx="5" ry="5"
              ></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
              ></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg
            >
          </a>
          <!-- LinkedIn -->
          <a
            href="https://www.linkedin.com/in/ahmedwebdesign/"
            target="_blank"
            rel="noopener noreferrer"
            class="hover-lift w-10 h-10 md:w-12 md:h-12 bg-white/5 rounded-full flex items-center justify-center no-underline"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="white"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
              ></path><rect x="2" y="9" width="4" height="12"></rect><circle
                cx="4"
                cy="4"
                r="2"></circle></svg
            >
          </a>
          <!-- Twitter (X) -->
          <a
            href="https://x.com/AhmedZulfiqr"
            target="_blank"
            rel="noopener noreferrer"
            class="hover-lift w-10 h-10 md:w-12 md:h-12 bg-white/5 rounded-full flex items-center justify-center no-underline"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="white"
              ><path
                d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
              ></path></svg
            >
          </a>
          <!-- WhatsApp -->
          <a
            href="https://wa.me/923180325800"
            target="_blank"
            rel="noopener noreferrer"
            class="hover-lift w-10 h-10 md:w-12 md:h-12 bg-white/5 rounded-full flex items-center justify-center no-underline"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="white"
              xmlns="http://www.w3.org/2000/svg"
              ><path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              ></path></svg
            >
          </a>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="self-stretch h-[1px] bg-white/10 my-10 md:my-[60px]"></div>

    <!-- Links Grid -->
    <div
      class="self-stretch flex justify-between items-start flex-wrap gap-8 md:gap-[60px]"
    >
      <!-- Nav Columns Group -->
      <div
        class="reveal-on-scroll stagger-1 flex gap-8 md:gap-[100px] flex-wrap"
      >
        <!-- Quick Links -->
        <div class="flex flex-col justify-start items-start gap-6">
          <div
            class="text-[var(--color-grey-78,#C9CBC5)] text-base font-['Inter'] font-normal"
          >
            Quick Links
          </div>
          <div class="flex flex-col justify-start items-start gap-3">
            <a
              href="/"
              class="text-[var(--color-chartreuse-green-72,#D1FC71)] text-base font-['Inter'] no-underline"
              >Home</a
            >
            <a
              href="/about-mvp-development/"
              class="text-white text-base font-['Inter'] no-underline opacity-80 hover:opacity-100 transition-opacity"
              >About</a
            >
            <a
              href="/services/"
              class="text-white text-base font-['Inter'] no-underline opacity-80 hover:opacity-100 transition-opacity"
              >Services</a
            >
            <a
              href="/pricing/"
              class="text-white text-base font-['Inter'] no-underline opacity-80 hover:opacity-100 transition-opacity"
              >Pricing</a
            >
            <a
              href="/contact/"
              class="text-white text-base font-['Inter'] no-underline opacity-80 hover:opacity-100 transition-opacity"
              >Contact</a
            >
          </div>
        </div>

        <!-- Solutions -->
        <div class="flex flex-col justify-start items-start gap-6">
          <div
            class="text-[var(--color-grey-78,#C9CBC5)] text-base font-['Inter'] font-normal"
          >
            Solutions
          </div>
          <div class="flex flex-col justify-start items-start gap-3">
            <a
              href="/solutions/ai-startups/"
              class="text-white text-base font-['Inter'] no-underline opacity-80 hover:opacity-100 transition-opacity"
              >AI Startups</a
            >
            <a
              href="/solutions/saas-founders/"
              class="text-white text-base font-['Inter'] no-underline opacity-80 hover:opacity-100 transition-opacity"
              >SaaS Founders</a
            >
            <a
              href="/solutions/enterprise/"
              class="text-white text-base font-['Inter'] no-underline opacity-80 hover:opacity-100 transition-opacity"
              >Enterprise Teams</a
            >
          </div>
        </div>

        <!-- Services -->
        <div class="flex flex-col justify-start items-start gap-6">
          <div
            class="text-[var(--color-grey-78,#C9CBC5)] text-base font-['Inter'] font-normal"
          >
            Services
          </div>
          <div class="flex flex-col justify-start items-start gap-3">
            <a
              href="/services/mvp-development/"
              class="text-white text-base font-['Inter'] no-underline opacity-80 hover:opacity-100 transition-opacity"
              >MVP Development</a
            >
            <a
              href="/services/ai-integration/"
              class="text-white text-base font-['Inter'] no-underline opacity-80 hover:opacity-100 transition-opacity"
              >AI Integration</a
            >
            <a
              href="/services/tech-stack/"
              class="text-white text-base font-['Inter'] no-underline opacity-80 hover:opacity-100 transition-opacity"
              >Scalable Tech Stacks</a
            >
            <a
              href="/services/prototype-to-production/"
              class="text-white text-base font-['Inter'] no-underline opacity-80 hover:opacity-100 transition-opacity"
              >Replit to Production</a
            >
          </div>
        </div>
      </div>

      <!-- Opening Hours & Socials -->
      <div
        class="reveal-on-scroll stagger-2 flex gap-10 md:gap-[80px] flex-wrap"
      >
        <div class="flex flex-col justify-start items-start gap-6">
          <div
            class="text-[var(--color-grey-78,#C9CBC5)] text-base font-['Inter'] font-normal"
          >
            Location
          </div>
          <div
            class="text-white text-base font-['Inter'] no-underline opacity-80"
          >
            Serving Founders Globally
          </div>
        </div>

        <div class="flex flex-col justify-start items-start gap-6">
          <div
            class="text-[var(--color-grey-78,#C9CBC5)] text-base font-['Inter'] font-normal"
          >
            Connect
          </div>
          <div class="flex flex-col justify-start items-start gap-3">
            <a
              href="mailto:hello@validmvps.com"
              class="text-white text-base font-['Inter'] no-underline opacity-80"
              >hello@validmvps.com</a
            >
            <a
              href="https://wa.me/923180325800"
              target="_blank"
              rel="noopener noreferrer"
              class="text-white text-base font-['Inter'] no-underline opacity-80 flex items-center gap-2"
            >
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="white"
                xmlns="http://www.w3.org/2000/svg"
                ><path
                  d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                ></path></svg
              >
              +92 3180325800
            </a>
            <div
              class="text-white text-sm font-['Inter'] no-underline opacity-60 leading-[1.5] max-w-[200px]"
            >
              Remote First<br />Available Globally
            </div>
          </div>
        </div>
      </div>

      <!-- Legal Links -->
      <div class="reveal-on-scroll stagger-3 flex gap-10 flex-wrap">
        <div class="flex flex-col justify-start items-start gap-6">
          <div
            class="text-[var(--color-grey-78,#C9CBC5)] text-base font-['Inter'] font-normal"
          >
            Legal
          </div>
          <div class="flex flex-col justify-start items-start gap-3">
            <a
              href="/privacy/"
              class="text-white text-base font-['Inter'] no-underline opacity-80"
              >Privacy Policy</a
            >
            <a
              href="/terms/"
              class="text-white text-base font-['Inter'] no-underline opacity-80"
              >Terms of Service</a
            >
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Row: Copyright & Large Brand Signature -->
    <div
      class="reveal-on-scroll stagger-3 self-stretch pt-12 border-t border-white/5 flex flex-col md:flex-row justify-between items-center md:items-end gap-8 md:gap-10"
    >
      <div
        class="text-white text-sm md:text-base font-['Inter'] font-normal opacity-60 text-center md:text-left"
      >
        Copyright © 2026 ValidMVPs. All rights reserved
      </div>

      <div class="flex-1 flex justify-center md:justify-end">
        <h2
          class="m-0 font-['Bricolage_Grotesque'] text-[32px] md:text-[clamp(60px,8vw,120px)] font-medium text-white tracking-[-0.04em] leading-[0.9] pointer-events-none select-none whitespace-nowrap"
        >
          Valid<span class="text-[#D1FC71]">MVPs</span>
        </h2>
      </div>
    </div>
  </div>
</footer>
