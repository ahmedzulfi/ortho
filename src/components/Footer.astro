---
/**
 * Footer Component - Orthodontics Align
 * Featuring "Let's Connect" section and comprehensive navigation.
 */
---

<footer style="width: 100%; background: var(--color-spring-green-8, #0D1B15); overflow: hidden; display: flex; flex-direction: column; align-items: center; box-sizing: border-box;">
  <div style="width: 100%; max-width: 1440px; padding: 120px 50px 80px 50px; flex-direction: column; justify-content: center; align-items: center; gap: 64px; display: flex; box-sizing: border-box;">
    
    <!-- Top Row: Let's Connect & Email -->
    <div class="reveal-on-scroll" style="align-self: stretch; min-height: 124px; justify-content: space-between; align-items: flex-end; display: flex; flex-wrap: wrap; gap: 40px;">
      <div style="flex-direction: column; justify-content: center; align-items: flex-start; gap: 12px; display: flex;">
        <div style="flex-direction: column; justify-content: center; align-items: flex-start; display: flex;">
          <div style="align-self: stretch; padding-bottom: 0px; flexDirection: column; justify-content: flex-start; align-items: flex-start; display: flex;">
            <h2 style="margin: 0; color: white; font-size: 48px; font-family: 'Bricolage Grotesque'; font-weight: 500; line-height: 1.2;">Let's Connect</h2>
          </div>
        </div>
        <div style="align-self: stretch; flexDirection: column; justify-content: center; align-items: flex-start; display: flex;">
          <div style="display: flex; flex-direction: column; gap: 4px;">
            <a href="tel:+923219473647" class="hover-lift" style="color: white; font-size: 16px; font-family: 'Inter'; font-weight: 400; line-height: 1.7; text-decoration: none;">+92 321 9473647</a>
            <div style="color: white; font-size: 16px; font-family: 'Inter'; font-weight: 400; line-height: 1.7;">We are open 24/7</div>
          </div>
        </div>
      </div>

      <div style="flex-direction: column; justify-content: center; align-items: flex-start; gap: 12px; display: flex;">
        <div style="color: white; font-size: 16px; font-family: 'Inter'; font-weight: 400; line-height: 1.7;">Reach out to us at:</div>
        <a href="mailto:info.orthodonticsalign@gmail.com" class="hover-lift" style="color: white; font-size: 48px; font-family: 'Bricolage Grotesque'; font-weight: 500; line-height: 1.2; text-decoration: none; word-break: break-all;">info.orthodonticsalign@gmail.com</a>
        <div style="display: flex; gap: 16px; margin-top: 24px;">
          <!-- Instagram -->
          <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="hover-lift" style="width: 48px; height: 48px; background: rgba(255,255,255,0.05); border-radius: 50%; display: flex; align-items: center; justify-content: center; text-decoration: none;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
          </a>
          <!-- LinkedIn -->
          <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="hover-lift" style="width: 48px; height: 48px; background: rgba(255,255,255,0.05); border-radius: 50%; display: flex; align-items: center; justify-content: center; text-decoration: none;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
          </a>
          <!-- Facebook -->
          <a href="https://facebook.com" target="_blank" rel="noopener noreferrer" class="hover-lift" style="width: 48px; height: 48px; background: rgba(255,255,255,0.05); border-radius: 50%; display: flex; align-items: center; justify-content: center; text-decoration: none;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div style="align-self: stretch; height: 1px; background: rgba(255,255,255,0.1); margin: 60px 0;"></div>

    <!-- Links Grid -->
    <div style="align-self: stretch; display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 60px;">
      
      <!-- Nav Columns Group -->
      <div class="reveal-on-scroll stagger-1" style="display: flex; gap: 100px; flex-wrap: wrap;">
        <!-- Menu -->
        <div style="flex-direction: column; justify-content: flex-start; align-items: flex-start; gap: 24px; display: flex;">
          <div style="color: var(--color-grey-78, #C9CBC5); font-size: 16px; font-family: 'Inter'; font-weight: 400;">Menu</div>
          <div style="flex-direction: column; justify-content: flex-start; align-items: flex-start; gap: 12px; display: flex;">
            <a href="/" style="color: var(--color-chartreuse-green-72, #D1FC71); font-size: 16px; font-family: 'Inter'; text-decoration: none;">Home</a>
            <a href="/about" style="color: white; font-size: 16px; font-family: 'Inter'; text-decoration: none; opacity: 0.8;">About</a>
            <a href="/services" style="color: white; font-size: 16px; font-family: 'Inter'; text-decoration: none; opacity: 0.8;">Services</a>
            <a href="/#doctors" style="color: white; font-size: 16px; font-family: 'Inter'; text-decoration: none; opacity: 0.8;">Doctors</a>
            <a href="/contact" style="color: white; font-size: 16px; font-family: 'Inter'; text-decoration: none; opacity: 0.8;">Contact</a>
          </div>
        </div>

        <!-- Services -->
        <div style="flex-direction: column; justify-content: flex-start; align-items: flex-start; gap: 24px; display: flex;">
          <div style="color: var(--color-grey-78, #C9CBC5); font-size: 16px; font-family: 'Inter'; font-weight: 400;">Services</div>
          <div style="flex-direction: column; justify-content: flex-start; align-items: flex-start; gap: 12px; display: flex;">
            <a href="/services/3d-treatment-planning" style="color: white; font-size: 16px; font-family: 'Inter'; text-decoration: none; opacity: 0.8;">3D Treatment Planning</a>
            <a href="/services/aligner-design" style="color: white; font-size: 16px; font-family: 'Inter'; text-decoration: none; opacity: 0.8;">CAD/CAM Aligner Design</a>
            <a href="/services/aligner-fabrication" style="color: white; font-size: 16px; font-family: 'Inter'; text-decoration: none; opacity: 0.8;">Precision Fabrication</a>
            <a href="/services/practice-workflow" style="color: white; font-size: 16px; font-family: 'Inter'; text-decoration: none; opacity: 0.8;">Practice Workflow Setup</a>
            <a href="/services/case-consultation" style="color: white; font-size: 16px; font-family: 'Inter'; text-decoration: none; opacity: 0.8;">Complex Case Consultation</a>
          </div>
        </div>
      </div>

      <!-- Opening Hours & Socials -->
      <div class="reveal-on-scroll stagger-2" style="display: flex; gap: 80px; flex-wrap: wrap;">
        <div style="flex-direction: column; justify-content: flex-start; align-items: flex-start; gap: 24px; display: flex;">
          <div style="color: var(--color-grey-78, #C9CBC5); font-size: 16px; font-family: 'Inter'; font-weight: 400;">Opening Hours</div>
          <div style="color: white; font-size: 16px; font-family: 'Inter'; text-decoration: none; opacity: 0.8;">We are open 24/7</div>
        </div>

        <div style="flex-direction: column; justify-content: flex-start; align-items: flex-start; gap: 24px; display: flex;">
          <div style="color: var(--color-grey-78, #C9CBC5); font-size: 16px; font-family: 'Inter'; font-weight: 400;">Connect</div>
          <div style="flex-direction: column; justify-content: flex-start; align-items: flex-start; gap: 12px; display: flex;">
            <a href="tel:+923219473647" style="color: white; font-size: 16px; font-family: 'Inter'; text-decoration: none; opacity: 0.8;">+92 321 9473647</a>
            <a href="mailto:info.orthodonticsalign@gmail.com" style="color: white; font-size: 16px; font-family: 'Inter'; text-decoration: none; opacity: 0.8;">info.orthodonticsalign@gmail.com</a>
            <div style="color: white; font-size: 14px; font-family: 'Inter'; text-decoration: none; opacity: 0.6; line-height: 1.5; max-width: 200px;">Lahore, Pakistan<br/>Serving Global Practices</div>
          </div>
        </div>
      </div>

      <!-- Legal Links -->
      <div class="reveal-on-scroll stagger-3" style="display: flex; gap: 40px; flex-wrap: wrap;">
        <div style="flex-direction: column; justify-content: flex-start; align-items: flex-start; gap: 24px; display: flex;">
          <div style="color: var(--color-grey-78, #C9CBC5); font-size: 16px; font-family: 'Inter'; font-weight: 400;">Legal</div>
          <div style="flex-direction: column; justify-content: flex-start; align-items: flex-start; gap: 12px; display: flex;">
            <a href="/privacy" style="color: white; font-size: 16px; font-family: 'Inter'; text-decoration: none; opacity: 0.8;">Privacy Policy</a>
            <a href="/terms" style="color: white; font-size: 16px; font-family: 'Inter'; text-decoration: none; opacity: 0.8;">Terms of Service</a>
          </div>
        </div>
      </div>

    </div>

    <!-- Bottom Row: Copyright & Large Brand Signature -->
    <div class="reveal-on-scroll stagger-3" style="align-self: stretch; padding-top: 64px; border-top: 1px solid rgba(255,255,255,0.05); justify-content: space-between; align-items: flex-end; display: flex; flex-wrap: wrap; gap: 40px;">
      <div style="color: white; font-size: 16px; font-family: 'Inter'; font-weight: 400; opacity: 0.6;">
        Copyright © 2026 Orthodontics Align. All rights reserved
      </div>
      
      <div style="flex: 1; display: flex; justify-content: flex-end;">
        <h2 style="margin: 0; font-family: 'Bricolage Grotesque'; font-size: clamp(40px, 10vw, 120px); font-weight: 500; color: white; letter-spacing: -0.04em; line-height: 0.9; pointer-events: none; user-select: none; white-space: nowrap;">
          Orthodontics Align
        </h2>
      </div>
    </div>

  </div>
</footer>
