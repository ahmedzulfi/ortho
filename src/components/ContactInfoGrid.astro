---
/**
 * Contact Info Grid Component - ValidMVPs
 */
const contactInfo = [
  {
    label: "Phone",
    value: "+92 3180325800",
    link: "tel:+923180325800",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>`,
  },
  {
    label: "Email",
    value: "ahmedzulfiqar.dev@gmail.com",
    link: "mailto:ahmedzulfiqar.dev@gmail.com",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>`,
  },
  {
    label: "Location",
    value: "Remote First - Working Globally",
    link: "#",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>`,
  },
  {
    label: "Availability",
    value: "Global 24/7 Support",
    link: "#",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>`,
  },
];
---

<section class="w-full bg-[#F6F7FF] pb-24">
  <div class="w-full max-w-[1540px] px-[50px] mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {
        contactInfo.map((item, idx) => (
          <a
            href={item.link}
            class={`reveal-on-scroll stagger-${idx + 1} group flex flex-col items-center text-center p-10 bg-white rounded-[24px] no-underline transition-all duration-500 hover:shadow-xl hover:-translate-y-2 border border-[#E2E8F0] h-full`}
          >
            <div class="w-16 h-16 bg-[#60A5FA] rounded-2xl flex items-center justify-center text-(--color-spring-green-8) mb-8 transition-transform duration-500 group-hover:scale-110">
              <Fragment set:html={item.icon} />
            </div>
            <div class="flex flex-col gap-3">
              <h5 class="m-0 text-(--color-grey-36) font-inter text-sm font-bold uppercase tracking-wider">
                {item.label}
              </h5>
              <p class="m-0 text-(--color-spring-green-8) font-bricolage text-xl font-medium leading-[1.3] group-hover:text-black transition-colors">
                {item.value}
              </p>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
