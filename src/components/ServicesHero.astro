---
/**
 * ServicesHero Section
 * Features a split layout with a large typography heading, description, 
 * and an infinitely scrolling horizontal marquee of images at the bottom.
 */

// Image configuration to match the organic, irregular widths of the original design
const galleryCards = [
  { src: "/images/dental_clinic.png", width: "359px" },
  { src: "/images/patient_smile.png", width: "250px" },
  { src: "/images/dentist_friendly.png", width: "359px" },
  { src: "/images/dental_clinic.png", width: "480px" },
  { src: "/images/patient_smile.png", width: "251px" },
  { src: "/images/dentist_friendly.png", width: "354px" }
];
---

<section class="w-full flex flex-col items-center justify-start bg-white overflow-hidden pt-48 pb-20 relative">
  
  <div class="w-full max-w-[1440px] px-[50px] flex flex-col lg:flex-row justify-between items-end gap-10 lg:gap-20 mb-20 z-10 relative reveal-on-scroll">
    
    <!-- Left: Large Heading -->
    <div class="shrink-0 w-full lg:w-[600px]">
      <h1 class="m-0 text-(--color-spring-green-8) font-bricolage text-[72px] lg:text-[96px] font-medium leading-none tracking-tight">
        Dental Care<br/>for All Smiles
      </h1>
    </div>

    <!-- Right: Description & Year -->
    <div class="flex w-full lg:w-auto items-end gap-6 pb-2">
      <div class="flex flex-col">
        <p class="m-0 text-(--color-grey-36) font-inter text-base leading-[1.7] max-w-[390px]">
          From checkups to treatments, we<br/>keep your smile healthy and bright.
        </p>
      </div>
      <div class="flex flex-col mb-[-10px]">
        <span class="text-(--color-spring-green-8) font-bricolage text-[86px] font-medium leading-[0.8] tracking-tight">
          ©25
        </span>
      </div>
    </div>

  </div>

  <!-- Bottom: Infinite Image Marquee with Irregular Widths -->
  <div class="w-full relative mt-10" style="height: 270px; display: flex; overflow: hidden;">
    <div class="marquee-track flex gap-4" style="height: 100%;">
      
      <!-- Original Set -->
      {galleryCards.map((card, idx) => (
        <div class="marquee-item shrink-0 h-full rounded-3xl overflow-hidden relative" style={`width: ${card.width};`}>
           <img src={card.src} alt={`Dental Practice ${idx}`} class="w-full h-full object-cover" />
        </div>
      ))}
      
      <!-- Cloned Set for Seamless Loop -->
      {galleryCards.map((card, idx) => (
        <div class="marquee-item shrink-0 h-full rounded-3xl overflow-hidden relative" style={`width: ${card.width};`} aria-hidden="true">
           <img src={card.src} alt={`Dental Practice clone ${idx}`} class="w-full h-full object-cover" />
        </div>
      ))}

    </div>
  </div>

</section>

<style>
  .marquee-track {
    animation: marquee 30s linear infinite;
    /* Optional: Pause on hover */
    /* pointer-events: auto; */
  }

  .marquee-track:hover {
    animation-play-state: paused;
  }

  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      /* Translation depends on the exact width of one set of items + gaps. 
         Using a percentage works if the track width is calculable, 
         but for robust CSS marquees, -50% shifts exactly half the track length */
      transform: translateX(-50%);
    }
  }

  /* Since we duplicated the items exactly once, shifting by -50% perfectly loops it */
  .marquee-track {
    width: max-content;
  }
</style>
