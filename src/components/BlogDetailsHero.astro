---
/**
 * Blog Details Hero Component - Orthodontics Align Edition
 * Displays the title, author metadata, and featured image for a specific blog post.
 */
interface Props {
  title: string;
  excerpt: string;
  authorName: string;
  authorImage: string;
  publishDate: string;
  featuredImage: string;
}

const { 
  title = "The benefits of 3D Treatment Planning",
  excerpt = "Digital planning provides an extra level of precision that traditional methods cannot achieve, ensuring predictable and accurate aligner results.",
  authorName = "Abdul Sami",
  authorImage = "https://framerusercontent.com/images/i51F5Pye2h2lXWmET6L6xg4nu6o.png?width=800",
  publishDate = "Mar 13, 2026",
  featuredImage = "https://framerusercontent.com/images/216OAsY94JtO7mDWlB4OG3ZZFN0.jpg"
} = Astro.props;
---

<section class="w-full bg-[#F6F7FF] pt-[180px] pb-12">
  <div class="w-full max-w-[1100px] px-[50px] mx-auto flex flex-col items-center">
    
    <!-- Title & Excerpt Container -->
    <div class="w-full text-center mb-12">
      <h1 class="m-0 text-(--color-spring-green-8) font-bricolage text-[48px] lg:text-[72px] font-medium leading-[1.1] mb-8 reveal-on-scroll">
        {title}
      </h1>
      <p class="m-0 text-(--color-grey-36) font-inter text-lg lg:text-2xl leading-[1.6] max-w-[1100px] mx-auto reveal-on-scroll stagger-1">
        {excerpt}
      </p>
    </div>

    <!-- Metadata: Author & Date -->
    <div class="flex flex-col md:flex-row items-center gap-6 mb-16 reveal-on-scroll stagger-2">
      <!-- Author -->
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-full overflow-hidden">
          <img src={authorImage} alt={authorName} class="w-full h-full object-cover" />
        </div>
        <span class="text-[#0D1B15] font-inter text-base font-medium">{authorName}</span>
      </div>
      
      <!-- Divider -->
      <div class="hidden md:block w-1.5 h-1.5 rounded-full bg-[#D1FC71]"></div>

      <!-- Date -->
      <span class="text-(--color-grey-36) font-inter text-base">{publishDate}</span>
    </div>

    <!-- Featured Image Container -->
    <div class="w-full aspect-video lg:aspect-21/9 rounded-[32px] overflow-hidden reveal-on-scroll stagger-3 shadow-sm border border-[#E2E8F0]">
      <img
        src={featuredImage}
        alt={title}
        class="w-full h-full object-cover"
      />
    </div>

  </div>
</section>
