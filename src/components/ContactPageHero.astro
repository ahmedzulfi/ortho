---
/**
 * Contact Page Hero Component - Orthodontics Align
 * Visual hero with background image and contact info cards.
 * Updated with official brand colors: Spring Green & Dark Forest.
 */
---

<section
  class="contact-hero-section"
  style="box-sizing: border-box; width: 100%; min-height: 700px; height: 85vh; max-height: 900px; display: flex; flex-direction: column; position: relative; overflow: hidden; background-color: #F6F7FF;"
>
  <!-- Background Image Layer -->
  <div
    class="hero-bg"
    style="position: absolute; inset: 0; z-index: 1;"
  >
    <img
      height="765"
      width="1897"
      alt="Contact background image"
      src="https://framerusercontent.com/images/9ds4Xj4YacbFfdyXqGt6AiEbIE.png"
      style="width: 100%; height: 100%; object-fit: cover; object-position: center;"
    />
    <!-- Brand-aligned overlay -->
    <div style="position: absolute; inset: 0; background: linear-gradient(to bottom, transparent 40%, rgba(13, 27, 21, 0.3));"></div>
  </div>

  <!-- Cards Container - Pinned to Bottom Center -->
  <div
    class="hero-content-container"
    style="position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); z-index: 10; width: 100%; max-width: 1100px; display: flex; justify-content: center;"
  >
    <div
      class="info-cards-grid"
      style="display: flex; width: 100%; border-top-left-radius: 20px; border-top-right-radius: 20px; overflow: hidden; box-shadow: 0 -15px 40px rgba(13, 27, 21, 0.12);"
    >
      
      <!-- Card 1: Opening Hours (Neutral) -->
      <div
        class="contact-card"
        style="flex: 1; background-color: #FFFFFF; padding: 45px 35px; display: flex; flex-direction: column; gap: 24px; min-width: 0;"
      >
        <h4 style="margin: 0; font-family: 'Bricolage Grotesque'; font-weight: 500; color: #0D1B15; font-size: 20px; letter-spacing: -0.02em;">Opening Hours</h4>
        <div style="display: flex; flex-direction: column; gap: 14px;">
          <div style="display: flex; justify-content: space-between; align-items: center;">
            <span style="font-family: 'Inter'; font-size: 15px; color: #595E5C;">Monday - Sunday</span>
            <span style="font-family: 'Inter'; font-size: 15px; font-weight: 600; color: #0D1B15;">Open 24/7</span>
          </div>
        </div>
      </div>

      <!-- Card 2: Office Location (Chartreuse Green) -->
      <div
        class="contact-card"
        style="flex: 1; background-color: var(--color-chartreuse-green-72, #D1FC71); padding: 45px 35px; display: flex; flex-direction: column; gap: 24px; min-width: 0;"
      >
        <h4 style="margin: 0; font-family: 'Bricolage Grotesque'; font-weight: 500; color: #0D1B15; font-size: 20px; letter-spacing: -0.02em;">Office Location</h4>
        <div style="display: flex; flex-direction: column; gap: 14px;">
          <div style="display: flex; justify-content: space-between; align-items: center; gap: 10px;">
            <span style="font-family: 'Inter'; font-size: 15px; color: rgba(13, 27, 21, 0.7);">Place</span>
            <span style="font-family: 'Inter'; font-size: 15px; font-weight: 600; color: #0D1B15; text-align: right;">Lahore Regional Office</span>
          </div>
          <div style="display: flex; justify-content: space-between; align-items: center; gap: 10px;">
            <span style="font-family: 'Inter'; font-size: 15px; color: rgba(13, 27, 21, 0.7);">Number</span>
            <span style="font-family: 'Inter'; font-size: 15px; font-weight: 600; color: #0D1B15; text-align: right;">+92 321 9473647</span>
          </div>
          <div style="display: flex; justify-content: space-between; align-items: center; gap: 10px;">
            <span style="font-family: 'Inter'; font-size: 15px; color: rgba(13, 27, 21, 0.7);">Email</span>
            <span style="font-family: 'Inter'; font-size: 15px; font-weight: 600; color: #0D1B15; text-align: right;">info@ortho.com</span>
          </div>
        </div>
      </div>

      <!-- Card 3: Service Location (Dark Spring Green) -->
      <div
        class="contact-card"
        style="flex: 1; background-color: var(--color-spring-green-8, #0D1B15); padding: 45px 35px; display: flex; flex-direction: column; gap: 24px; min-width: 0;"
      >
        <h4 style="margin: 0; font-family: 'Bricolage Grotesque'; font-weight: 500; color: #FFF; font-size: 20px; letter-spacing: -0.02em;">Service Location</h4>
        <div style="display: flex; flex-direction: column; gap: 14px;">
          <div style="display: flex; justify-content: space-between; align-items: center; gap: 10px;">
            <span style="font-family: 'Inter'; font-size: 15px; color: rgba(255,255,255,0.7);">Place</span>
            <span style="font-family: 'Inter'; font-size: 15px; font-weight: 500; color: #FFF; text-align: right;">Main 3D Planning Lab</span>
          </div>
          <div style="display: flex; justify-content: space-between; align-items: center; gap: 10px;">
            <span style="font-family: 'Inter'; font-size: 15px; color: rgba(255,255,255,0.7);">Number</span>
            <span style="font-family: 'Inter'; font-size: 15px; font-weight: 500; color: #FFF; text-align: right;">+92 321 9473647</span>
          </div>
          <div style="display: flex; justify-content: space-between; align-items: center; gap: 10px;">
            <span style="font-family: 'Inter'; font-size: 15px; color: rgba(255,255,255,0.7);">Email</span>
            <span style="font-family: 'Inter'; font-size: 15px; font-weight: 500; color: #FFF; text-align: right;">support@ortho.com</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  @media (max-width: 1024px) {
    .info-cards-grid {
      flex-direction: column !important;
      border-radius: 0 !important;
    }
    .hero-content-container {
      position: relative !important;
      transform: none !important;
      left: 0 !important;
      top: 0 !important;
    }
    .contact-hero-section {
      height: auto !important;
      min-height: auto !important;
      max-height: none !important;
      padding-top: 100px;
    }
    .hero-bg {
      position: relative !important;
      height: 400px !important;
    }
  }
</style>
