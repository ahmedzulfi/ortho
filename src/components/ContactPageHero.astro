---
/**
 * Contact Page Hero Component - Orthodontics Align
 * Visual hero with background image and contact info cards.
 * Rebuilt fully with Tailwind CSS for maximum responsiveness and design fidelity.
 */
---

<section class="relative w-full lg:h-[85vh] lg:min-h-[700px] lg:max-h-[900px] bg-[#F6F7FF] flex flex-col items-center pt-[80px] sm:pt-[100px] lg:pt-0 overflow-visible">
  
  <!-- Background Image Layer -->
  <div class="relative lg:absolute lg:inset-0 w-full h-[300px] sm:h-[400px] lg:h-full z-0">
    <img
      height="765"
      width="1897"
      alt="Contact background image"
      src="/aligner_high_volume_batch_1776504000020.png"
      class="w-full h-full object-cover object-center"
    />
    <!-- Brand-aligned overlay -->
    <div class="absolute inset-0 bg-gradient-to-b from-transparent from-40% to-[rgba(13,27,21,0.3)]"></div>
  </div>

  <!-- Cards Container -->
  <div class="relative lg:absolute lg:bottom-0 lg:left-1/2 lg:-translate-x-1/2 -mt-10 sm:-mt-12 lg:mt-0 z-10 w-full max-w-[1100px] px-4 sm:px-6 lg:px-0 flex justify-center">
    <div class="flex flex-col lg:flex-row w-full max-w-[500px] lg:max-w-none rounded-[20px] lg:rounded-t-[20px] lg:rounded-b-none overflow-hidden shadow-[0_20px_50px_rgba(13,27,21,0.15)] bg-white">
      
      <!-- Card 1: Availability -->
      <div class="flex-1 bg-white p-8 sm:p-10 lg:p-[45px_35px] flex flex-col items-center lg:items-start text-center lg:text-left gap-6 border-b lg:border-b-0 lg:border-r border-[#0D1B15]/5">
        <h4 class="m-0 font-['Bricolage_Grotesque'] font-medium text-[#0D1B15] text-[20px] tracking-[-0.02em]">Service Availability</h4>
        <div class="w-full flex flex-col gap-[14px]">
          <div class="flex justify-between items-center gap-4">
            <span class="font-['Inter'] text-[15px] text-[#595E5C]">Monday - Sunday</span>
            <span class="font-['Inter'] text-[15px] font-semibold text-[#0D1B15]">Global Support</span>
          </div>
        </div>
      </div>

      <!-- Card 2: Office Location (Chartreuse Green) -->
      <div class="flex-1 bg-[#D1FC71] p-8 sm:p-10 lg:p-[45px_35px] flex flex-col items-center lg:items-start text-center lg:text-left gap-6 border-b lg:border-b-0 lg:border-r border-[#0D1B15]/5">
        <h4 class="m-0 font-['Bricolage_Grotesque'] font-medium text-[#0D1B15] text-[20px] tracking-[-0.02em]">Primary Hub</h4>
        <div class="w-full flex flex-col gap-[14px]">
          <div class="flex justify-between items-center gap-4">
            <span class="font-['Inter'] text-[15px] text-[rgba(13,27,21,0.7)]">Base</span>
            <span class="font-['Inter'] text-[15px] font-semibold text-[#0D1B15]">Remote First</span>
          </div>
          <div class="flex justify-between items-center gap-4">
            <span class="font-['Inter'] text-[15px] text-[rgba(13,27,21,0.7)]">WhatsApp</span>
            <span class="font-['Inter'] text-[15px] font-semibold text-[#0D1B15]">+92 3180325800</span>
          </div>
          <div class="flex justify-between items-center gap-4">
            <span class="font-['Inter'] text-[15px] text-[rgba(13,27,21,0.7)]">General</span>
            <span class="font-['Inter'] text-[15px] font-semibold text-[#0D1B15]">hello@validmvps.com</span>
          </div>
        </div>
      </div>

      <!-- Card 3: Support Hub -->
      <div class="flex-1 bg-[#0D1B15] p-8 sm:p-10 lg:p-[45px_35px] flex flex-col items-center lg:items-start text-center lg:text-left gap-6">
        <h4 class="m-0 font-['Bricolage_Grotesque'] font-medium text-white text-[20px] tracking-[-0.02em]">Founders Support</h4>
        <div class="w-full flex flex-col gap-[14px]">
          <div class="flex justify-between items-center gap-4">
            <span class="font-['Inter'] text-[15px] text-[rgba(255,255,255,0.7)]">Status</span>
            <span class="font-['Inter'] text-[15px] font-medium text-white">Always Available</span>
          </div>
          <div class="flex justify-between items-center gap-4">
            <span class="font-['Inter'] text-[15px] text-[rgba(255,255,255,0.7)]">Urgent</span>
            <span class="font-['Inter'] text-[15px] font-medium text-white">+92 3180325800</span>
          </div>
          <div class="flex justify-between items-center gap-4">
            <span class="font-['Inter'] text-[15px] text-[rgba(255,255,255,0.7)]">Support</span>
            <span class="font-['Inter'] text-[15px] font-medium text-white">support@validmvps.com</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
