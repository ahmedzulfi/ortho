---
/**
 * PricingTables Section - Orthodontics Align
 * Grid of pricing options for treatment planning and fabrication.
 */

const tiers = [
  {
    name: "Standard Planning",
    description: "Perfect for single arch or simple alignment cases.",
    price: "49",
    period: "/case",
    linkText: "Get Started",
    features: [
      "Treatment Simulation",
      "STL File Delivery",
      "24-hour Turnaround",
      "Unlimited Revisions"
    ],
    highlight: false,
  },
  {
    name: "Premium Planning & Design",
    description: "Comprehensive planning with full aligner design and labeling.",
    price: "99",
    period: "/case",
    linkText: "Get Started",
    features: [
      "Advanced 3D Planning",
      "Full Aligner Design",
      "Automated Labeling",
      "Support for All Scanners",
      "Bite Correction Optimization"
    ],
    highlight: true,
  },
  {
    name: "Full Fabrication",
    description: "Complete treatment plan plus physical aligner manufacturing.",
    price: "299",
    period: "/arch",
    linkText: "Get Started",
    features: [
      "Full Treatment Planning",
      "Zendura FLX™ Materials",
      "Precision Laser Trimming",
      "Case Box & Accessories",
      "Shipping Included"
    ],
    highlight: false,
  }
];
---

<section class="w-full flex flex-col items-center justify-start bg-[#F6F7FF] py-24">
  
  <div class="w-full max-w-[1540px] px-[50px] flex flex-col lg:flex-row justify-center items-stretch gap-4 relative z-10">
    
    {tiers.map((tier, idx) => (
      <div class={`reveal-on-scroll stagger-${idx + 1} flex-[1_0_0px] min-w-0 rounded-[20px] p-10 flex flex-col gap-10 bg-white`}>
        
        <!-- Header -->
        <div class="flex flex-col gap-6">
          <div class="flex flex-col gap-[15px]">
            <h5 class="m-0 font-inter text-base font-medium text-black">
              {tier.name}
            </h5>
            <p class="m-0 font-inter text-base text-black max-w-[280px] leading-[1.2]">
              {tier.description}
            </p>
          </div>
          
          <!-- Price -->
          <div class="flex flex-row items-start">
            <span class="m-0 font-inter text-base font-medium text-black mt-2">
              $
            </span>
            <span class="m-0 font-inter text-[64px] font-medium leading-[1.2] text-black tracking-tight ml-1">
              {tier.price}
            </span>
            <span class="m-0 font-inter text-base font-medium text-black self-end mb-3 ml-1 pb-1">
              {tier.period}
            </span>
          </div>
        </div>
        
        <!-- Buy Button -->
        <div class="w-full">
          <a
            href="/contact"
            class="flex flex-col items-center justify-center w-full rounded-[60px] cursor-pointer no-underline transition-transform active:scale-[0.98]"
            style={`padding: 20px 30px; background-color: ${tier.highlight ? 'var(--color-chartreuse-green-72)' : 'var(--color-spring-green-8)'};`}
          >
            <span class={`m-0 font-inter text-base font-medium text-center ${tier.highlight ? 'text-(--color-spring-green-8)' : 'text-white'}`}>
              {tier.linkText}
            </span>
          </a>
        </div>

        <!-- Features List -->
        <div class="flex flex-col gap-[15px] pb-4">
          {tier.features.map(feature => (
            <div class="flex flex-row items-center justify-start gap-[10px] w-full">
              <div 
                class="shrink-0 w-[6px] h-[6px] rounded-full" 
                style={`background-color: var(--color-spring-green-8);`}
              ></div>
              <p class="m-0 font-inter text-base text-black leading-[1.2] pt-[1px]">
                {feature}
              </p>
            </div>
          ))}
        </div>

      </div>
    ))}

  </div>

</section>
