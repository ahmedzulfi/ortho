---
/**
 * PricingTables Section - ValidMVPs
 * Grid of pricing options for treatment planning and fabrication.
 */

const tiers = [
  {
    name: "Startup Blueprint",
    description: "Ideal for founders who need a technical roadmap and a validated prototype.",
    price: "1,499",
    period: "/blueprint",
    linkText: "Start Blueprint",
    features: [
      "Technical Architecture",
      "UI/UX Design Mockups",
      "Database Schema Design",
      "Feature Scoping & Roadmap",
      "Investor Pitch Deck Prep"
    ],
    highlight: false,
  },
  {
    name: "Full MVP Build",
    description: "A complete, functional product ready for real users and early adopters.",
    price: "4,999",
    period: "/start",
    linkText: "Build My MVP",
    features: [
      "MERN / PostgreSQL Stack",
      "Auth & User Management",
      "API Integrations (Stripe, AI)",
      "Production-Ready UI",
      "Standard Deployment Setup"
    ],
    highlight: true,
  },
  {
    name: "Scalable Execution",
    description: "Taking your validated idea into a high-scale, production-hardened system.",
    price: "9,999",
    period: "/product",
    linkText: "Go Production",
    features: [
      "Advanced AI Integrations",
      "Automated CI/CD Pipelines",
      "Performance Optimization",
      "Cloud Infrastructure Setup",
      "Post-Launch Technical Support"
    ],
    highlight: false,
  }
];
---

<section class="w-full flex flex-col items-center justify-start bg-[#F6F7FF] py-12 md:py-24 md:pt-0 pt-5">
  
  <div class="w-full max-w-[1540px] px-6 md:px-[50px] flex flex-col lg:flex-row justify-center items-stretch gap-6 lg:gap-4 relative z-10">
    
    {tiers.map((tier, idx) => (
      <div class={`reveal-on-scroll stagger-${idx + 1} flex-[1_0_0px] min-w-0 rounded-[20px] p-6 md:p-10 flex flex-col gap-8 md:gap-10 bg-white shadow-sm`}>
        
        <!-- Header -->
        <div class="flex flex-col gap-6">
          <div class="flex flex-col gap-[15px]">
            <h5 class="m-0 font-inter text-base font-medium text-black">
              {tier.name}
            </h5>
            <p class="m-0 font-inter text-base text-black max-w-[280px] leading-[1.2]">
              {tier.description}
            </p>
          </div>
          
          <!-- Price -->
          <div class="flex flex-row items-start">
            <span class="m-0 font-inter text-base font-medium text-black mt-2">
              $
            </span>
            <span class="m-0 font-inter text-4xl md:text-[64px] font-medium leading-none text-black tracking-tight ml-1">
              {tier.price}
            </span>
            <span class="m-0 font-inter text-base font-medium text-black self-end mb-3 ml-1 pb-1">
              {tier.period}
            </span>
          </div>
        </div>
        
        <!-- Buy Button -->
        <div class="w-full">
          <a
            href="/contact"
            class={`flex flex-col items-center justify-center w-full rounded-[60px] cursor-pointer no-underline transition-transform active:scale-[0.98] py-4 md:py-5 px-[30px] ${tier.highlight ? 'bg-[var(--color-chartreuse-green-72)]' : 'bg-[var(--color-spring-green-8)]'}`}
          >
            <span class={`m-0 font-inter text-base font-medium text-center ${tier.highlight ? 'text-(--color-spring-green-8)' : 'text-white'}`}>
              {tier.linkText}
            </span>
          </a>
        </div>

        <!-- Features List -->
        <div class="flex flex-col gap-[15px] pb-4">
          {tier.features.map(feature => (
            <div class="flex flex-row items-center justify-start gap-[10px] w-full">
              <div class="shrink-0 w-[6px] h-[6px] rounded-full bg-[var(--color-spring-green-8)]"></div>
              <p class="m-0 font-inter text-base text-black leading-[1.2] pt-[1px]">
                {feature}
              </p>
            </div>
          ))}
        </div>

      </div>
    ))}

  </div>

</section>
