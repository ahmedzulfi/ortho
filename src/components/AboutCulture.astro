---
/**
 * AboutCulture Section
 * Focuses on the cultural and environmental aspects of the office.
 */
import { Image } from 'astro:assets';
const cultureImage = "/images/dental_clinic.png";
---

<section style="width: 100%; padding: 112px 50px; background: white; display: flex; justify-content: center; box-sizing: border-box;">
  
  <div class="reveal-on-scroll" style="width: 100%; max-width: 1440px; display: flex; align-items: center; justify-content: center; gap: 80px; flex-wrap: wrap;">
    
    <!-- Left: Large Square Image -->
    <div style="flex: 1; min-width: 300px; max-width: 600px; aspect-ratio: 1 / 1; border-radius: 16px; overflow: hidden; box-shadow: 0 40px 80px rgba(0,0,0,0.06);">
       <img src={cultureImage} alt="Orthodontics Align Culture" style="width: 100%; height: 100%; object-fit: cover;" />
    </div>

    <!-- Right: Content -->
    <div style="flex: 1; min-width: 300px; max-width: 620px; display: flex; flex-direction: column; gap: 32px;">
      
      <div style="display: flex; flex-direction: column; gap: 24px;">
        
        <!-- Label Area -->
        <div style="display: flex; flex-direction: column; gap: 16px;">
          <div style="display: flex; align-items: center; gap: 8px;">
            <div style="width: 4px; height: 4px; background: var(--color-spring-green-8, #0D1B15); border-radius: 50%;"></div>
            <div style="color: var(--color-spring-green-8, #0D1B15); font-size: 16px; font-family: 'Jost'; font-weight: 400;">Our culture</div>
          </div>
          <div style="width: 100%; height: 1px; background: #E5E7EB;"></div>
        </div>

        <!-- Headline -->
        <h2 style="margin: 0; color: var(--color-spring-green-8, #0D1B15); font-size: 48px; font-family: 'Bricolage Grotesque'; font-weight: 500; line-height: 1.2; letter-spacing: -2px;">
          We’ve created a chill dental <br/>vibe where everyone feels <br/>comfortable and is welcome to <br/>speak up.
        </h2>

        <!-- Description -->
        <p style="margin: 0; color: var(--color-grey-36, #595E5C); font-size: 18px; font-family: 'Inter'; font-weight: 400; line-height: 1.7;">
          At our dental practice, we strive to create a positive environment for both 
          our team and our patients. By ensuring everyone is satisfied throughout 
          their experience, we believe this will lead to more referrals and ongoing 
          relationships with our clients.
        </p>

      </div>

      <!-- CTA Button -->
      <div style="display: flex;">
        <a href="/contact" class="btn-premium-morph btn-green-bg" style="padding: 12px 24px; background: var(--color-chartreuse-green-72, #D1FC71); border-radius: 100px; color: var(--color-spring-green-8); font-size: 16px; font-family: 'Inter'; font-weight: 500; text-decoration: none;">
          Make an Appointment
        </a>
      </div>

    </div>

  </div>

</section>
