---
/**
 * AboutCulture Section
 * Focuses on the cultural and environmental aspects of the office.
 */
import { Image } from 'astro:assets';
const cultureImage = "https://images.pexels.com/photos/3182812/pexels-photo-3182812.jpeg?auto=compress&cs=tinysrgb&w=1200";
---

<section class="w-full py-12 md:py-[112px] px-6 md:px-[50px] bg-white flex justify-center box-border">
  
  <div class="reveal-on-scroll w-full max-w-[1440px] flex items-center justify-center gap-8 md:gap-20 flex-wrap">
    
    <!-- Left: Large Square Image -->
    <div class="flex-1 min-w-[300px] max-w-[600px] aspect-square rounded-2xl overflow-hidden shadow-[0_40px_80px_rgba(0,0,0,0.06)]">
       <img src={cultureImage} alt="ValidMVPs Culture" class="w-full h-full object-cover" />
    </div>

    <!-- Right: Content -->
    <div class="flex-1 min-w-[300px] max-w-[620px] flex flex-col gap-8">
      
      <div class="flex flex-col gap-6">
        
        <!-- Label Area -->
        <div class="flex flex-col gap-4">
          <div class="flex items-center gap-2">
            <div class="w-1 h-1 bg-[var(--color-spring-green-8,#0A0F1E)] rounded-full"></div>
            <div class="text-[var(--color-spring-green-8,#0A0F1E)] text-base font-['Jost'] font-normal">Our culture</div>
          </div>
          <div class="w-full h-[1px] bg-[#E5E7EB]"></div>
        </div>

        <!-- Headline -->
        <h2 class="m-0 text-[var(--color-spring-green-8,#0A0F1E)] text-[24px] md:text-[40px] lg:text-[48px] font-['Bricolage_Grotesque'] font-medium leading-tight md:leading-[1.2] tracking-[-1px] md:tracking-[-2px]">
          Driven by speed and a commitment to practical execution, we foster a collaborative environment focused on results.
        </h2>

        <!-- Description -->
        <p class="m-0 text-[var(--color-grey-36,#595E5C)] text-[15px] md:text-[18px] font-['Inter'] font-normal leading-[1.7]">
          At our core, we believe that high-quality software begins with a focus on what truly matters: validation and usability. By prioritizing rapid iteration and technical innovation in every MVP we build, we help founders reduce risk and make informed decisions about the future of their product.
        </p>

      </div>

      <!-- CTA Button -->
      <div class="flex">
        <a href="/contact" class="btn-premium-morph btn-green-bg py-3 px-6 bg-[var(--color-chartreuse-green-72,#D1FC71)] rounded-full text-[var(--color-spring-green-8)] text-base font-['Inter'] font-medium no-underline">
          Consult with a Partner
        </a>
      </div>

    </div>

  </div>

</section>
