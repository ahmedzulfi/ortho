---
/**
 * PricingHero Section
 * Same split-layout pattern as ServicesHero with a large heading,
 * description block, and a wide hero image below.
 */
---

<section
  class="w-full flex flex-col items-center justify-start bg-[#F6F7FF] overflow-hidden pt-24 md:pt-48 pb-12 md:pb-20 relative"
>
  <!-- Top: Split Heading & Description -->
  <div
    class="w-full max-w-[1540px] px-6 md:px-[50px] flex flex-col lg:flex-row justify-between items-start lg:items-end gap-10 lg:gap-20 mb-12 md:mb-20 z-10 relative reveal-on-scroll"
  >
    <!-- Left: Large Heading -->
    <div class="shrink-0 w-full lg:w-[600px]">
      <h1
        class="m-0 text-(--color-spring-green-8) font-bricolage text-[40px] md:text-[72px] lg:text-[96px] font-medium leading-none tracking-tight"
      >
        Simple Pricing
      </h1>
    </div>

    <!-- Right: Description & Year -->
    <div class="flex flex-col md:flex-row w-full lg:w-auto items-start md:items-end gap-6 pb-2">
      <div class="flex flex-col">
        <p
          class="m-0 text-(--color-grey-36) font-inter text-base leading-[1.7] max-w-[390px]"
        >
          Flexible execution tiers for MVP development,<br class="hidden md:block" />re-engineering, and technical strategy.
        </p>
      </div>
      <div class="flex flex-col mb-0 md:mb-[-10px]">
        <span
          class="text-(--color-spring-green-8) font-bricolage text-[48px] md:text-[86px] font-medium leading-[0.8] tracking-tight"
        >
          ©26
        </span>
      </div>
    </div>
  </div>

  <!-- Bottom: Hero Image with Background SVG -->
  <div
    class="w-full max-w-[1540px] px-6 md:px-[50px] relative reveal-on-scroll stagger-1"
  >
    <!-- Background SVG (pinned to bottom) -->
    <div class="absolute bottom-0 left-0 right-0 h-[430px] pointer-events-none overflow-hidden z-[1]">
      <img
        src="https://framerusercontent.com/images/5wu706iRUO1goYAgVmD86OpBUVw.svg"
        alt=""
        class="w-full h-full object-cover object-center"
      />
    </div>

    <!-- Main Partnership Image -->
    <div class="rounded-[20px] overflow-hidden brightness-80 h-[220px] md:h-[550px] w-full relative z-[2]">
      <img
        src="https://framerusercontent.com/images/vFDZpkWiCWHzsbiY5t09wlxpOg.png"
        alt="Technical partners at work"
        class="w-full h-full object-cover object-center block"
      />
    </div>
  </div>
</section>
