                    class="icon-bar"
                    style="width: 10px; height: 2px; background: #595E5C;"
                  />
                  <div
                    class="icon-bar vertical"
                    style="width: 2px; height: 10px; background: #595E5C; position: absolute; transition: transform 0.3s ease;"
