---
---

<section id="faq" class="box-border flex flex-col items-center justify-center w-full bg-[#F6F7FF]">
  <div class="w-full max-w-[1540px] px-6 lg:px-[50px] py-[40px] lg:py-[120px] overflow-hidden flex flex-col lg:flex-row justify-between items-start gap-8 lg:gap-20">
    <!-- Left Column: Title and Subtitle -->
    <div class="reveal-on-scroll flex-1 max-w-full lg:max-w-[480px] flex flex-col justify-start items-start gap-4 lg:gap-5">
      <div class="w-full flex flex-col justify-start items-end gap-3 md:gap-4">
        <div class="w-full flex justify-center items-center gap-2">
          <div class="w-1 h-1 relative bg-[var(--color-spring-green-8,#0D1B15)] rounded-[30px]"></div>
          <div class="flex-1 flex flex-col justify-start items-start">
            <div class="w-full flex justify-center text-[var(--color-spring-green-8,#0D1B15)] text-base font-['Jost'] font-normal leading-relaxed break-words">
              Faq
            </div>
          </div>
        </div>
        <div class="w-full h-px relative bg-[rgba(13,27,21,0.1)]"></div>
      </div>

      <!-- Heading -->
      <div class="w-full flex flex-col justify-start items-start gap-[12px] md:gap-[19px] mt-4 md:mt-5">
        <h2 class="m-0 text-[var(--color-spring-green-8,#0D1B15)] text-3xl md:text-[40px] lg:text-[48px] font-['Bricolage_Grotesque'] font-medium leading-tight md:leading-[1.2]">
          Frequently<br class="hidden md:block"/>Asked<br class="hidden md:block"/>Questions
        </h2>
        <div class="w-full flex-col justify-start items-start flex">
          <div class="w-full justify-center flex flex-col text-[var(--color-grey-36,#595E5C)] text-[16px] md:text-[18px] font-['Inter'] font-normal leading-[1.6] md:leading-[1.7] break-words">
            Get your orthodontic treatment planning done in 24 hours turn-around time using advanced technology under experts supervision.
          </div>
        </div>
      </div>
    </div>

    <!-- Right Column: Interactive Accordion -->
    <div class="reveal-on-scroll stagger-1 w-full lg:w-[740px] flex flex-col justify-start items-start">
      <div class="w-full overflow-hidden flex flex-col justify-start items-center gap-3 md:gap-4">
        <!-- Accordion Item Template -->
        {[
            {
              q: "What services does Orthodontics Align offer?",
              a: "We specialize in premium clear aligner manufacturing and high-precision 3D treatment planning for dental practices worldwide.",
            },
            {
              q: "How long does a treatment plan take?",
              a: "Our designers deliver biologically safe, ready-to-print STL files and treatment plans within a guaranteed 24-hour turnaround time.",
            },
            {
              q: "What records do I need to provide?",
              a: "We require Upper/Lower digital scans (.STL), clinical intraoral and extraoral photographs, and a completed Rx form.",
            },
            {
              q: "Do you supply physical aligners?",
              a: "Yes, we offer both end-to-end clear aligner manufacturing and digital-only planning services depending on your practice requirements.",
            },
            {
              q: "Who designs the treatment plans?",
              a: "Every case is crafted by expert orthodontic technicians using advanced algorithms and overseen by clinical supervisors for maximum predictability.",
            },
            {
              q: "How can I start a partnership?",
              a: "Simply contact us via our website or email. We will set up your clinical portal access so you can immediately begin uploading patient cases for design and manufacturing.",
            },
        ].map((item, idx) => (
          <div class="faq-accordion-item w-full bg-[var(--color-white-solid,white)] rounded-lg flex flex-col justify-start items-start overflow-hidden relative">
            <button
              class="faq-trigger appearance-none border-none bg-none text-left list-none w-full p-4 lg:p-6 flex justify-between items-center gap-4 cursor-pointer transition-colors duration-300"
              aria-expanded="false"
              aria-controls={`faq-content-${idx}`}
            >
              <div class="flex-1 flex flex-col justify-start items-start pointer-events-none">
                <div class="w-full justify-center flex flex-col text-[var(--color-spring-green-8,#0D1B15)] text-[17px] md:text-[20px] font-['Bricolage_Grotesque'] font-medium leading-[1.3] md:leading-[1.4]">
                  {item.q}
                </div>
              </div>
              <div class="w-5 h-5 md:w-6 md:h-6 relative overflow-hidden bg-[#D1FC71] rounded flex items-center justify-center shrink-0 pointer-events-none">
                <div class="icon-bar w-[10px] h-[2px] bg-[#595E5C]"></div>
                <div class="icon-bar vertical w-[2px] h-[10px] bg-[#595E5C] absolute transition-transform duration-400 ease-in-out opacity-100"></div>
              </div>
            </button>

            <div
              id={`faq-content-${idx}`}
              class="faq-content-wrapper grid grid-rows-[0fr] transition-[grid-template-rows] duration-500 ease-in-out w-full"
              role="region"
              aria-labelledby={`faq-trigger-${idx}`}
            >
              <div class="overflow-hidden">
                <div class="faq-content-inner px-4 pb-6 lg:px-6 w-full opacity-0 -translate-y-2 transition-all duration-300">
                  <div class="text-[var(--color-grey-36,#595E5C)] text-[16px] font-['Inter'] font-normal leading-[1.7]">
                    {item.a}
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .faq-accordion-item {
    transition: box-shadow 0.4s cubic-bezier(0.23, 1, 0.32, 1);
  }

  /* Disable global premium button morph animation for FAQ */
  .faq-trigger::before {
    display: none !important;
  }

  .faq-trigger:hover {
    background: none !important;
    transform: none !important;
  }

  .faq-trigger:hover * {
    color: var(--color-spring-green-8, #0d1b15) !important;
  }

  .faq-accordion-item.is-open {
    box-shadow: 0 10px 30px rgba(13, 27, 21, 0.05);
  }

  .faq-accordion-item.is-open .vertical {
    transform: rotate(90deg) !important;
    opacity: 0 !important;
  }

  .faq-accordion-item.is-open .faq-content-wrapper {
    grid-template-rows: 1fr !important;
  }

  .faq-accordion-item.is-open .faq-content-inner {
    opacity: 1 !important;
    transform: translateY(0) !important;
  }

  .faq-trigger:focus-visible {
    outline: 2px solid #d1fc71;
    outline-offset: -2px;
  }
</style>

<script>
  function initFAQ() {
    const items = document.querySelectorAll(".faq-accordion-item");

    items.forEach((item) => {
      const trigger = item.querySelector(".faq-trigger");

      trigger.addEventListener("click", () => {
        const isOpen = item.classList.contains("is-open");

        // Close other items (optional but creates a cleaner experience)
        items.forEach((otherItem) => {
          if (otherItem !== item && otherItem.classList.contains("is-open")) {
            otherItem.classList.remove("is-open");
            otherItem
              .querySelector(".faq-trigger")
              .setAttribute("aria-expanded", "false");
          }
        });

        // Toggle current item
        if (isOpen) {
          item.classList.remove("is-open");
          trigger.setAttribute("aria-expanded", "false");
        } else {
          item.classList.add("is-open");
          trigger.setAttribute("aria-expanded", "true");
        }
      });
    });
  }

  // Init on load
  initFAQ();

  // Re-init after Astro page transitions
  document.addEventListener("astro:after-swap", initFAQ);
</script>
