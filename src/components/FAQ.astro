---
/**
 * FAQ Section
 * Professional accordion-based FAQ with split layout.
 */
---

<section id="faq" class="w-full bg-[#F6F7FF] py-12 lg:py-[120px] px-6 md:px-[50px] flex justify-center overflow-hidden">
  <div class="w-full max-w-[1440px] flex flex-col lg:flex-row justify-between items-start gap-12 lg:gap-20">
    
    <!-- Left Column: Header & Description -->
    <div class="reveal-on-scroll flex flex-col items-start gap-6 lg:max-w-[480px]">
      <div class="flex items-center gap-2">
        <div class="w-1.5 h-1.5 bg-[var(--color-spring-green-8,#0D1B15)] rounded-full"></div>
        <div class="text-[var(--color-spring-green-8,#0D1B15)] text-base font-['Jost'] font-normal tracking-wide">FAQ</div>
      </div>
      
      <div class="flex flex-col gap-5">
        <h2 class="m-0 text-[var(--color-spring-green-8,#0D1B15)] text-4xl md:text-[48px] font-['Bricolage_Grotesque'] font-medium leading-[1.1] tracking-[-1px] md:tracking-[-2px]">
          Frequently<br class="hidden md:block"/>Asked Questions
        </h2>
        <p class="m-0 text-[var(--color-grey-36,#595E5C)] text-base md:text-lg font-['Inter'] font-normal leading-relaxed max-w-[440px]">
          Launch your product in weeks with technical execution that prioritizes speed, clarity, and scalability.
        </p>
      </div>
    </div>

    <!-- Right Column: Interactive Accordion -->
    <div class="reveal-on-scroll stagger-1 w-full lg:max-w-[740px]">
      <div class="flex flex-col gap-4">
        {[
          {
            q: "How fast can you build my MVP?",
            a: "We focus on speed. Depending on the complexity, we can deliver a functional, investor-ready product with core features in 4 to 8 weeks.",
          },
          {
            q: "I built a prototype in Replit. Can you help?",
            a: "Absolutely. We specialize in taking rough prototypes or 'vibe-coded' apps and converting them into structured, production-ready systems with proper architecture.",
          },
          {
            q: "What tech stack do you use?",
            a: "We typically use widely adopted and scalable stacks like MERN (MongoDB, Express, React, Node), PostgreSQL, and cloud-based infrastructures to ensure your product can grow.",
          },
          {
            q: "Is the final product investor-ready?",
            a: "Yes. We prioritize clean code, professional UI/UX, and scalable architecture so that your MVP serves as a credible representation of your vision to investors.",
          },
          {
            q: "Do you integrate AI into the products?",
            a: "Yes! We specialize in incorporating AI-driven features like automation, data processing, and intelligent workflows to give your product a competitive edge.",
          },
          {
            q: "How involved will I be in the process?",
            a: "We maintain direct communication with founders. You'll see progress consistently through rapid iteration cycles and weekly delivery of new features.",
          },
        ].map((item, idx) => (
          <div class="faq-accordion-item group bg-white rounded-2xl border border-[rgba(13,27,21,0.05)] transition-all duration-300 hover:shadow-[0_10px_30px_rgba(13,27,21,0.04)]">
            <button
              class="faq-trigger w-full text-left p-6 flex justify-between items-center gap-6 cursor-pointer group/btn"
              aria-expanded="false"
              aria-controls={`faq-content-${idx}`}
              id={`faq-trigger-${idx}`}
            >
              <span class="text-[var(--color-spring-green-8,#0D1B15)] text-[18px] md:text-[22px] font-['Bricolage_Grotesque'] font-medium leading-tight">
                {item.q}
              </span>
              <div class="w-10 h-10 rounded-full bg-[var(--color-chartreuse-green-72,#D1FC71)] flex items-center justify-center shrink-0 transition-transform duration-300 group-[.is-open]:rotate-45">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 5V19M5 12H19" stroke="#0D1B15" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </button>

            <div
              id={`faq-content-${idx}`}
              class="faq-content-wrapper grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-in-out"
              role="region"
              aria-labelledby={`faq-trigger-${idx}`}
            >
              <div class="overflow-hidden">
                <div class="px-6 pb-6 pt-0 opacity-0 -translate-y-2 transition-all duration-300 group-[.is-open]:opacity-100 group-[.is-open]:translate-y-0">
                  <p class="m-0 text-[var(--color-grey-36,#595E5C)] text-[16px] md:text-[17px] font-['Inter'] font-normal leading-relaxed">
                    {item.a}
                  </p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* Base item state */
  .faq-accordion-item.is-open {
    border-color: rgba(13, 27, 21, 0.1);
    box-shadow: 0 15px 40px rgba(13, 27, 21, 0.05);
  }

  .faq-accordion-item.is-open .faq-content-wrapper {
    grid-template-rows: 1fr;
  }

  /* Focus styles for accessibility */
  .faq-trigger:focus-visible {
    outline: 2px solid var(--color-chartreuse-green-72, #D1FC71);
    outline-offset: -4px;
    border-radius: 12px;
  }

  /* Disable the premium morph for the accordion items to keep it clean */
  :global(.faq-trigger.btn-premium-morph::before) {
    display: none !important;
  }
  
  :global(.faq-trigger.btn-premium-morph:hover) {
    background: transparent !important;
    transform: none !important;
  }

  :global(.faq-trigger.btn-premium-morph:hover *) {
    color: inherit !important;
  }
</style>

<script>
  function initFAQ() {
    const items = document.querySelectorAll(".faq-accordion-item");

    items.forEach((item) => {
      const trigger = item.querySelector(".faq-trigger");

      trigger.addEventListener("click", () => {
        const isOpen = item.classList.contains("is-open");

        // Close other items
        items.forEach((otherItem) => {
          if (otherItem !== item && otherItem.classList.contains("is-open")) {
            otherItem.classList.remove("is-open");
            otherItem
              .querySelector(".faq-trigger")
              .setAttribute("aria-expanded", "false");
          }
        });

        // Toggle current item
        if (isOpen) {
          item.classList.remove("is-open");
          trigger.setAttribute("aria-expanded", "false");
        } else {
          item.classList.add("is-open");
          trigger.setAttribute("aria-expanded", "true");
        }
      });
    });
  }

  // Init on load
  initFAQ();

  // Re-init after Astro page transitions
  document.addEventListener("astro:after-swap", initFAQ);
</script>

