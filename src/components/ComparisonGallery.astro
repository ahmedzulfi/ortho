---
/**
 * ComparisonGallery Section - High Fidelity Version
 * Features a high-fidelity Before & After image comparison slider with drag support.
 */
---

<section id="comparison-gallery" class="box-border overflow-visible flex flex-col items-center justify-start w-full max-w-[1540px] mx-auto py-12 md:py-[120px] px-6 md:px-[50px] gap-2.5 relative">
  <div class="gallery-container w-full flex flex-row items-center justify-center gap-16 relative">
    
    <!-- Left Content Column -->
    <div class="reveal-on-scroll flex-1 flex flex-col items-start justify-start gap-12 min-w-[1px]">
      
      <!-- Top Info Group -->
      <div class="w-full flex flex-col gap-8">
        <div class="w-full flex flex-col gap-6">
          
          <!-- Section Label -->
          <div class="flex items-center gap-2 w-full">
            <div class="w-1 h-1 bg-[var(--color-spring-green-8)] rounded-[30px]"></div>
            <div class="text-[var(--color-spring-green-8)] text-base font-['Inter'] font-normal">Results</div>
          </div>
          <div class="w-full h-px bg-[var(--color-grey-78)]"></div>

          <!-- Main Heading & Paragraph -->
          <div class="w-full flex flex-col gap-4 md:gap-5">
            <h2 class="m-0 text-[var(--color-spring-green-8)] text-[24px] md:text-[48px] font-['Bricolage_Grotesque'] font-medium leading-[1.2] md:leading-[57.60px]">Before & After Gallery</h2>
            <p class="m-0 text-[var(--color-grey-36)] text-[15px] md:text-lg font-['Inter'] font-normal leading-relaxed md:leading-[30.60px] max-w-[600px]">
              Witness the precision of our 3D planning. We help you visualize the final outcome before the first aligner is even printed.
            </p>
          </div>
        </div>

        <!-- Features List -->
        <div class="w-full flex flex-col gap-4 md:gap-6">
          <!-- Item 1 -->
          <div class="flex gap-3 md:gap-4 items-start w-full">
            <div class="w-10 h-10 md:w-12 md:h-12 shrink-0 bg-[var(--color-chartreuse-green-72)] rounded-xl flex items-center justify-center">
              <svg width="20" height="20" md:width="24" md:height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </div>
            <div class="flex flex-col gap-1 md:gap-2">
              <h4 class="m-0 text-[var(--color-spring-green-8)] text-[17px] md:text-[20px] font-['Bricolage_Grotesque'] font-medium">Predictable Outcomes</h4>
              <p class="m-0 text-[var(--color-grey-36)] text-sm md:text-base font-['Inter'] leading-relaxed md:leading-[27.20px]">
                Our simulations are backed by clinical data to ensure the physical results match the digital plan perfectly.
              </p>
            </div>
          </div>
          <!-- Item 2 -->
          <div class="flex gap-3 md:gap-4 items-start w-full">
            <div class="w-10 h-10 md:w-12 md:h-12 shrink-0 bg-[var(--color-chartreuse-green-72)] rounded-xl flex items-center justify-center">
              <svg width="20" height="20" md:width="24" md:height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M2 12h20"></path></svg>
            </div>
            <div class="flex flex-col gap-1 md:gap-2">
              <h4 class="m-0 text-[var(--color-spring-green-8)] text-[17px] md:text-[20px] font-['Bricolage_Grotesque'] font-medium">Clinical Precision</h4>
              <p class="m-0 text-[var(--color-grey-36)] text-sm md:text-base font-['Inter'] leading-relaxed md:leading-[27.20px]">
                Advanced orthodontists review every single setup to guarantee anatomical safety and tooth health.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- CTA Button -->
      <a href="/contact" class="btn-premium px-8 py-4 bg-[var(--color-spring-green-8)] rounded-full text-white text-base font-['Inter'] font-medium no-underline transition-all duration-300 ease-[var(--ease-out)]">
        Start Your Free Case
      </a>
    </div>

    <!-- Right Image Comparison Column -->
    <div class="reveal-on-scroll stagger-1 flex-[1.1] max-w-[688px] w-[53%] relative">
      <div id="comparison-slider" class="slider-container w-full aspect-[1/1.1] rounded-3xl overflow-hidden relative cursor-ew-resize bg-[#EEE] shadow-[0_40px_80px_rgba(13,27,21,0.12)] select-none touch-none">
        
        <!-- After Image (Base) -->
        <div class="image-after absolute inset-0">
          <img 
            src="https://framerusercontent.com/images/6uxB1oYI7Dra1nq97NIcTA8r1fA.png?width=1000" 
            alt="After treatment" 
            class="w-full h-full object-cover pointer-events-none"
          />
          <span class="label absolute bottom-5 right-5 bg-white/90 px-3 py-1.5 rounded-lg text-xs font-semibold text-[#0D1B15] uppercase">After</span>
        </div>

        <!-- Before Image (Overlay) -->
        <div id="before-image-layer" class="image-before absolute top-0 left-0 w-1/2 h-full overflow-hidden border-r-2 border-[#D1FC71] z-[5]">
          <img 
            id="before-img-node"
            src="https://framerusercontent.com/images/p182OaybQK9EiLdW2ihxzGI2x9E.png?width=1000" 
            alt="Before treatment" 
            class="w-full h-full object-cover absolute left-0 top-0 pointer-events-none"
          />
          <span class="label absolute bottom-5 left-5 bg-[#0D1B15]/90 px-3 py-1.5 rounded-lg text-xs font-semibold text-white uppercase">Before</span>
        </div>

        <!-- Handle -->
        <div id="slider-handle" class="slider-handle absolute top-0 left-1/2 bottom-0 w-1 bg-[#D1FC71] -translate-x-1/2 z-10 pointer-events-none">
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-12 h-12 bg-[#D1FC71] rounded-full flex items-center justify-center shadow-[0_8px_24px_rgba(0,0,0,0.3)] border-4 border-white">
             <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0D1B15" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="rotate-0"><polyline points="15 18 9 12 15 6"></polyline><polyline points="21 18 15 12 21 6"></polyline></svg>
             <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0D1B15" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="rotate-180"><polyline points="15 18 9 12 15 6"></polyline><polyline points="21 18 15 12 21 6"></polyline></svg>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @media (max-width: 991px) {
    .gallery-container {
      flex-direction: column !important;
      gap: 40px !important;
    }
    .reveal-on-scroll {
      width: 100% !important;
    }
    .slider-container {
      width: 100% !important;
      height: 300px !important;
      aspect-ratio: auto !important;
    }
  }

  .btn-premium:hover {
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 10px 20px rgba(13, 27, 21, 0.2);
  }
</style>

<script>
  function initComparisonSlider() {
    const slider = document.getElementById('comparison-slider');
    const beforeImageLayer = document.getElementById('before-image-layer');
    const beforeImgNode = document.getElementById('before-img-node');
    const handle = document.getElementById('slider-handle');

    if (!slider || !beforeImageLayer || !beforeImgNode || !handle) return;

    let isDragging = false;

    const setPosition = (x: number) => {
      const rect = slider.getBoundingClientRect();
      let pos = (x - rect.left) / rect.width;
      
      if (pos < 0) pos = 0;
      if (pos > 1) pos = 1;

      const percentage = pos * 100;
      beforeImageLayer.style.width = `${percentage}%`;
      handle.style.left = `${percentage}%`;
      
      // Keep the width of the before image consistent with the slider
      beforeImgNode.style.width = `${rect.width}px`;
    };

    // Update image width based on container width
    const syncImageWidth = () => {
      const rect = slider.getBoundingClientRect();
      beforeImgNode.style.width = `${rect.width}px`;
    };

    const onStart = (e: MouseEvent | TouchEvent) => {
      isDragging = true;
      onMove(e);
    };

    const onEnd = () => {
      isDragging = false;
    };

    const onMove = (e: MouseEvent | TouchEvent) => {
      if (!isDragging) return;
      const clientX = e instanceof MouseEvent ? e.clientX : e.touches[0].clientX;
      setPosition(clientX);
    };

    // Events for the slider itself (for click to jump)
    slider.addEventListener('mousedown', onStart);
    slider.addEventListener('touchstart', onStart, { passive: false });

    // Global events for smoother dragging
    window.addEventListener('mousemove', onMove);
    window.addEventListener('touchmove', onMove, { passive: false });
    window.addEventListener('mouseup', onEnd);
    window.addEventListener('touchend', onEnd);

    // Initial sync
    syncImageWidth();
    window.addEventListener('resize', syncImageWidth);
  }

  // Initial load
  initComparisonSlider();

  // Handle Astro page transitions
  document.addEventListener('astro:after-swap', initComparisonSlider);
</script>
