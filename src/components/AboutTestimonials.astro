---
/**
 * AboutTestimonials Section
 * Complex grid of testimonials and stats for the About page.
 */
const images = [
  "/images/dental_clinic.png",
  "/images/dentist_friendly.png",
  "/images/patient_smile.png"
];
---

<section style="width: 100%; padding: 112px 50px; display: flex; flex-direction: column; align-items: center; gap: 80px; box-sizing: border-box; background: #F6F7FF;">
  
  <div class="reveal-on-scroll" style="width: 100%; max-width: 1440px; display: flex; flex-direction: column; gap: 80px;">
    
    <!-- Header Row -->
    <div style="width: 100%; display: flex; flex-direction: column; gap: 20px;">
      <div style="display: flex; align-items: center; gap: 8px;">
        <div style="width: 4px; height: 4px; background: var(--color-spring-green-8, #0D1B15); border-radius: 50%;"></div>
        <div style="color: var(--color-spring-green-8, #0D1B15); font-size: 16px; font-family: 'Jost'; font-weight: 400;">Our words</div>
      </div>
      
      <div style="width: 100%; display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 20px;">
        <div style="max-width: 440px;">
            <h2 style="margin: 0; color: var(--color-spring-green-8, #0D1B15); font-size: 48px; font-family: 'Bricolage Grotesque'; font-weight: 500; line-height: 1.1; letter-spacing: -2px;">
                Dental Innovation <br/> at the Speed of Care
            </h2>
        </div>
        <a href="/team" class="btn-premium-morph btn-green-bg" style="padding: 12px 24px; background: var(--color-chartreuse-green-72, #D1FC71); border-radius: 100px; color: var(--color-spring-green-8); font-size: 16px; font-family: 'Inter'; font-weight: 500; text-decoration: none;">
          Meet the Team
        </a>
      </div>
    </div>

    <!-- Testimonial Grid -->
    <div style="display: flex; flex-direction: column; gap: 24px;">
      
      <!-- Row 1 -->
      <div style="display: grid; grid-template-columns: 1fr 1.5fr; gap: 24px;">
        <!-- Card: Green Testimonial -->
        <div class="reveal-on-scroll stagger-1" style="padding: 32px; background: var(--color-chartreuse-green-72, #D1FC71); border-radius: 12px; display: flex; flex-direction: column; justify-content: space-between; min-height: 540px;">
          <h3 style="margin: 0; color: var(--color-spring-green-8, #0D1B15); font-size: 48px; font-family: 'Bricolage Grotesque'; font-weight: 500; line-height: 1.2;">
            We'll keep relying on <br/>Orthodontics Align at every <br/>stage of our growth; <br/>it's trusted care.
          </h3>
          <div style="color: var(--color-spring-green-8, #0D1B15); font-size: 28px; font-family: 'Bricolage Grotesque'; font-weight: 500;">Orthodontics Align Team</div>
        </div>
        
        <!-- Image 1 -->
        <div class="reveal-on-scroll stagger-2" style="border-radius: 12px; overflow: hidden; height: 540px;">
           <img src={images[0]} style="width: 100%; height: 100%; object-fit: cover;" />
        </div>
      </div>

      <!-- Row 2 -->
      <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 24px;">
        
        <!-- Card Group: White Testimonial + Image -->
        <div class="reveal-on-scroll stagger-3" style="display: flex; gap: 24px; padding: 32px; background: white; border-radius: 12px; align-items: stretch;">
          <div style="flex: 1; display: flex; flex-direction: column; justify-content: space-between;">
            <p style="margin: 0; color: var(--color-grey-36, #595E5C); font-size: 20px; font-family: 'Bricolage Grotesque'; font-weight: 500; line-height: 1.5;">
              Partnering with Orthodontics Align has been <br/>crucial for site Innovations. This <br/>collaboration enhances our capabilities and <br/>aligns with our vision to revolutionize dental <br/>care. Together, we will seek innovative <br/>solutions for our clients and the industry.
            </p>
            <div style="color: var(--color-spring-green-8, #0D1B15); font-size: 28px; font-family: 'Bricolage Grotesque'; font-weight: 500;">Dentist, Orthodontics Align</div>
          </div>
          <div style="flex: 1; border-radius: 12px; overflow: hidden; background: #F2F2EF; padding: 12px;">
             <img src={images[1]} style="width: 100%; height: 100%; object-fit: cover; border-radius: 8px;" />
          </div>
        </div>

        <!-- Card: Dark Stat Card -->
        <div class="reveal-on-scroll stagger-4" style="padding: 32px; background: var(--color-spring-green-8, #0D1B15); border-radius: 12px; display: flex; flex-direction: column; justify-content: space-between;">
          <div style="display: flex; flex-direction: column; gap: 16px;">
            <div style="color: white; font-size: 36px; font-family: 'Bricolage Grotesque'; font-weight: 500;">$120M+</div>
            <div style="color: white; font-size: 36px; font-family: 'Bricolage Grotesque'; font-weight: 500; line-height: 1.2;">The largest in dental <br/>advancements in <br/>the region.</div>
          </div>
          <div style="color: var(--color-grey-96, #F5F4F7); font-size: 28px; font-family: 'Bricolage Grotesque'; font-weight: 500;">Dental Surgeon</div>
        </div>

      </div>

    </div>

  </div>

</section>
