---
/**
 * Team Section - Orthodontics Align
 * Features the qualified doctors with their details.
 */

const teamMembers = [
  {
    name: "Abdul Sami",
    role: "COO",
    phone: "+92 321 9473647",
    bio: "I am an ambitious workaholic, but apart from that, pretty simple person.",
    image: "https://framerusercontent.com/images/i51F5Pye2h2lXWmET6L6xg4nu6o.png?width=800",
    socials: { x: "#", linkedin: "#", instagram: "#" }
  },
  {
    name: "Dr. Muhammad Imran",
    role: "Expert Planner",
    phone: "+92 321 9473647",
    bio: "Recreating the patients smile and make them laugh effortlessly.",
    image: "https://framerusercontent.com/images/vMz9OdzFeY1ocTWV8LofJOEA.png?width=800",
    socials: { x: "#", linkedin: "#", instagram: "#" }
  },
  {
    name: "Dr. Abdul Muneeb",
    role: "Expert Planner",
    phone: "+92 321 9473647",
    bio: "The art of aligners seeks to provide comfortable orthodontic treatment with a strong emphasis on aesthetics and art of smile design.",
    image: "https://framerusercontent.com/images/mNnfxtlCi5hp2ZvLyYUsscSSTc.png?scale-down-to=1024&width=2552&height=2664",
    socials: { x: "#", linkedin: "#", instagram: "#" }
  },
  {
    name: "Dr. Maham Bilal",
    role: "Expert Planner",
    phone: "+92 321 9473647",
    bio: "I am a dentist by profession, who is always up for innovative and challenging tasks that will enhance my professional skills.",
    image: "https://framerusercontent.com/images/i51F5Pye2h2lXWmET6L6xg4nu6o.png?width=800",
    socials: { x: "#", linkedin: "#", instagram: "#" }
  }
];
---

<section id="doctors" style="width: 100%; background: white;">
  <div style="box-sizing: border-box; display: flex; flex-direction: column; align-items: center; justify-content: flex-start; width: 100%; max-width: 1540px; margin: 0 auto; padding: 120px 50px; gap: 80px; position: relative;">
  
  <!-- Header Group -->
  <div class="reveal-on-scroll" style="width: 100%; display: flex; flex-direction: column; gap: 20px;">
    <!-- Label -->
    <div style="display: flex; align-items: center; gap: 8px; width: 100%;">
      <div style="width: 4px; height: 4px; background: var(--color-spring-green-8); border-radius: 30px;"></div>
      <div style="color: var(--color-spring-green-8); font-size: 16px; font-family: 'Jost'; font-weight: 400;">Planning Team</div>
    </div>
    <div style="width: 100%; height: 1px; background: var(--color-grey-78);"></div>
    
    <!-- Title and Subtitle -->
    <div style="width: 100%; display: flex; flex-direction: column; gap: 16px;">
      <p style="margin: 0; color: var(--color-grey-36); font-size: 18px; font-family: 'Inter'; line-height: 1.6;">We deliver excellence in every 3D treatment plan.</p>
      <div style="width: 100%; display: flex; flex-direction: row; justify-content: space-between; align-items: center;">
        <h2 style="margin: 0; color: var(--color-spring-green-8); font-size: 64px; font-family: 'Bricolage Grotesque'; font-weight: 500; line-height: 73.60px;">Our Planning Experts</h2>
        <a href="/contact" style="padding: 12px 24px; background: var(--color-chartreuse-green-72); border-radius: 100px; color: var(--color-spring-green-8); font-size: 16px; font-family: 'Inter'; font-weight: 500; text-decoration: none; display: flex; align-items: center; gap: 8px;">
          Contact Us
        </a>
      </div>
    </div>
  </div>

  <!-- Team Grid -->
  <div style="width: 100%; display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px;">
    {teamMembers.map((member, idx) => (
      <div class={`reveal-on-scroll stagger-${idx + 1} `} style="background: white; border-radius: 16px; display: flex; flex-direction: column; gap: 16px; overflow: hidden; border: 1px solid rgba(0,0,0,0.05);">
        <!-- Member Image -->
        <div style="width: 100%; aspect-ratio: 0.9579; overflow: hidden; border-radius: 16px;">
          <img src={member.image} alt={member.name} style="width: 100%; height: 100%; object-fit: cover;" />
        </div>

        <!-- Member Info -->
        <div style="padding: 16px 12px; display: flex; flex-direction: column; gap: 24px;">
          <div style="display: flex; flex-direction: column; gap: 12px;">
            <h4 style="margin: 0; color: var(--color-spring-green-8); font-size: 28px; font-family: 'Bricolage Grotesque'; font-weight: 500; line-height: 36px;">{member.name}</h4>
            
            <div style="display: flex; flex-direction: column; gap: 7px;">
              <p style="margin: 0; color: var(--color-grey-36); font-size: 14px; font-family: 'Inter'; font-weight: 600;">{member.role}</p>
              <p style="margin: 0; color: var(--color-grey-36); font-size: 14px; font-family: 'Inter'; line-height: 1.5;">{member.bio}</p>
              
              <!-- Socials -->
              <div style="display: flex; gap: 12px; margin-top: 8px;">
                <a href={member.socials.x} style="width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: #f5f5f5; transition: background 0.2s;">
                  <img src="https://framerusercontent.com/images/13OVRZCM0XAYzQB5ntqN9wt61o.svg" style="width: 18px; height: 18px;" />
                </a>
                <a href={member.socials.linkedin} style="width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: #f5f5f5; transition: background 0.2s;">
                  <img src="https://framerusercontent.com/images/nPc7SX3zQOl0N4C05zFuh1PXsQ.svg" style="width: 18px; height: 18px;" />
                </a>
                <a href={member.socials.instagram} style="width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: #f5f5f5; transition: background 0.2s;">
                  <img src="https://framerusercontent.com/images/amcnTj2qniRVVe75PxUGpNO8SK0.svg" style="width: 18px; height: 18px;" />
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>
  </div>
</section>
