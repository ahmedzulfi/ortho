---
/**
 * Team Section - High Fidelity Version
 * Features a grid of team members with social links and CTAs.
 */

const teamMembers = [
  {
    name: "Dr. Julien Lefèvre",
    role: "Cosmetic Dentistry",
    phone: "(408) 555-0382",
    image: "https://framerusercontent.com/images/i51F5Pye2h2lXWmET6L6xg4nu6o.png?width=800",
    socials: { x: "#", linkedin: "#", instagram: "#" }
  },
  {
    name: "Dr. Amelia Grant",
    role: "Orthodontics Specialist",
    phone: "(408) 555-0383",
    image: "https://framerusercontent.com/images/vMz9OdzFeY1ocTWV8LofJOEA.png?width=800",
    socials: { x: "#", linkedin: "#", instagram: "#" }
  },
  {
    name: "Dr. Victor Han",
    role: "Oral Surgeon",
    phone: "(408) 555-0384",
    image: "https://framerusercontent.com/images/mNnfxtlCi5hp2ZvLyYUsscSSTc.png?scale-down-to=1024&width=2552&height=2664",
    socials: { x: "#", linkedin: "#", instagram: "#" }
  }
];
---

<section style="width: 100%; background: white;">
  <div style="box-sizing: border-box; display: flex; flex-direction: column; align-items: center; justify-content: flex-start; width: 100%; max-width: 1540px; margin: 0 auto; padding: 120px 50px; gap: 80px; position: relative;">
  
  <!-- Header Group -->
  <div class="reveal-on-scroll" style="width: 100%; display: flex; flex-direction: column; gap: 20px;">
    <!-- Label -->
    <div style="display: flex; align-items: center; gap: 8px; width: 100%;">
      <div style="width: 4px; height: 4px; background: var(--color-spring-green-8); border-radius: 30px;"></div>
      <div style="color: var(--color-spring-green-8); font-size: 16px; font-family: 'Jost'; font-weight: 400;">Team</div>
    </div>
    <div style="width: 100%; height: 1px; background: var(--color-grey-78);"></div>
    
    <!-- Title and Action -->
    <div style="width: 100%; display: flex; flex-direction: row; justify-content: space-between; align-items: center;">
      <h2 style="margin: 0; color: var(--color-spring-green-8); font-size: 64px; font-family: 'Bricolage Grotesque'; font-weight: 500; line-height: 73.60px;">Team Members</h2>
      <a href="#" style="padding: 12px 24px; background: var(--color-chartreuse-green-72); border-radius: 100px; color: var(--color-spring-green-8); font-size: 16px; font-family: 'Inter'; font-weight: 500; text-decoration: none; display: flex; align-items: center; gap: 8px;">
        View All
      </a>
    </div>
  </div>

  <!-- Team Grid -->
  <div style="width: 100%; display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;">
    {teamMembers.map((member, idx) => (
      <div class={`reveal-on-scroll stagger-${idx + 1} hover-lift`} style="background: white; border-radius: 16px; display: flex; flex-direction: column; gap: 16px; overflow: hidden; border: 1px solid rgba(0,0,0,0.05);">
        <!-- Member Image -->
        <div style="width: 100%; aspect-ratio: 0.9579; overflow: hidden; border-radius: 16px;">
          <img src={member.image} alt={member.name} style="width: 100%; height: 100%; object-fit: cover;" />
        </div>

        <!-- Member Info -->
        <div style="padding: 16px 12px; display: flex; flex-direction: column; gap: 24px;">
          <div style="display: flex; flex-direction: column; gap: 12px;">
            <h4 style="margin: 0; color: var(--color-spring-green-8); font-size: 36px; font-family: 'Bricolage Grotesque'; font-weight: 500; line-height: 45px;">{member.name}</h4>
            
            <div style="display: flex; height: 62.41px; justify-content: space-between; align-items: flex-end;">
              <div style="display: flex; flex-direction: column; gap: 7px;">
                <p style="margin: 0; color: var(--color-grey-36); font-size: 16px; font-family: 'Inter';">{member.role}</p>
                
                <!-- Phone -->
                <div style="display: flex; align-items: center; gap: 8px;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-grey-36);"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                  <a href={`tel:${member.phone}`} style="color: var(--color-grey-36); font-size: 16px; font-family: 'Inter'; text-decoration: none;">{member.phone}</a>
                </div>
              </div>

              <!-- Socials -->
              <div style="display: flex; gap: 12px;">
                <a href={member.socials.x} style="width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: #f5f5f5; transition: background 0.2s;">
                  <img src="https://framerusercontent.com/images/13OVRZCM0XAYzQB5ntqN9wt61o.svg" style="width: 20px; height: 20px;" />
                </a>
                <a href={member.socials.linkedin} style="width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: #f5f5f5; transition: background 0.2s;">
                  <img src="https://framerusercontent.com/images/nPc7SX3zQOl0N4C05zFuh1PXsQ.svg" style="width: 20px; height: 20px;" />
                </a>
                <a href={member.socials.instagram} style="width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: #f5f5f5; transition: background 0.2s;">
                  <img src="https://framerusercontent.com/images/amcnTj2qniRVVe75PxUGpNO8SK0.svg" style="width: 20px; height: 20px;" />
                </a>
              </div>
            </div>
          </div>

          <!-- Card CTA -->
          <a href="#" style="width: 100%; padding: 12px; background: var(--color-chartreuse-green-72); border-radius: 100px; color: var(--color-spring-green-8); font-size: 16px; font-family: 'Inter'; font-weight: 500; text-decoration: none; text-align: center; border: 1px solid var(--color-spring-green-8); position: relative; overflow: hidden; display: block;">
            Book an Appointment
          </a>
        </div>
      </div>
    ))}
  </div>
  </div>
</section>
