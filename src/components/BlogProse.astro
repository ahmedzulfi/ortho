---
/**
 * Blog Prose Component
 * Handles the main article content styling and layout.
 */
---

<section class="w-full bg-[#F6F7FF] pb-24">
  <div
    class="w-full max-w-[1100px] px-6 md:px-12 mx-auto flex flex-col items-center"
  >
    <!-- Main Content Wrapper -->
    <div class="w-full">
      <!-- Article Body -->
      <article class="prose prose-xl max-w-none reveal-on-scroll">
        <slot />
      </article>

      <!-- Written By Section Expansion -->
      <div
        class="mt-20 pt-12 border-t border-[#E2E8F0] w-full flex flex-col md:flex-row items-center justify-between gap-8 h-min relative overflow-visible"
      >
        <div
          class="flex items-center gap-4 flex-none flex-row overflow-visible p-0 h-min relative w-min"
        >
          <figure
            class="m-0 rounded-2xl flex-none h-[68px] w-[68px] relative overflow-hidden"
          >
            <div class="rounded-[inherit] inset-0 absolute">
              <img
                src="https://framerusercontent.com/images/7BOVHyT8ljRAuHmbcImH63R2HzI.jpg?width=4000&height=6000"
                alt="Ahmed Zulfiqar "
                class="rounded-[inherit] block w-full h-full object-center object-cover"
              />
            </div>
          </figure>
          <div class="flex flex-col justify-center">
            <p
              class="m-0 font-['Inter'] text-[14px] text-[#0A0F1E]/70 leading-[1.2em]"
            >
              Written by
            </p>
            <p
              class="m-0 font-['Inter'] text-[20px] font-medium w-[210px] text-[#0A0F1E] leading-[1.2em]"
            >
              Ahmed Zulfiqar
            </p>
            <p
              class="m-0 font-['Inter'] text-[14px] text-[#0A0F1E]/70 leading-[1.2em]"
            >
              CEO & Founder
            </p>
          </div>
        </div>

        <div
          class="flex-1 max-w-[450px] outline-none flex flex-col justify-start whitespace-pre-wrap shrink-0 min-h-0 relative break-words"
        >
          <p
            class="m-0 font-['Inter'] text-[16px] text-[#0A0F1E]/70 leading-[1.5]"
          >
            Hey! I'm Ahmed Zulfiqar . CEO & Founder of ValidMVPs.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  /* Custom prose overrides for ValidMVPs brand */
  .prose h2,
  .prose h3 {
    margin-top: 2em;
    margin-bottom: 0.5em;
  }
</style>
