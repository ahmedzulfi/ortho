<script>
  const contactForm = document.getElementById(
    "contact-form",
  ) as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn");
  const btnText = submitBtn?.querySelector(".btn-text");
  const btnLoader = submitBtn?.querySelector(".btn-loader") as HTMLElement;
  const feedback = document.getElementById("form-feedback");

  // Input focus effects
  const wrappers = document.querySelectorAll(".input-wrapper");
  wrappers.forEach((wrapper) => {
    const input = wrapper.querySelector("input, select");
    if (input) {
      input.addEventListener("focus", () => {
        (wrapper as HTMLElement).style.borderColor = "#D1FC71";
        (wrapper as HTMLElement).style.background = "#FFFFFF";
        (wrapper as HTMLElement).style.boxShadow =
          "0 0 0 4px rgba(209, 252, 113, 0.1)";
      });
      input.addEventListener("blur", () => {
        (wrapper as HTMLElement).style.borderColor = "transparent";
        (wrapper as HTMLElement).style.background = "#F2F2EF";
        (wrapper as HTMLElement).style.boxShadow = "none";
      });
    }
  });

  contactForm?.addEventListener("submit", async (e) => {
    e.preventDefault();

    // UI Loading State
    if (submitBtn) (submitBtn as HTMLButtonElement).disabled = true;
    if (btnText) (btnText as HTMLElement).style.opacity = "0";
    if (btnLoader) btnLoader.style.display = "flex";
    if (feedback) {
      feedback.style.display = "none";
      feedback.textContent = "";
    }

    const formData = new FormData(contactForm);
    const data = Object.fromEntries(formData.entries());

    try {
      // Simulate API call - Replace with actual endpoint if available
      await new Promise((resolve) => setTimeout(resolve, 1500));

      console.log("Form Submitted:", data);

      // Success Feedback
      if (feedback) {
        feedback.style.display = "block";
        feedback.style.color = "#0A0F1E";
        feedback.textContent =
          "Message sent successfully! We will contact you soon.";
      }
      contactForm.reset();
    } catch (error) {
      // Error Feedback
      if (feedback) {
        feedback.style.display = "block";
        feedback.style.color = "#EF4444";
        feedback.textContent =
          "Something went wrong. Please try again or call us directly.";
      }
    } finally {
      // Restore UI
      if (submitBtn) (submitBtn as HTMLButtonElement).disabled = false;
      if (btnText) (btnText as HTMLElement).style.opacity = "1";
      if (btnLoader) btnLoader.style.display = "none";
    }
  });
</script>

<style>
  .input-wrapper {
    box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.02);
  }

  /* Select arrows and other overrides */
  select {
    cursor: pointer;
  }

  /* Premium Button Hover Override for this form */
  #submit-btn:hover:not(:disabled) {
    background: #0a0f1e !important;
    color: #d1fc71 !important;
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(13, 27, 21, 0.15);
  }

  #submit-btn:disabled {
    cursor: not-allowed;
    opacity: 0.7;
  }

  .animate-spin {
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }
</style>
