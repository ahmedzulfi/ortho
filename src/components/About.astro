---
/**
 * About Section
 * Cleaned up and migrated to Tailwind CSS
 */
---

<div class="w-full flex justify-center items-center bg-white overflow-hidden p-0 m-0">
  <div class="w-full max-w-[1540px] flex flex-col items-center justify-start gap-8 md:gap-20 py-10 md:py-[120px] px-6 md:px-[50px] overflow-hidden">
    
    <!-- Top Text Section -->
    <div class="reveal-on-scroll w-full flex flex-col justify-start items-center gap-[10px]">
      <div class="w-full flex flex-col md:flex-row items-start justify-start gap-5 md:gap-[60px]">
        
        <!-- Left Title Group -->
        <div class="hidden md:flex flex-1 w-[1px] flex-col justify-end items-end gap-4 h-auto pt-2">
          <div class="w-full flex justify-center items-center gap-2">
            <div class="w-1 h-1 bg-[var(--color-spring-green-8,#0D1B15)] rounded-[30px] shrink-0"></div>
            <p class="m-0 flex-1 font-['Inter'] text-base font-normal text-black text-left leading-[1.2em]">About</p>
          </div>
          <div class="w-full h-[1px] bg-[var(--color-grey-78,#C9CBC5)] mt-4"></div>
        </div>
        
        <!-- Right Main Text -->
        <div class="w-full md:w-[66%] max-w-[1100px]">
          <h2 class="m-0 font-['Bricolage_Grotesque'] text-[24px] md:text-[48px] font-medium tracking-tight md:tracking-[-3px] leading-[1.2] text-[var(--color-spring-green-8,#0D1B15)]">
            At Orthodontics Align, we specialize in high-precision dental aligner manufacturing and expert 3D treatment planning, delivering clinically-validated designs and ready-to-use STL files with industry-leading speed.
          </h2>
        </div>
      </div>
    </div>
    
    <!-- Middle Image and Text Section -->
    <div class="reveal-on-scroll stagger-1 w-full flex flex-col items-end gap-8 md:gap-[96px]">
      <div class="w-full max-w-[1000px] flex flex-col md:flex-row items-start justify-center gap-6 md:gap-8">
        
        <!-- Image -->
        <div class="w-full md:flex-1 max-w-full md:max-w-[450px] rounded-[16px] overflow-hidden flex items-center justify-center">
          <figure class="m-0 aspect-[0.9/1] w-full h-[220px] md:h-[500px]">
            <img src="/aligner_lifestyle_smile_1776503878607.png" alt="Person wearing clear aligners" class="w-full h-full object-cover object-center block" />
          </figure>
        </div>
        
        <!-- Text and Button -->
        <div class="flex-1 flex flex-col items-start justify-between self-stretch gap-8 pt-4">
          <div class="w-full flex flex-col gap-[10px]">
             <p class="m-0 font-['Inter'] text-base font-normal text-black leading-[1.2em]">Our team of expert orthodontic technicians and designers work on crafting the perfect plan for your patients. Our 3D Treatment Planning service not only optimizes tooth movement for clear aligner fabrication but also delivers ready-to-print models in high-resolution STL format.</p>
             <p class="m-0 font-['Inter'] text-base font-normal text-black leading-[1.2em] mt-[10px]">From high-volume aligner manufacturing to complex simulation planning, we provide the accuracy and speed your practice demands. Because predictable orthodontic success begins with manufacturing and planning you can trust.</p>
          </div>
          <div class="hover-lift mt-auto pb-4">
            <a href="/about" class="px-4 py-3 bg-[var(--color-chartreuse-green-72,#D1FC71)] rounded-[100px] flex flex-col items-center justify-center no-underline cursor-pointer">
              <p class="m-0 font-['Inter'] text-base font-medium text-[var(--color-spring-green-8,#0D1B15)]">About Orthodontics Align</p>
            </a>
          </div>
        </div>
      </div>
      
      <!-- Stats area -->
      <div class="w-full grid grid-cols-2 lg:grid-cols-4 items-center justify-between gap-6 md:gap-12">
        
        <div class="flex flex-col items-start justify-start gap-1 md:gap-4">
          <h4 class="m-0 font-['Bricolage_Grotesque'] text-[24px] md:text-[48px] font-normal text-[var(--color-spring-green-8,#0D1B15)]">1200+</h4>
          <p class="m-0 font-['Inter'] text-[13px] md:text-base font-medium text-[var(--color-spring-green-8,#0D1B15)]">Cases Completed</p>
        </div>
        
        <div class="flex flex-col items-start justify-start gap-1 md:gap-4">
          <h4 class="m-0 font-['Bricolage_Grotesque'] text-[24px] md:text-[48px] font-normal text-[var(--color-spring-green-8,#0D1B15)]">85+</h4>
          <p class="m-0 font-['Inter'] text-[13px] md:text-base font-medium text-[var(--color-spring-green-8,#0D1B15)]">Active Partner Clinics</p>
        </div>
        
        <div class="flex flex-col items-start justify-start gap-1 md:gap-4">
          <h4 class="m-0 font-['Bricolage_Grotesque'] text-[24px] md:text-[48px] font-normal text-[var(--color-spring-green-8,#0D1B15)]">60+</h4>
          <p class="m-0 font-['Inter'] text-[13px] md:text-base font-medium text-[var(--color-spring-green-8,#0D1B15)]">Dental Partners</p>
        </div>
        
        <div class="flex flex-col items-start justify-start gap-1 md:gap-4">
          <h4 class="m-0 font-['Bricolage_Grotesque'] text-[24px] md:text-[48px] font-normal text-[var(--color-spring-green-8,#0D1B15)]">94%</h4>
          <p class="m-0 font-['Inter'] text-[13px] md:text-base font-medium text-[var(--color-spring-green-8,#0D1B15)]">Client Satisfaction Score</p>
        </div>
      </div>
    </div>
  </div>
</div>
