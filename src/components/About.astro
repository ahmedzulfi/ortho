---
/**
 * About Section
 * Cleaned up and migrated to Tailwind CSS
 */
---

<div
  class="w-full flex justify-center items-center bg-white overflow-hidden p-0 m-0"
>
  <div
    class="w-full max-w-[1440px] flex flex-col items-center justify-start gap-8 md:gap-20 py-10 md:py-[120px] px-6 md:px-[50px] overflow-hidden"
  >
    <!-- Top Text Section -->
    <div
      class="reveal-on-scroll w-full flex flex-col justify-start items-center gap-[10px]"
    >
      <div
        class="w-full flex flex-col md:flex-row items-start justify-start gap-5 md:gap-[60px]"
      >
        <!-- Left Title Group -->
        <div
          class="hidden md:flex flex-1 flex-col justify-start items-start gap-6 pt-2"
        >
          <div class="flex items-center gap-2">
            <div
              class="w-1.5 h-1.5 bg-[var(--color-spring-green-8,#0A0F1E)] rounded-full"
            >
            </div>
            <div
              class="text-[var(--color-spring-green-8,#0A0F1E)] text-base font-['Jost'] font-normal tracking-wide"
            >
              About
            </div>
          </div>
        </div>

        <!-- Right Main Text -->
        <div class="w-full md:w-[66%] max-w-[1100px]">
          <h2
            class="m-0 font-['Bricolage_Grotesque'] text-[24px] md:text-[48px] font-medium tracking-tight md:tracking-[-3px] leading-[1.2] text-[var(--color-spring-green-8,#0A0F1E)]"
          >
            ValidMVPs is a fast-execution development service focused on helping
            founders and early-stage teams turn ideas into functional,
            investor-ready products in weeks.
          </h2>
        </div>
      </div>
    </div>

    <!-- Middle Image and Text Section -->
    <div
      class="reveal-on-scroll stagger-1 w-full flex flex-col items-end gap-8 md:gap-[96px]"
    >
      <div
        class="w-full max-w-[1000px] flex flex-col md:flex-row items-start justify-center gap-6 md:gap-8"
      >
        <!-- Image -->
        <div
          class="w-full md:flex-1 max-w-full md:max-w-[450px] rounded-[16px] overflow-hidden flex items-center justify-center"
        >
          <figure class="m-0 aspect-[0.9/1] w-full h-[220px] md:h-[500px]">
            <img
              src="https://images.pexels.com/photos/3184291/pexels-photo-3184291.jpeg?auto=compress&cs=tinysrgb&w=800"
              alt="Collaborative MVP development"
              class="w-full h-full object-cover object-center block"
            />
          </figure>
        </div>

        <!-- Text and Button -->
        <div
          class="flex-1 flex flex-col items-start justify-between self-stretch gap-8 pt-4"
        >
          <div class="w-full flex flex-col gap-[10px]">
            <p
              class="m-0 font-['Inter'] text-base font-normal text-black leading-[1.2em]"
            >
              Our core philosophy centers on speed, clarity, and practicality
              prioritizing working software over over-engineered systems.
              Instead of spending months on planning, we identify the smallest
              viable version of your product that can validate your business
              idea in the real market.
            </p>
            <p
              class="m-0 font-['Inter'] text-base font-normal text-black leading-[1.2em] mt-[10px]"
            >
              We bridge the gap for founders stuck in 'vibe coding' or no-code
              tools. We take rough prototypes and convert them into structured,
              scalable applications with proper architecture, backend logic, and
              automated deployment pipelines.
            </p>
          </div>
          <div class="mt-auto pb-4">
            <a
              href="/about"
              class="btn-premium-morph btn-green-bg px-8 py-4 bg-[var(--color-chartreuse-green-72,#60A5FA)] rounded-full flex flex-col items-center justify-center no-underline cursor-pointer group"
            >
              <span
                class="font-['Inter'] text-base font-medium text-[var(--color-spring-green-8,#0A0F1E)]"
                >More About ValidMVPs</span
              >
            </a>
          </div>
        </div>
      </div>

      <!-- Stats area -->
      <div
        class="w-full grid grid-cols-2 lg:grid-cols-4 items-center justify-between gap-6 md:gap-12"
      >
        <div class="flex flex-col items-start justify-start gap-1 md:gap-4">
          <h4
            class="m-0 font-['Bricolage_Grotesque'] text-[24px] md:text-[48px] font-normal text-[var(--color-spring-green-8,#0A0F1E)]"
          >
            4-8 Weeks
          </h4>
          <p
            class="m-0 font-['Inter'] text-[13px] md:text-base font-medium text-[var(--color-spring-green-8,#0A0F1E)]"
          >
            Avg. Delivery Time
          </p>
        </div>

        <div class="flex flex-col items-start justify-start gap-1 md:gap-4">
          <h4
            class="m-0 font-['Bricolage_Grotesque'] text-[24px] md:text-[48px] font-normal text-[var(--color-spring-green-8,#0A0F1E)]"
          >
            50+
          </h4>
          <p
            class="m-0 font-['Inter'] text-[13px] md:text-base font-medium text-[var(--color-spring-green-8,#0A0F1E)]"
          >
            MVPs Launched
          </p>
        </div>

        <div class="flex flex-col items-start justify-start gap-1 md:gap-4">
          <h4
            class="m-0 font-['Bricolage_Grotesque'] text-[24px] md:text-[48px] font-normal text-[var(--color-spring-green-8,#0A0F1E)]"
          >
            MERN
          </h4>
          <p
            class="m-0 font-['Inter'] text-[13px] md:text-base font-medium text-[var(--color-spring-green-8,#0A0F1E)]"
          >
            Modern Tech Stack
          </p>
        </div>

        <div class="flex flex-col items-start justify-start gap-1 md:gap-4">
          <h4
            class="m-0 font-['Bricolage_Grotesque'] text-[24px] md:text-[48px] font-normal text-[var(--color-spring-green-8,#0A0F1E)]"
          >
            100%
          </h4>
          <p
            class="m-0 font-['Inter'] text-[13px] md:text-base font-medium text-[var(--color-spring-green-8,#0A0F1E)]"
          >
            Investor-Ready Code
          </p>
        </div>
      </div>
    </div>
  </div>
</div>
