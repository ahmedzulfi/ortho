---
/**
 * AboutBrief Section
 * Clean, text-centric design with social proof.
 */
---

<section class="w-full py-20 md:py-[120px] px-6 md:px-[50px] bg-white flex flex-col items-center justify-center box-border">
  
  <div class="reveal-on-scroll w-full max-w-[1100px] flex flex-col items-center gap-10">
    
    <!-- Label -->
    <div class="flex items-center gap-2">
      <div class="w-1 h-1 bg-[var(--color-spring-green-8,#0A0F1E)] rounded-full"></div>
      <div class="text-[var(--color-spring-green-8,#0A0F1E)] text-base font-['Jost'] font-normal">About</div>
    </div>

    <!-- Main Headline -->
    <div class="text-center max-w-[1100px]">
      <h2 class="m-0 text-[var(--color-spring-green-8,#0A0F1E)] text-[clamp(24px,5vw,48px)] font-['Bricolage_Grotesque'] font-medium leading-[1.2] tracking-[-1.5px] md:tracking-[-3px]">
        At ValidMVPs, we bridge the gap between rough prototypes and production-ready systems, providing fast technical execution for founders and startups.
      </h2>
    </div>

    <!-- Social Proof Section -->
    <div class="reveal-on-scroll stagger-1 flex flex-col items-center gap-5">
      <p class="m-0 text-[var(--color-grey-36,#595E5C)] text-base font-['Inter'] font-medium">
        Loved by many clients, rated 4.9
      </p>

      <!-- Avatar Row -->
      <div class="flex items-center justify-center relative">
        <!-- Overlapping Avatars -->
        <div class="flex -mr-[10px]">
          {[ 
            "/images/avatar_1.png",
            "/images/avatar_2.png",
            "/images/avatar_3.png",
            "/images/avatar_1.png"
          ].map((src, i) => (
            <div class={`hover-lift w-[50px] md:w-[60px] h-[40px] md:h-[49px] rounded-lg overflow-hidden border-2 border-white relative transition-transform duration-300 ease-in-out ${i === 0 ? 'ml-0' : '-ml-[12px] md:-ml-[15px]'} z-[${5 - i}]`}>
               <img src={src} alt="Client" class="w-full h-full object-cover" />
            </div>
          ))}
          
          <!-- "50+" Badge -->
          <div class="w-[50px] md:w-[60px] h-[40px] md:h-[49px] bg-[var(--color-spring-green-8,#0A0F1E)] rounded-lg flex items-center justify-center -ml-[12px] md:-ml-[15px] relative z-0 border-2 border-white">
            <span class="text-white text-[15px] md:text-lg font-['Inter'] font-semibold">50+</span>
          </div>
        </div>
      </div>
    </div>

  </div>

</section>
