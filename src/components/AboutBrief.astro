---
/**
 * AboutBrief Section
 * Clean, text-centric design with social proof.
 */
---

<section style="width: 100%; padding: 120px 50px; background: white; display: flex; flex-direction: column; align-items: center; justify-content: center; box-sizing: border-box;">
  
  <div class="reveal-on-scroll" style="width: 100%; max-width: 1100px; display: flex; flex-direction: column; align-items: center; gap: 40px;">
    
    <!-- Label -->
    <div style="display: flex; align-items: center; gap: 8px;">
      <div style="width: 4px; height: 4px; background: var(--color-spring-green-8, #0D1B15); border-radius: 50%;"></div>
      <div style="color: var(--color-spring-green-8, #0D1B15); font-size: 16px; font-family: 'Jost'; font-weight: 400;">About</div>
    </div>

    <!-- Main Headline -->
    <div style="text-align: center; max-width: 1100px;">
      <h2 style="margin: 0; color: var(--color-spring-green-8, #0D1B15); font-size: clamp(32px, 5vw, 48px); font-family: 'Bricolage Grotesque'; font-weight: 500; line-height: 1.2; letter-spacing: -3px;">
        At Orthodontics Align we combine advanced technology with years of experience, allowing you to be completely worry-free in treatment planning and designing done in a very short time.
      </h2>
    </div>

    <!-- Social Proof Section -->
    <div class="reveal-on-scroll stagger-1" style="display: flex; flex-direction: column; align-items: center; gap: 20px;">
      <p style="margin: 0; color: var(--color-grey-36, #595E5C); font-size: 16px; font-family: 'Inter'; font-weight: 500;">
        Loved by many clients, rated 4.9
      </p>

      <!-- Avatar Row -->
      <div style="display: flex; align-items: center; justify-content: center; position: relative;">
        <!-- Overlapping Avatars -->
        <div style="display: flex; margin-right: -10px;">
          {[ 
            "/images/avatar_1.png",
            "/images/avatar_2.png",
            "/images/avatar_3.png",
            "/images/avatar_1.png"
          ].map((src, i) => (
            <div style={`width: 60px; height: 49px; border-radius: 8px; overflow: hidden; border: 2px solid white; margin-left: ${i === 0 ? '0' : '-15px'}; position: relative; z-index: ${5 - i}; transition: transform 0.3s ease;`} class="hover-lift">
               <img src={src} alt="Client" style="width: 100%; height: 100%; object-fit: cover;" />
            </div>
          ))}
          
          <!-- "80+" Badge -->
          <div style="width: 60px; height: 49px; background: var(--color-spring-green-8, #0D1B15); border-radius: 8px; display: flex; align-items: center; justify-content: center; margin-left: -15px; position: relative; z-index: 0; border: 2px solid white;">
            <span style="color: white; font-size: 18px; font-family: 'Inter'; font-weight: 600;">80+</span>
          </div>
        </div>
      </div>
    </div>

  </div>

</section>
