---
/**
 * Main Navbar Component
 * Floating white pill design with interactive hover states.
 */
const { pathname } = Astro.url;
// Normalize pathname to handle trailing slashes
const normalizedPath = pathname.replace(/\/$/, "") || "/";

const navLinksFirst = [
  { name: 'Home', path: '/' },
  { name: 'About', path: '/about-mvp-development/' },
  { name: 'Services', path: '/services/' }
];

const navLinksLast = [
  { name: 'Blog', path: '/blog/' },
  { name: 'Pricing', path: '/pricing/' },
  { name: 'Contact', path: '/contact/' }
];

const solutions = {
  products: {
    title: "By Product Type",
    links: [
      { name: 'AI & LLM Apps', path: '/solutions/ai-startups/', desc: 'Custom RAG and agentic systems' },
      { name: 'SaaS Platforms', path: '/solutions/saas-founders/', desc: 'Multi-tenant scalable MVPs' },
      { name: 'Enterprise Tools', path: '/solutions/enterprise/', desc: 'Internal apps and modernization' }
    ]
  },
  services: {
    title: "By Service",
    links: [
      { name: 'Rapid Prototyping', path: '/solutions/ai-startups/', desc: 'Idea to MVP in 4 weeks' },
      { name: 'Product Strategy', path: '/solutions/saas-founders/', desc: 'Roadmap and technical discovery' },
      { name: 'Technical Audit', path: '/solutions/enterprise/', desc: 'Legacy code review and optimization' }
    ]
  }
};

const allSolutionLinks = [...solutions.products.links, ...solutions.services.links];
const isSolutionActive = allSolutionLinks.some(l => normalizedPath === l.path);
---

<header class="fixed top-0 left-0 w-full z-50 flex flex-col items-center justify-start pointer-events-none">
  <div class="pointer-events-auto flex flex-col items-center w-full pb-4 pt-4 md:pt-6 px-4 md:px-8 lg:px-[50px]">
    <!-- Inner Pill Container -->
    <div class="w-full max-w-[1440px] px-4 md:px-10 py-3 bg-white backdrop-blur-md border border-white/20 shadow-[0px_4px_20px_rgba(13,27,21,0.04)] rounded-2xl flex justify-between items-center relative">
      
      <!-- Left: Logo -->
      <a href="/" class="flex items-center justify-center shrink-0">
        <img
          src="/images/LOGO.png"
          alt="ValidMVPs Logo"
          class="h-10 md:h-[50px] w-auto object-contain"
        />
      </a>

      <!-- Center: Navigation Links (Desktop) -->
      <nav class="hidden lg:flex items-center gap-2">
        {navLinksFirst.map(link => {
          const isActive = normalizedPath === link.path;
          return (
            <a href={link.path} class="nav-link group relative h-9 px-4 flex items-center gap-2 rounded-full no-underline overflow-hidden transition-transform active:scale-95">
              <div class={`nav-bg absolute inset-0 bg-[#D1FC71] transition-opacity duration-300 rounded-full ${isActive ? 'opacity-100' : 'opacity-0'}`}></div>
              <div class={`nav-dot w-[5px] h-[5px] rounded-full relative z-10 transition-colors duration-300 ${isActive ? 'bg-[#0D1B15]' : 'bg-[#595E5C]'}`}></div>
              <span class={`nav-text text-base font-['Inter'] font-medium relative z-10 transition-colors duration-300 ${isActive ? 'text-[#0D1B15]' : 'text-[#595E5C]'}`}>
                {link.name}
              </span>
            </a>
          );
        })}

        <!-- Solutions Dropdown -->
        <div class="solutions-dropdown h-9" id="solutions-dropdown-container">
          <button 
            class={`nav-link solutions-trigger group relative h-9 px-4 flex items-center gap-2 rounded-full overflow-hidden cursor-pointer border-none bg-transparent transition-transform active:scale-95`}
            aria-haspopup="true"
            aria-expanded="false"
            id="solutions-trigger-btn"
          >
            <div class={`nav-bg absolute inset-0 bg-[#D1FC71] transition-opacity duration-300 rounded-full ${isSolutionActive ? 'opacity-100' : 'opacity-0'}`}></div>
            <div class={`nav-dot w-[5px] h-[5px] rounded-full relative z-10 transition-colors duration-300 ${isSolutionActive ? 'bg-[#0D1B15]' : 'bg-[#595E5C]'}`}></div>
            <span class={`nav-text text-base font-['Inter'] font-medium relative z-10 transition-colors duration-300 ${isSolutionActive ? 'text-[#0D1B15]' : 'text-[#595E5C]'}`}>Solutions</span>
            <svg class="solutions-chevron relative z-10 w-3 h-3 transition-transform duration-300" viewBox="0 0 12 12" fill="none">
              <path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>

        {navLinksLast.map(link => {
          const isActive = normalizedPath === link.path;
          return (
            <a href={link.path} class="nav-link group relative h-9 px-4 flex items-center gap-2 rounded-full no-underline overflow-hidden transition-transform active:scale-95">
              <div class={`nav-bg absolute inset-0 bg-[#D1FC71] transition-opacity duration-300 rounded-full ${isActive ? 'opacity-100' : 'opacity-0'}`}></div>
              <div class={`nav-dot w-[5px] h-[5px] rounded-full relative z-10 transition-colors duration-300 ${isActive ? 'bg-[#0D1B15]' : 'bg-[#595E5C]'}`}></div>
              <span class={`nav-text text-base font-['Inter'] font-medium relative z-10 transition-colors duration-300 ${isActive ? 'text-[#0D1B15]' : 'text-[#595E5C]'}`}>
                {link.name}
              </span>
            </a>
          );
        })}
      </nav>

      <!-- Mobile Menu Button -->
      <button 
        id="mobile-menu-btn" 
        class="lg:hidden p-2 flex flex-col gap-1.5 items-center justify-center z-50 pointer-events-auto"
        aria-label="Toggle Menu"
      >
        <span class="block w-6 h-0.5 bg-[#0D1B15] transition-transform duration-300"></span>
        <span class="block w-6 h-0.5 bg-[#0D1B15] transition-opacity duration-300"></span>
        <span class="block w-6 h-0.5 bg-[#0D1B15] transition-transform duration-300"></span>
      </button>

      <!-- Right: CTA Button (Desktop) -->
      <a href="/contact/" class="hidden lg:flex hover-lift px-6 py-3 bg-[#D1FC71] rounded-full items-center justify-center no-underline">
        <span class="text-[#0D1B15] text-base font-['Inter'] font-medium">
          Get Started
        </span>
      </a>

      <!-- Mega Menu Panel (Positioned relative to the Pill) -->
      <div 
        id="desktop-solutions-panel"
        class="solutions-panel absolute top-full inset-x-0 mx-auto w-[480px] pt-3 opacity-0 pointer-events-none transition-all duration-200 origin-top z-50"
        role="menu"
        aria-labelledby="solutions-trigger-btn"
      >
        <div class="bg-white backdrop-blur-xl border border-white/20 shadow-[0px_10px_40px_rgba(0,0,0,0.1)] rounded-[24px] p-6 grid grid-cols-2 gap-8 relative overflow-hidden">
          <div class="flex flex-col gap-4">
            <span class="text-[10px] font-bold uppercase tracking-[0.15em] text-[#595E5C] px-3 opacity-60">{solutions.products.title}</span>
            <div class="flex flex-col gap-1">
              {solutions.products.links.map(link => (
                <a href={link.path} class="flex flex-col px-4 py-3 rounded-2xl hover:bg-[#D1FC71] group transition-all duration-200 no-underline" role="menuitem">
                  <span class="text-sm font-semibold text-[#0D1B15] transition-colors">{link.name}</span>
                  <span class="text-[12px] text-[#595E5C] group-hover:text-[#0D1B15]/70 mt-0.5 transition-colors">{link.desc}</span>
                </a>
              ))}
            </div>
          </div>

          <div class="flex flex-col gap-4">
            <span class="text-[10px] font-bold uppercase tracking-[0.15em] text-[#595E5C] px-3 opacity-60">{solutions.services.title}</span>
            <div class="flex flex-col gap-1">
              {solutions.services.links.map(link => (
                <a href={link.path} class="flex flex-col px-4 py-3 rounded-2xl hover:bg-[#D1FC71] group transition-all duration-200 no-underline" role="menuitem">
                  <span class="text-sm font-semibold text-[#0D1B15] transition-colors">{link.name}</span>
                  <span class="text-[12px] text-[#595E5C] group-hover:text-[#0D1B15]/70 mt-0.5 transition-colors">{link.desc}</span>
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Mobile Navigation Overlay -->
    <div 
      id="mobile-nav-overlay" 
      class="fixed inset-0 z-[60] bg-[#0D1B15]/95 backdrop-blur-sm opacity-0 pointer-events-none transition-all duration-500 lg:hidden flex items-start justify-center pt-4 px-4 h-screen w-screen"
    >
      <div 
        id="mobile-nav-card"
        class="w-full max-w-[400px] bg-white premium-noise rounded-[20px] p-6 shadow-2xl flex flex-col items-center gap-4 translate-y-[-40px] transition-all duration-500 ease-[var(--ease-out)]"
      >
        <!-- Header -->
        <div class="w-full flex justify-between items-center mb-2 px-2">
          <a href="/" class="flex items-center">
            <img src="/images/LOGO.png" alt="ValidMVPs Logo" class="h-8 md:h-10 w-auto object-contain" />
          </a>
          <button 
            id="close-mobile-nav" 
            class="w-10 h-10 flex items-center justify-center rounded-full bg-gray-100 text-[#0D1B15] hover:bg-gray-200 transition-colors focus:outline-none focus:ring-2 focus:ring-[#D1FC71]"
            aria-label="Close Menu"
          >
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>
        </div>

        <!-- Navigation Links -->
        <nav class="w-full flex flex-col gap-2">
          {navLinksFirst.map((link, i) => {
            const isActive = normalizedPath === link.path;
            return (
              <a 
                href={link.path} 
                class={`mobile-link group flex items-center gap-3 px-5 py-3 rounded-2xl w-full transition-all duration-300 ${isActive ? 'bg-[#D1FC71] text-[#0D1B15]' : 'text-gray-600 hover:bg-[#D1FC71]/10 hover:text-[#0D1B15]'}`}
                style={`--stagger: ${i};`}
              >
                <div class="w-1.5 h-1.5 bg-current rounded-full group-hover:scale-150 transition-transform"></div>
                <span class="text-lg font-['Inter'] font-semibold tracking-tight">{link.name}</span>
              </a>
            );
          })}

          <!-- Solutions Accordion (Mobile) -->
          <div class="mobile-link" style={`--stagger: ${navLinksFirst.length};`}>
            <button id="mobile-solutions-btn" class={`flex items-center gap-3 px-5 py-3 rounded-2xl w-full transition-all duration-300 text-gray-600 hover:bg-[#D1FC71]/10 hover:text-[#0D1B15] ${isSolutionActive ? 'bg-[#D1FC71] text-[#0D1B15]' : ''}`}>
              <div class="w-1.5 h-1.5 bg-current rounded-full"></div>
              <span class="text-lg font-['Inter'] font-semibold tracking-tight flex-1 text-left">Solutions</span>
              <svg id="mobile-solutions-chevron" class="w-4 h-4 transition-transform duration-300" viewBox="0 0 12 12" fill="none">
                <path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div id="mobile-solutions-panel" class="hidden flex-col gap-1 pt-1 pl-4">
              {allSolutionLinks.map(link => (
                <a href={link.path} class={`mobile-link flex items-center px-5 py-3 rounded-xl no-underline transition-all duration-150 ${normalizedPath === link.path ? 'bg-[#D1FC71]/30 text-[#0D1B15]' : 'text-gray-500 hover:text-[#0D1B15] hover:bg-gray-50'}`}>
                  <span class="text-base font-['Inter'] font-medium">{link.name}</span>
                </a>
              ))}
            </div>
          </div>

          {navLinksLast.map((link, i) => {
            const isActive = normalizedPath === link.path;
            const staggerIdx = navLinksFirst.length + 1 + i;
            return (
              <a 
                href={link.path} 
                class={`mobile-link group flex items-center gap-3 px-5 py-3 rounded-2xl w-full transition-all duration-300 ${isActive ? 'bg-[#D1FC71] text-[#0D1B15]' : 'text-gray-600 hover:bg-[#D1FC71]/10 hover:text-[#0D1B15]'}`}
                style={`--stagger: ${staggerIdx};`}
              >
                <div class="w-1.5 h-1.5 bg-current rounded-full group-hover:scale-150 transition-transform"></div>
                <span class="text-lg font-['Inter'] font-semibold tracking-tight">{link.name}</span>
              </a>
            );
          })}
        </nav>

        <!-- CTA Button -->
        <a 
          href="/contact/" 
          class="mt-2 w-full btn-premium-morph px-8 py-4 bg-[#D1FC71] text-[#0D1B15] rounded-2xl text-center font-bold shadow-lg hover:shadow-xl active:scale-95 transition-all flex items-center justify-center gap-2"
        >
          <span>Get Started</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="translate-x-0 group-hover:translate-x-1 transition-transform"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </a>
      </div>
    </div>
  </div>
</header>


<style>
  /* Staggered Entrance for Links */
  #mobile-nav-overlay.is-active .mobile-link {
    animation: slideIn 0.5s var(--ease-out) forwards;
    animation-delay: calc(var(--stagger) * 60ms + 100ms);
    opacity: 0;
    transform: translateY(10px);
  }

  @keyframes slideIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Custom Easing from Emil Kowalski's recommendations */
  :root {
    --ease-out: cubic-bezier(0.23, 1, 0.32, 1);
  }

  /* Make sure the navbar stays above everything */
  header {
    z-index: 1000;
  }

  /* Hamburger Animation */
  button.is-nav-active span:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }
  button.is-nav-active span:nth-child(2) {
    opacity: 0;
  }
  button.is-nav-active span:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }

  /* Navigation Hover States */
  @media (hover: hover) and (pointer: fine) {
    .nav-link:hover .nav-bg {
      opacity: 1 !important;
    }
    .nav-link:hover .nav-dot {
      background: var(--color-spring-green-8, #0D1B15) !important;
    }
    .nav-link:hover .nav-text {
      color: var(--color-spring-green-8, #0D1B15) !important;
    }
  .solutions-dropdown:hover .solutions-chevron,
  .solutions-dropdown.is-open .solutions-chevron {
    transform: rotate(180deg);
  }

  /* Show panel when it has the is-active class */
  .solutions-panel.is-active {
    opacity: 1;
    pointer-events: auto;
    transform: scale(1);
  }

  .solutions-panel {
    transform: scale(0.95);
    transform-origin: top;
    transition: 
      opacity 200ms var(--ease-out),
      transform 200ms var(--ease-out);
  }

  /* Active states for mobile dropdown items */
  .mobile-link:active {
    transform: scale(0.98);
  }

  /* Prevent scrolling when menu is open */
  body.menu-open {
    overflow: hidden;
  }
</style>

<script>
  function initNavbar() {
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileNavOverlay = document.getElementById('mobile-nav-overlay');
    const mobileNavCard = document.getElementById('mobile-nav-card');
    const closeMobileBtn = document.getElementById('close-mobile-nav');
    const mobileLinks = document.querySelectorAll('.mobile-link');

    if (!mobileMenuBtn || !mobileNavOverlay || !mobileNavCard) return;

    const openMenu = () => {
      mobileNavOverlay.classList.remove('opacity-0', 'pointer-events-none');
      mobileNavOverlay.classList.add('opacity-100', 'pointer-events-auto', 'is-active');
      mobileNavCard.classList.remove('translate-y-[-40px]');
      mobileNavCard.classList.add('translate-y-0');
      mobileMenuBtn.classList.add('is-nav-active');
      document.body.classList.add('menu-open');
    };

    const closeMenu = () => {
      mobileNavOverlay.classList.add('opacity-0', 'pointer-events-none');
      mobileNavOverlay.classList.remove('opacity-100', 'pointer-events-auto', 'is-active');
      mobileNavCard.classList.add('translate-y-[-40px]');
      mobileNavCard.classList.remove('translate-y-0');
      mobileMenuBtn.classList.remove('is-nav-active');
      document.body.classList.remove('menu-open');
    };

    const toggleMenu = () => {
      const isOpen = !mobileNavOverlay.classList.contains('opacity-0');
      if (isOpen) closeMenu();
      else openMenu();
    };

    mobileMenuBtn.addEventListener('click', toggleMenu);
    if (closeMobileBtn) closeMobileBtn.addEventListener('click', closeMenu);

    // Close on backdrop click
    mobileNavOverlay.addEventListener('click', (e) => {
      if (e.target === mobileNavOverlay) closeMenu();
    });

    mobileLinks.forEach(link => {
      link.addEventListener('click', closeMenu);
    });

    // Desktop Solutions Dropdown Logic
    const solutionsTrigger = document.getElementById('solutions-trigger-btn');
    const solutionsPanel = document.getElementById('desktop-solutions-panel');
    const solutionsContainer = document.getElementById('solutions-dropdown-container');

    if (solutionsTrigger && solutionsPanel) {
      const showPanel = () => {
        solutionsPanel.classList.add('is-active');
        solutionsTrigger.setAttribute('aria-expanded', 'true');
        const chevron = solutionsTrigger.querySelector('.solutions-chevron');
        if (chevron) chevron.style.transform = 'rotate(180deg)';
      };

      const hidePanel = () => {
        solutionsPanel.classList.remove('is-active');
        solutionsTrigger.setAttribute('aria-expanded', 'false');
        const chevron = solutionsTrigger.querySelector('.solutions-chevron');
        if (chevron) chevron.style.transform = '';
      };

      // Show when hovering trigger or panel
      solutionsTrigger.addEventListener('mouseenter', showPanel);
      solutionsPanel.addEventListener('mouseenter', showPanel);

      // Hide when leaving both
      const handleMouseLeave = (e) => {
        // Short delay to allow moving between trigger and panel
        setTimeout(() => {
          const isOverTrigger = solutionsTrigger.matches(':hover');
          const isOverPanel = solutionsPanel.matches(':hover');
          if (!isOverTrigger && !isOverPanel) {
            hidePanel();
          }
        }, 50);
      };

      solutionsTrigger.addEventListener('mouseleave', handleMouseLeave);
      solutionsPanel.addEventListener('mouseleave', handleMouseLeave);

      // Keyboard handling
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') hidePanel();
      });
    }

    // Mobile Solutions accordion
    const mobileSolutionsBtn = document.getElementById('mobile-solutions-btn');
    const mobileSolutionsPanel = document.getElementById('mobile-solutions-panel');
    const mobileSolutionsChevron = document.getElementById('mobile-solutions-chevron');

    if (mobileSolutionsBtn && mobileSolutionsPanel) {
      mobileSolutionsBtn.addEventListener('click', () => {
        const isOpen = !mobileSolutionsPanel.classList.contains('hidden');
        mobileSolutionsBtn.setAttribute('aria-expanded', String(!isOpen));
        if (isOpen) {
          mobileSolutionsPanel.classList.add('hidden');
          mobileSolutionsPanel.classList.remove('flex');
          if (mobileSolutionsChevron) mobileSolutionsChevron.style.transform = '';
        } else {
          mobileSolutionsPanel.classList.remove('hidden');
          mobileSolutionsPanel.classList.add('flex');
          if (mobileSolutionsChevron) mobileSolutionsChevron.style.transform = 'rotate(180deg)';
        }
      });
    }
  }

  // Initial init
  initNavbar();
  // Listen for view transitions
  document.addEventListener('astro:after-swap', initNavbar);
</script>
