---
/**
 * Services Section - Orthodontics Align
 * 6 treatment types for clear aligner services.
 */

const services = [
  {
    index: "01",
    title: "3D Treatment Planning",
    description: "Expert orthodontic technicians create precise 3D simulations using 3Shape and OnyxCeph, ensuring predictable tooth movement and biological safety for every case.",
    bullets: ["Precise Tooth Movement", "Expert Medical Review", "24-Hour STL Delivery", "Clinically Validated"],
    image: "https://framerusercontent.com/images/DjC5pMWJdlfxcNqmLKEPK4bycJk.jpg",
    path: "/services/3d-treatment-planning"
  },
  {
    index: "02",
    title: "CAD/CAM Aligner Design",
    description: "High-resolution digital design of aligner steps and attachment geometry, optimized for clear aligner materials and industrial-grade 3D printing workflows.",
    bullets: ["Custom Attachment Design", "Gingival Line Optimization", "Automated STL Export", "Material Calibration"],
    image: "https://framerusercontent.com/images/ZHxi4wDoLoO2bFOOewbLKCw.png?width=3472&height=3200",
    path: "/services/aligner-design"
  },
  {
    index: "03",
    title: "Precision Fabrication",
    description: "Industrial manufacturing using premium medical-grade plastics like Zendura FLX. Our vacuum thermoforming process ensures incredible clarity and crack resistance.",
    bullets: ["Zendura FLX Materials", "Crystal Clear Clarity", "High Crack Resistance", "Laser Edge Trimming"],
    image: "https://framerusercontent.com/images/pRfDLqmzu07eDPWmYEYmVlmqaXY.png?width=3472&height=3200",
    path: "/services/aligner-fabrication"
  },
  {
    index: "04",
    title: "Workflow Integration",
    description: "Seamlessly integrate digital orthodontics into your practice. We help you setup scan-to-print workflows that save you time and increase patient throughput.",
    bullets: ["Scanner Optimization", "Digital File Management", "Practice Training", "End-to-End Support"],
    image: "https://framerusercontent.com/images/Xvo1Nlc2AUNcyQ6my8GsMxxi2M.png?scale-down-to=512&width=4600&height=3200",
    path: "/services/practice-workflow"
  },
  {
    index: "05",
    title: "Complex Case Consulting",
    description: "Strategic planning for high-difficulty cases involving skeletal adjustments or complex sequential distalization. Our experts guide you through every stage.",
    bullets: ["Skeletal Management", "Expert Consultation", "Custom Staging Plans", "Remote Supervision"],
    image: "https://framerusercontent.com/images/3fKqpTuR1TuGSP6iX2BAfRvmD4g.png?scale-down-to=512&width=1280&height=1180",
    path: "/services/case-consultation"
  },
  {
    index: "06",
    title: "Digital Process Optimization",
    description: "Advanced repair and optimization of digital impressions. We fix scan noise and holes to ensure the highest possible fit accuracy for the final aligners.",
    bullets: ["Scan Noise Reduction", "Missing Data Repair", "High-Resolution STL", "Perfect Fit Accuracy"],
    image: "https://framerusercontent.com/images/DjC5pMWJdlfxcNqmLKEPK4bycJk.jpg",
    path: "/services/digital-optimization"
  }
];
---

<section class="w-full bg-[#F6F7FF] py-24">
  <div class="w-full max-w-[1540px] px-[50px] mx-auto flex flex-col items-center">
    
    <!-- Section Header -->
    <div class="w-full flex flex-col gap-4 mb-16 reveal-on-scroll">
      <h2 class="m-0 text-[var(--color-spring-green-8)] font-bricolage text-[48px] lg:text-[56px] font-medium leading-[1.1]">
        Our Services
      </h2>
      <p class="m-0 text-black/70 font-inter text-lg leading-[1.6] max-w-[700px]">
        Offering the best treatment planning and fabrication services for all types of cases for a smooth and hassle-free orthodontic treatment.
      </p>
    </div>

    <!-- Services Grid/List -->
    <div class="w-full flex flex-col">
      {services.map((service, idx) => (
        <div class={`w-full reveal-on-scroll stagger-${(idx % 3) + 1} flex flex-col lg:flex-row items-center lg:items-start gap-12 lg:gap-16 py-12 lg:py-16 border-t border-black/10 last:border-b`}>
          
          <!-- Image Block -->
          <div class="shrink-0 w-full md:w-[320px] h-[300px] rounded-[24px] overflow-hidden hover-lift hover:shadow-lg transition-all">
            <img src={service.image} alt={service.title} class="w-full h-full object-cover" />
          </div>

          <!-- Content Block -->
          <div class="flex-1 w-full flex flex-col md:flex-row gap-8 lg:gap-16 pt-2">
            
            <!-- Left Info (Index & Bullets) -->
            <div class="w-full md:w-[250px] shrink-0 flex flex-col gap-6">
              <div class="text-[var(--color-spring-green-8)] font-bricolage text-[40px] font-medium leading-none">
                {service.index}
              </div>
              <ul class="flex flex-col gap-3 m-0 p-0 list-none">
                {service.bullets.map((bullet) => (
                  <li class="flex items-center gap-3">
                    <div class="w-[6px] h-[6px] rounded-full bg-black/40 shrink-0"></div>
                    <span class="text-black/70 font-inter text-base">{bullet}</span>
                  </li>
                ))}
              </ul>
            </div>

            <!-- Right Content (Title, Desc, CTA) -->
            <div class="flex-1 flex flex-col gap-6 items-start">
              <h3 class="m-0 text-[var(--color-spring-green-8)] font-bricolage text-[40px] lg:text-[48px] font-medium leading-[1.1]">
                {service.title}
              </h3>
              <p class="m-0 text-black/70 font-inter text-lg leading-[1.6] max-w-[500px]">
                {service.description}
              </p>
              <a href={service.path} class="mt-4 px-8 py-4 bg-[var(--color-chartreuse-green-72)] text-[var(--color-spring-green-8)] rounded-[60px] font-inter text-base font-medium text-center no-underline transition-transform hover:scale-[0.98]">
                View Details
              </a>
            </div>
            
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
