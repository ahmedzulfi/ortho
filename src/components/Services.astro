---
/**
 * Services Section - Orthodontics Align
 * 6 treatment types for clear aligner services.
 */

const services = [
  {
    index: "01",
    title: "Expert 3D Treatment Planning",
    description: "Our orthodontic technicians create biologically safe, high-accuracy 3D simulations using advanced software, ensuring predictable tooth movements for every patient.",
    bullets: ["Phased Tooth Movement", "Biological Safety Review", "24-Hour STL Export", "Clinically Validated"],
    image: "/aligner_3d_planning_software_1776503684006.png",
    path: "/services/3d-treatment-planning"
  },
  {
    index: "02",
    title: "Precision Manufacturing",
    description: "Industrial-grade manufacturing of clear aligners using medical-grade materials. Our thermoforming process ensures incredible clarity and optimal retention.",
    bullets: ["Medical-Grade Plastics", "Crystal Clear Finish", "High Crack Resistance", "Precision Laser Trimming"],
    image: "/aligner_manufacturing_machine_1776503510227.png",
    path: "/services/aligner-fabrication"
  },
  {
    index: "03",
    title: "CAD/CAM Aligner Design",
    description: "Digital design of aligner steps and custom attachments, optimized for seamless 3D printing and thermoforming workflows in clear aligner production.",
    bullets: ["Custom Attachment Design", "Gingival Line Calibration", "High-Resolution Geometry", "Material-Specific Scaling"],
    image: "/aligner_3d_planning_software_1776503684006.png",
    path: "/services/aligner-design"
  },
  {
    index: "04",
    title: "Scan-to-Print Workflows",
    description: "Integrate digital orthodontics into your practice with our help. We establish efficient scan-to-print pipelines that maximize chairside efficiency.",
    bullets: ["Intraoral Scan Optimization", "Digital Lab Integration", "Staff Training", "Full Workflow Support"],
    image: "/aligner_high_volume_batch_1776504000020.png",
    path: "/services/practice-workflow"
  },
  {
    index: "05",
    title: "Complex Case Management",
    description: "Strategic planning for high-difficulty orthodontic cases. Our experts provide custom staging and consulting for complex movements and skeletal shifts.",
    bullets: ["Skeletal Shift Planning", "Custom Staging Protocols", "Expert Consultation", "Remote Case Monitoring"],
    image: "/aligner_3d_planning_software_1776503684006.png",
    path: "/services/case-consultation"
  },
  {
    index: "06",
    title: "Digital Mesh Optimization",
    description: "Advanced repair of digital impressions. We eliminate scan noise and fill data holes to ensure the perfect fit for your manufactured clear aligners.",
    bullets: ["High-Res STL Repair", "Digital Noise Removal", "Fitting Accuracy", "Bite Realignment Scan"],
    image: "/aligner_manufacturing_machine_1776503510227.png",
    path: "/services/digital-optimization"
  }
];
---

<section class="w-full bg-[#F6F7FF] py-12 md:py-24">
  <div class="w-full max-w-[1540px] px-6 md:px-12 lg:px-[50px] mx-auto flex flex-col items-center">
    
    <!-- Section Header -->
    <div class="w-full flex flex-col gap-2 md:gap-4 mb-8 md:mb-16 reveal-on-scroll">
      <h2 class="m-0 text-[var(--color-spring-green-8)] font-bricolage text-3xl md:text-[48px] lg:text-[56px] font-medium leading-[1.1]">
        Aligner Manufacturing & Planning
      </h2>
      <p class="m-0 text-black/70 font-inter text-base md:text-lg leading-[1.6] max-w-[700px]">
        Offering world-class dental aligner manufacturing and precise 3D treatment planning to ensure a predictable and successful orthodontic experience for every patient.
      </p>
    </div>

    <!-- Services Grid/List -->
    <div class="w-full flex flex-col">
      {services.map((service, idx) => (
        <div class={`w-full reveal-on-scroll stagger-${(idx % 3) + 1} flex flex-col lg:flex-row items-center lg:items-start gap-8 md:gap-12 lg:gap-16 py-8 md:py-16 border-t border-black/10 last:border-b`}>
          
          <!-- Image Block -->
          <div class="shrink-0 w-full md:w-[320px] h-[200px] md:h-[300px] rounded-[20px] md:rounded-[24px] overflow-hidden hover-lift hover:shadow-lg transition-all">
            <img src={service.image} alt={service.title} class="w-full h-full object-cover" />
          </div>

          <!-- Content Block -->
          <div class="flex-1 w-full flex flex-col md:flex-row gap-6 md:gap-8 lg:gap-16 pt-2">
            
            <!-- Left Info (Index & Bullets) -->
            <div class="w-full md:w-[250px] shrink-0 flex flex-col gap-4 md:gap-6">
              <div class="text-[var(--color-spring-green-8)] font-bricolage text-3xl md:text-[40px] font-medium leading-none">
                {service.index}
              </div>
              <ul class="flex flex-col gap-2 md:gap-3 m-0 p-0 list-none text-sm md:text-base">
                {service.bullets.map((bullet) => (
                  <li class="flex items-center gap-2 md:gap-3">
                    <div class="w-[5px] h-[5px] rounded-full bg-black/40 shrink-0"></div>
                    <span class="text-black/70 font-inter">{bullet}</span>
                  </li>
                ))}
              </ul>
            </div>

            <!-- Right Content (Title, Desc, CTA) -->
            <div class="flex-1 flex flex-col gap-4 md:gap-6 items-start">
              <h3 class="m-0 text-[var(--color-spring-green-8)] font-bricolage text-2xl md:text-[40px] lg:text-[48px] font-medium leading-[1.1]">
                {service.title}
              </h3>
              <p class="m-0 text-black/70 font-inter text-base md:text-lg leading-[1.6] max-w-[500px]">
                {service.description}
              </p>
              <a href={service.path} class="mt-2 md:mt-4 px-6 md:px-8 py-3 md:py-4 bg-[var(--color-chartreuse-green-72)] text-[var(--color-spring-green-8)] rounded-[60px] font-inter text-sm md:text-base font-medium text-center no-underline transition-transform hover:scale-[0.98]">
                View Details
              </a>
            </div>
            
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
