---
/**
 * Services Section - High Fidelity Version
 * Updated to match the requested look and feel with detailed structure.
 */

const services = [
  {
    index: "01",
    title: "General Dentistry",
    description: "Routine exams, cleanings, and preventive care to keep your teeth and gums healthy.",
    bullets: ["Oral Surgery", "Digital Records", "Online Booking", "Multilingual Support"],
    image: "https://framerusercontent.com/images/ZHxi4wDoLoO2bFOOewbLKCw.png?width=3472&height=3200"
  },
  {
    index: "02",
    title: "Orthodontics Care",
    description: "Personalized orthodontic solutions designed to align your teeth comfortably and effectively for a confident smile.",
    bullets: ["Clear Aligners", "Traditional Braces", "Retainer Programs", "3D Treatment Planning"],
    image: "https://framerusercontent.com/images/pRfDLqmzu07eDPWmYEYmVlmqaXY.png?width=3472&height=3200"
  },
  {
    index: "03",
    title: "Cosmetic Dentistry",
    description: "Enhance your natural beauty with advanced cosmetic treatments that create a brighter, more radiant smile.",
    bullets: ["Teeth Whitening", "Veneers & Bonding", "Smile Makeovers", "Digital Smile Preview"],
    image: "https://framerusercontent.com/images/Xvo1Nlc2AUNcyQ6my8GsMxxi2M.png?scale-down-to=512&width=4600&height=3200"
  },
  {
    index: "04",
    title: "Oral Surgery",
    description: "Comprehensive surgical care performed with precision and comfort to restore and protect your oral health.",
    bullets: ["Wisdom Tooth Removal", "Dental Implants", "Bone Grafting", "Sedation Options"],
    image: "https://framerusercontent.com/images/3fKqpTuR1TuGSP6iX2BAfRvmD4g.png?scale-down-to=512&width=1280&height=1180"
  }
];
---

<section 
  style="box-sizing: border-box; -webkit-font-smoothing: inherit; overflow: visible; flex-flow: row; flex: 0 0 auto; place-content: center; gap: 0px; padding: 0px; height: min-content; align-items: center; width: 100%; display: flex; position: relative;"
>
  <div style="width: 100%; max-width: 1540px; padding-left: 50px; padding-right: 50px; padding-top: 120px; padding-bottom: 120px; overflow: hidden; flex-direction: column; justify-content: flex-start; align-items: center; display: inline-flex;">
    <!-- Section Header -->
    <div class="reveal-on-scroll" style="align-self: stretch; margin-bottom: 80px; justify-content: space-between; align-items: center; display: inline-flex;">
      <h2 style="margin: 0; color: var(--color-spring-green-8); font-size: 48px; font-family: 'Bricolage Grotesque'; font-weight: 500; line-height: 57.60px;">Our Services</h2>
      <div style="padding: 11px 16px; background: var(--color-chartreuse-green-72); border-radius: 100px; color: var(--color-spring-green-8); font-size: 16px; font-family: 'Inter'; font-weight: 400; cursor: pointer;">
        View Services
      </div>
    </div>

    <!-- Services Grid/List -->
    <div style="align-self: stretch; flex-direction: column; justify-content: center; align-items: flex-start; gap: 48px; display: flex;">
      {services.map((service, idx) => (
        <div class={`reveal-on-scroll stagger-${idx + 1}`} style="align-self: stretch; justify-content: flex-start; align-items: center; gap: 80px; display: inline-flex;">
          <!-- Image Block -->
          <div class="hover-lift" style="width: 320px; height: 295px; max-width: 320px; overflow: hidden; border-radius: 6px; justify-content: flex-start; align-items: center; display: flex;">
            <div style="width: 320px; height: 295px; position: relative;">
              <img style="width: 320px; height: 295px; left: 0; top: 0; position: absolute; object-fit: cover;" src={service.image} alt={service.title} />
            </div>
          </div>

          <!-- Content Block -->
          <div style="max-width: 900px; padding-top: 40px; padding-bottom: 40px; position: relative; justify-content: flex-start; align-items: flex-start; gap: 60px; display: flex; flex: 1;">
            <!-- Left Info (Index & Bullets) -->
            <div style="max-width: 282px; min-width: 282px; flex-direction: column; justify-content: flex-start; align-items: flex-start; gap: 19px; display: inline-flex;">
              <div style="flex-direction: column; justify-content: flex-start; align-items: flex-start; display: flex;">
                <div style="align-self: stretch; flex-direction: column; justify-content: flex-start; align-items: flex-start; display: flex;">
                  <div style="justify-content: center; display: flex; flex-direction: column; color: var(--color-spring-green-8); font-size: 36px; font-family: 'Bricolage Grotesque'; font-weight: 500; line-height: 45px; word-wrap: break-word;">{service.index}</div>
                </div>
              </div>
              <div style="align-self: stretch; flex-direction: column; justify-content: flex-start; align-items: flex-start; gap: 11px; display: flex;">
                {service.bullets.map((bullet) => (
                  <div style="align-self: stretch; justify-content: center; align-items: center; gap: 6px; display: inline-flex;">
                    <div style="height: 27.20px; justify-content: center; align-items: flex-start; display: flex;">
                      <div style="align-self: stretch; padding-top: 11px; justify-content: center; align-items: flex-start; display: flex;">
                        <div style="width: 5px; height: 5px; position: relative; background: var(--color-grey-36); border-radius: 50px;"></div>
                      </div>
                    </div>
                    <div style="flex: 1 1 0; flex-direction: column; justify-content: flex-start; align-items: flex-start; display: inline-flex;">
                      <div style="align-self: stretch; flex-direction: column; justify-content: flex-start; align-items: flex-start; display: flex;">
                        <div style="align-self: stretch; justify-content: center; display: flex; flex-direction: column; color: var(--color-grey-36); font-size: 16px; font-family: 'Inter'; font-weight: 400; line-height: 27.20px; word-wrap: break-word;">{bullet}</div>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <!-- Right Content (Title, Desc, CTA) -->
            <div style="width: 558px; height: 203.20px; position: relative;">
              <div style="width: 558px; padding-bottom: 0.59px; left: 0; top: -1px; position: absolute; flex-direction: column; justify-content: flex-start; align-items: flex-start; display: inline-flex;">
                <div style="justify-content: center; display: flex; flex-direction: column; color: var(--color-spring-green-8); font-size: 48px; font-family: 'Bricolage Grotesque'; font-weight: 500; line-height: 57.60px; word-wrap: break-word;">{service.title}</div>
              </div>
              <div style="width: 390.59px; left: 0; top: 76.70px; position: absolute; flex-direction: column; justify-content: flex-start; align-items: flex-start; display: inline-flex;">
                <div style="align-self: stretch; flex-direction: column; justify-content: flex-start; align-items: flex-start; display: flex;">
                  <div style="align-self: stretch; justify-content: center; display: flex; flex-direction: column; color: var(--color-grey-36); font-size: 16px; font-family: 'Inter'; font-weight: 400; line-height: 27.20px; word-wrap: break-word;">{service.description}</div>
                </div>
              </div>
              <a href="#" style="padding-top: 11px; padding-bottom: 12px; padding-left: 16px; padding-right: 16px; left: 0; top: 152px; position: absolute; background: var(--color-chartreuse-green-72); overflow: hidden; border-radius: 100px; flex-direction: column; justify-content: flex-start; align-items: center; display: inline-flex; text-decoration: none;">
                <div style="flex-direction: column; justify-content: flex-start; align-items: flex-start; display: flex;">
                  <div style="align-self: stretch; flex-direction: column; justify-content: flex-start; align-items: flex-start; display: flex;">
                    <div style="justify-content: center; display: flex; flex-direction: column; color: var(--color-spring-green-8); font-size: 16px; font-family: 'Inter'; font-weight: 400; line-height: 27.20px; word-wrap: break-word;">View Details</div>
                  </div>
                </div>
              </a>
            </div>
            
            <!-- Bottom Border (absolute within relative content container) -->
            <div style="width: 900px; height: 289px; left: 0; top: 0; position: absolute; border-top: 1px var(--color-grey-78) solid; border-bottom: 1px var(--color-grey-78) solid; pointer-events: none;" />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
