---
/**
 * Services Section - Orthodontics Align
 * 6 treatment types for clear aligner services.
 */

interface ServiceItem {
  index: string;
  title: string;
  description: string;
  bullets: string[];
  image: string;
  path: string;
}

interface Props {
  title?: string;
  description?: string;
  servicesData?: ServiceItem[];
}

const defaultServices = [
  {
    index: "01",
    title: "End-to-End MVP Development",
    description: "We build functional, usable products that can onboard real users and collect feedback. From auth systems to dashboards, we handle it all.",
    bullets: ["Full-Stack Development", "Authentication Systems", "Database Architecture", "Investor-Ready UI/UX"],
    image: "https://images.pexels.com/photos/1181244/pexels-photo-1181244.jpeg?auto=compress&cs=tinysrgb&w=800",
    path: "/services/mvp-development"
  },
  {
    index: "02",
    title: "Prototypes to Production",
    description: "Bridging the gap for founders using Replit or no-code tools. We turn rough prototypes into structured, scalable production systems.",
    bullets: ["Replit Migration", "Code Refactoring", "Scalability Optimization", "CI/CD Setup"],
    image: "https://images.pexels.com/photos/1181263/pexels-photo-1181263.jpeg?auto=compress&cs=tinysrgb&w=800",
    path: "/services/prototype-to-production"
  },
  {
    index: "03",
    title: "AI & Emerging Tech Integration",
    description: "Differentiate early by incorporating AI-driven features like automation, data processing, and intelligent workflows into your MVP.",
    bullets: ["LLM Integration", "AI-Driven Automation", "Intelligent Workflows", "Data Processing"],
    image: "https://images.pexels.com/photos/1181467/pexels-photo-1181467.jpeg?auto=compress&cs=tinysrgb&w=800",
    path: "/services/ai-integration"
  },
  {
    index: "04",
    title: "Modern Tech Stacks",
    description: "Build on a solid foundation. We use widely adopted technologies like MERN, PostgreSQL, and Cloud services for maximum longevity.",
    bullets: ["MERN (React/Node)", "PostgreSQL / MongoDB", "Cloud Deployment", "API Development"],
    image: "https://images.pexels.com/photos/3861969/pexels-photo-3861969.jpeg?auto=compress&cs=tinysrgb&w=800",
    path: "/services/tech-stack"
  },
  {
    index: "05",
    title: "Rapid Iteration & Delivery",
    description: "Direct communication and continuous delivery. See progress weekly and refine your product direction in real time.",
    bullets: ["Weekly Sprints", "Direct Founder Access", "Rapid Prototyping", "Continuous Feedback"],
    image: "https://images.pexels.com/photos/3183158/pexels-photo-3183158.jpeg?auto=compress&cs=tinysrgb&w=800",
    path: "/services/rapid-iteration"
  },
  {
    index: "06",
    title: "Technical Strategy & Partnership",
    description: "We act as your technical co-founder, translating business ideas into software that meets market trends and user expectations.",
    bullets: ["Strategic Consulting", "Roadmap Planning", "Founder-Led Design", "Growth Ready Architecture"],
    image: "https://images.pexels.com/photos/3182812/pexels-photo-3182812.jpeg?auto=compress&cs=tinysrgb&w=800",
    path: "/services/technical-partnership"
  }
];

const {
  title = "Fast-Execution Development",
  description = "Helping founders launch faster and scale further with technical execution that prioritizes speed, clarity, and practicality.",
  servicesData = defaultServices
} = Astro.props;
---

<section class="w-full bg-[#F6F7FF]  py-12 md:py-24 px-6 md:px-[50px] flex justify-center overflow-hidden">
  <div class="w-full max-w-[1440px] flex flex-col items-center">
    
    <!-- Section Header -->
    <div class="w-full flex flex-col gap-6 mb-8 md:mb-16 reveal-on-scroll">
      <div class="flex items-center gap-2">
        <div class="w-1.5 h-1.5 bg-[var(--color-spring-green-8,#0D1B15)] rounded-full"></div>
        <div class="text-[var(--color-spring-green-8,#0D1B15)] text-base font-['Jost'] font-normal tracking-wide">Services</div>
      </div>
      <div class="flex flex-col gap-5">
        <h2 class="m-0 text-[var(--color-spring-green-8,#0D1B15)] text-4xl md:text-[56px] font-['Bricolage_Grotesque'] font-medium leading-[1.1] tracking-[-1.5px] md:tracking-[-2px]">
          {title}
        </h2>
        <p class="m-0 text-[var(--color-grey-36,#595E5C)] text-base md:text-lg font-['Inter'] font-normal leading-relaxed max-w-[700px]">
          {description}
        </p>
      </div>
    </div>

    <!-- Services Grid/List -->
    <div class="w-full flex flex-col">
      {servicesData.map((service, idx) => (
        <div class={`w-full reveal-on-scroll stagger-${(idx % 3) + 1} flex flex-col lg:flex-row items-center lg:items-start gap-8 md:gap-12 lg:gap-16 py-8 md:py-16 border-t border-black/10 last:border-b`}>
          
          <!-- Image Block -->
          <div class="shrink-0 w-full md:w-[320px] h-[200px] md:h-[300px] rounded-[20px] md:rounded-[24px] overflow-hidden hover-lift hover:shadow-lg transition-all">
            <img src={service.image} alt={service.title} class="w-full h-full object-cover" loading="lazy" />
          </div>

          <!-- Content Block -->
          <div class="flex-1 w-full flex flex-col md:flex-row gap-6 md:gap-8 lg:gap-16 pt-2">
            
            <!-- Left Info (Index & Bullets) -->
            <div class="w-full md:w-[250px] shrink-0 flex flex-col gap-4 md:gap-6">
              <div class="text-[var(--color-spring-green-8)] font-bricolage text-3xl md:text-[40px] font-medium leading-none">
                {service.index}
              </div>
              <ul class="flex flex-col gap-2 md:gap-3 m-0 p-0 list-none text-sm md:text-base">
                {service.bullets.map((bullet) => (
                  <li class="flex items-center gap-2 md:gap-3">
                    <div class="w-[5px] h-[5px] rounded-full bg-black/40 shrink-0"></div>
                    <span class="text-black/70 font-inter">{bullet}</span>
                  </li>
                ))}
              </ul>
            </div>

            <!-- Right Content (Title, Desc, CTA) -->
            <div class="flex-1 flex flex-col gap-4 md:gap-6 items-start">
              <h3 class="m-0 text-[var(--color-spring-green-8)] font-bricolage text-2xl md:text-[40px] lg:text-[48px] font-medium leading-[1.1]">
                {service.title}
              </h3>
              <p class="m-0 text-black/70 font-inter text-base md:text-lg leading-[1.6] max-w-[500px]">
                {service.description}
              </p>
              <a href={service.path} class="btn-premium-morph btn-green-bg mt-2 md:mt-4 px-6 md:px-8 py-3 md:py-4 bg-[var(--color-chartreuse-green-72,#D1FC71)] text-[var(--color-spring-green-8,#0D1B15)] rounded-[60px] font-['Inter'] text-sm md:text-base font-medium text-center no-underline transition-transform hover:scale-[0.98]">
                <span>View Details</span>
              </a>
            </div>
            
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
