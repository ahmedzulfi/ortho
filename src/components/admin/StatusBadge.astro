---
export interface Props {
  status: 'pending' | 'confirmed' | 'completed' | 'cancelled';
}

const { status } = Astro.props;

const styles = {
  pending: 'bg-amber-50 text-amber-700 border border-amber-200/50',
  confirmed: 'bg-emerald-50 text-emerald-700 border border-emerald-200/50',
  completed: 'bg-gray-100 text-gray-700 border border-gray-200/50',
  cancelled: 'bg-rose-50 text-rose-700 border border-rose-200/50',
};

const labels = {
  pending: 'Pending Review',
  confirmed: 'Accepted',
  completed: 'Completed',
  cancelled: 'Declined',
};
---
<span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold ${styles[status]}`}>
  {labels[status]}
</span>