---
/**
 * Process Section - Orthodontics Align
 * 4-step interactive workflow for clear aligner treatment planning.
 */

interface ProcessStep {
  index: string;
  title: string;
  description: string;
  image: string;
  features: string[];
}

interface Props {
  title?: string;
  description?: string;
  stepsData?: ProcessStep[];
}

const defaultSteps = [
  {
    index: "01",
    title: "Discovery & Blueprinting",
    description: "We work directly with founders to identify the smallest viable version of their product. We define core features, user personas, and technical architecture.",
    image: "/process/discovery.jfif",
    features: ["Feature Scoping", "User Flow Mapping", "Tech Stack Selection", "Architecture Design"]
  },
  {
    index: "02",
    title: "Rapid Execution Phase",
    description: "Our technical partners move into higher-gear development, building functional software with clean UI and scalable backend logic in record time.",
    image: "https://images.pexels.com/photos/1181244/pexels-photo-1181244.jpeg?auto=compress&cs=tinysrgb&w=800",
    features: ["MERN/PostgreSQL Build", "AI Feature Integration", "API Development", "Auth & State Mgmt"]
  },
  {
    index: "03",
    title: "Production Stabilization",
    description: "We bridge the gap from prototype to production. This includes setting up automated deployment pipelines, cloud infrastructure, and rigorous testing.",
    image: "/process/test.png",
    features: ["Cloud Deployment", "Test Automation", "CI/CD Setup", "Performance Tuning"]
  },
  {
    index: "04",
    title: "Launch & Iterate",
    description: "Your investor-ready product goes live. We support the initial launch and help you iterate based on real-world user feedback and traction.",
    image: "/process/launch.png",
    features: ["Public Launch", "User Onboarding", "Feedback Collection", "Growth Support"]
  }
];

const {
  title = "How We Build",
  description = "From idea to launch in weeks. Our streamlined workflow ensures constant visibility and rapid delivery of working software.",
  stepsData = defaultSteps
} = Astro.props;
---

<section id="process-section" class="w-full bg-[var(--color-white-solid,white)] overflow-hidden justify-center items-center flex py-20 md:py-[120px]">
  <div class="w-full max-w-[1440px] px-6 md:px-[0px] overflow-hidden flex-col justify-start items-center gap-12 md:gap-20 inline-flex">
    
    <!-- Section Header -->
    <div class="reveal-on-scroll w-full flex-col justify-start items-start gap-5 flex">
      <div class="self-stretch flex-col justify-start items-end gap-4 flex">
        <div class="self-stretch justify-center items-center gap-2 inline-flex">
          <div class="w-1 h-1 relative bg-[var(--color-spring-green-8)] rounded-[30px]"></div>
          <div class="flex-1 flex-col justify-start items-start inline-flex">
            <div class="self-stretch text-[var(--color-spring-green-8)] text-base font-['Inter'] font-normal leading-[27.20px]">Our Execution</div>
          </div>
        </div>
      </div>
      
      <div class="self-stretch relative flex flex-col md:flex-row justify-between items-start md:items-end flex-wrap gap-5">
        <h2 class="m-0 text-[var(--color-spring-green-8)] text-4xl md:text-[48px] font-['Bricolage_Grotesque'] font-medium leading-tight md:leading-[57.60px]">{title}</h2>
        <div class="max-w-[571px] text-[var(--color-grey-36)] text-base md:text-lg font-['Inter'] font-normal leading-relaxed md:leading-[30.60px]">
          {description}
        </div>
      </div>
    </div>

    <!-- Steps List -->
    <div class="process-steps-container self-stretch flex-col justify-start items-center gap-6 flex">
      {stepsData.map((step, idx) => (
        <div 
          class={`process-step-item reveal-on-scroll stagger-${idx + 1}`} 
          data-index={idx}
          data-expanded={idx === 0 ? "true" : "false"}
        >
          <div class="step-header">
            <div class="step-title-group">
              <div class="step-number-circle">
                <span class="step-number">{step.index}</span>
              </div>
              <h3 class="step-title">{step.title}</h3>
            </div>
            <div class="step-toggle-btn">
               <div class="toggle-icon"></div>
            </div>
          </div>

          <!-- Expanded Content -->
          <div class="step-content">
            <div class="content-inner">
              <div class="image-wrapper">
                <img src={step.image} alt={step.title} />
              </div>
              <div class="text-wrapper">
                <p class="step-description">{step.description}</p>
                <div class="features-group">
                  <h4 class="features-label">What You Need</h4>
                  <div class="features-list">
                    {step.features?.map(feature => (
                      <div class="feature-tag">{feature}</div>
                    ))}
                  </div>
                </div>
                <div class="cta-wrapper">
                  <a href="/contact" class="btn-primary">Get Started</a>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Base Item Styling */
  .process-step-item {
    align-self: stretch;
    background: #FFF;
    border: 1px solid var(--color-grey-78);
    border-radius: 40px;
    overflow: hidden;
    transition: all 0.5s var(--ease-out);
    cursor: pointer;
  }

  .process-step-item[data-expanded="true"] {
    background: var(--color-spring-green-8) !important;
    border-color: transparent !important;
    cursor: default;
  }

  /* Header Interaction */
  .step-header {
    padding: 22px 50px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: padding 0.5s var(--ease-out);
  }

  .process-step-item[data-expanded="true"] .step-header {
    padding-bottom: 24px;
    padding-top: 40px;
  }

  .step-title-group {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .step-number-circle {
    width: 60px;
    height: 60px;
    border-radius: 100px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.5s var(--ease-out);
  }

  .process-step-item[data-expanded="true"] .step-number-circle {
    border-color: #ffffff00;
  }

  .step-number {
    font-family: 'Inter';
    color: var(--color-spring-green-8);
    font-size: 16px;
    transition: color 0.5s var(--ease-out);
  }

  .process-step-item[data-expanded="true"] .step-number {
    color: #FFF;
  }

  .step-title {
    margin: 0;
    font-family: 'Bricolage Grotesque';
    font-size: 36px;
    font-weight: 500;
    color: var(--color-spring-green-8);
    transition: color 0.5s var(--ease-out);
  }

  .process-step-item[data-expanded="true"] .step-title {
    color: #FFF;
  }

  /* Toggle Icon */
  .step-toggle-btn {
    width: 64px;
    height: 64px;
    border-radius: 100px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.5s var(--ease-out);
  }

  .process-step-item[data-expanded="true"] .step-toggle-btn {
    transform: rotate(45deg);
  }
.process-step-item[data-expanded="true"] .toggle-icon{
  background: #fff;
}
  .toggle-icon {
    width: 19px;
    height: 19px;
    background: #0D1B15;
    clip-path: polygon(45% 0%, 55% 0%, 55% 45%, 100% 45%, 100% 55%, 55% 55%, 55% 100%, 45% 100%, 45% 55%, 0% 55%, 0% 45%, 45% 45%);
  }

  /* Content Expansion */
  .step-content {
    max-height: 0;
    opacity: 0;
    visibility: hidden;
    overflow: hidden;
    transition: all 0.6s var(--ease-out);
  }

  .process-step-item[data-expanded="true"] .step-content {
    max-height: 600px;
    opacity: 1;
    visibility: visible;
    padding-bottom: 80px;
  }

  .content-inner {
    padding: 0 70px;
    display: flex;
    gap: 60px;
    align-items: flex-start;
  }

  .image-wrapper {
    width: 380px;
    height: 280px;
    border-radius: 32px;
    overflow: hidden;
    flex-shrink: 0;
    box-shadow: 0 20px 40px rgba(0,0,0,0.2);
  }

  .image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .text-wrapper {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .step-description {
    margin: 0;
    color: #F5F4F7;
    font-family: 'Inter';
    font-size: 20px;
    line-height: 1.6;
    max-width: 600px;
  }

  .features-group {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .features-label {
    margin: 0;
    color: var(--color-grey-78);
    font-family: 'Inter';
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .features-list {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .feature-tag {
    padding: 8px 20px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 32px;
    color: white;
    font-family: 'Inter';
    font-size: 14px;
  }

  .btn-primary {
    padding: 14px 32px;
    background: var(--color-chartreuse-green-72);
    border-radius: 100px;
    color: var(--color-spring-green-8);
    font-family: 'Inter';
    font-weight: 600;
    text-decoration: none;
    display: inline-block;
    transition: transform 0.2s;
  }

  .btn-primary:hover {
    transform: scale(1.02);
  }

  /* Mobile Adjustments */
  @media (max-width: 768px) {
    .step-header {
      padding: 16px 20px;
    }
    .process-step-item[data-expanded="true"] .step-header {
      padding-bottom: 16px;
      padding-top: 24px;
    }
    .step-title-group {
      gap: 12px;
    }
    .content-inner {
      padding: 0 20px;
      flex-direction: column;
      gap: 24px;
    }
    .image-wrapper {
      width: 100%;
      height: 200px;
      border-radius: 20px;
    }
    .step-title {
      font-size: 15px !important;
    }
    .step-number-circle {
      width: 36px;
      height: 36px; 
    }
    .step-toggle-btn {
      width: 40px;
      height: 40px;
    }
    .toggle-icon {
      width: 10px;
      height: 10px;
    }
    .process-step-item[data-expanded="true"] .step-content {
      max-height: 1000px; /* Safer for mobile stacking */
      padding-bottom: 40px;
    }
    .step-description {
      font-size: 14px;
    }
    .text-wrapper {
      gap: 20px;
    }
    .features-list {
      gap: 8px;
    }
    .feature-tag {
      padding: 6px 14px;
      font-size: 11px;
    }
  }
</style>

<script>
  function initProcessAccordion() {
    const items = document.querySelectorAll('.process-step-item');
    
    items.forEach(item => {
      const header = item.querySelector('.step-header');
      if (!header) return;

      header.addEventListener('click', () => {
        const isCurrentExpanded = item.getAttribute('data-expanded') === 'true';
        
        // Collapse all others
        items.forEach(other => {
          if (other !== item) {
            other.setAttribute('data-expanded', 'false');
          }
        });

        // Toggle current
        item.setAttribute('data-expanded', isCurrentExpanded ? 'false' : 'true');
      });
    });
  }

  // Initial load
  initProcessAccordion();

  // Watch for Astro page transitions if using ViewTransitions
  document.addEventListener('astro:after-swap', initProcessAccordion);
</script>
