---
const galleryImages = [
  "/assets/images/gallery-dashboard.png",
  "/assets/images/gallery-ai.png",
  "/assets/images/gallery-mobile.png",
  "/assets/images/coding-ai.png",
  "/assets/images/team-collab.png",
  "/assets/images/engineer-portrait.png",
  "/Gemini_Generated_Image_jt8usfjt8usfjt8u.png",
  "/assets/images/gallery-dashboard.png",
];
---

<section
  class="gallery-section w-full py-12 md:py-[112px] overflow-hidden bg-[#F6F7FF] flex flex-col items-center gap-5"
>
  <!-- Top Marquee Row (Staggered Offsets) -->
  <div class="marquee-container h-[210px] md:h-[270px]">
    <div class="marquee-track">
      {
        Array(3)
          .fill(galleryImages)
          .flat()
          .map((img, i) => {
            const offsets = [
              "mt-0",
              "mt-[40px]",
              "mt-[80px]",
              "mt-[120px]",
              "mt-[160px]",
              "mt-[120px]",
              "mt-[80px]",
              "mt-[40px]",
            ];
            const topOffset = offsets[i % offsets.length];
            return (
              <div class={`gallery-item ${topOffset}`}>
                <img
                  src={img}
                  alt="Startup technical execution"
                  loading="lazy"
                />
              </div>
            );
          })
      }
    </div>
  </div>

  <!-- Center Content -->
  <div
    class="w-full max-w-[1440px] flex flex-col items-center justify-center gap-6 md:gap-10 px-6 py-6 md:py-10 z-10"
  >
    <div
      class="w-full max-w-[610px] self-stretch flex flex-col justify-start items-center gap-4 md:gap-[24.01px] mx-auto"
    >
      <!-- Label -->
      <div class="flex items-center gap-2">
        <div
          class="w-1.5 h-1.5 bg-[var(--color-spring-green-8,#0D1B15)] rounded-full"
        >
        </div>
        <div
          class="text-[var(--color-spring-green-8,#0D1B15)] text-base font-['Jost'] font-normal tracking-wide"
        >
          Showcase
        </div>
      </div>

      <!-- Heading & Paragraph -->
      <div
        class="reveal-on-scroll self-stretch flex flex-col justify-start items-center gap-4 md:gap-6 text-center"
      >
        <h2
          class="m-0 text-[#0D1B15] text-4xl md:text-[48px] font-['Bricolage_Grotesque'] font-medium leading-[1.1] tracking-[-1.5px] md:tracking-[-2px]"
        >
          Visualizing Precision in Every MVP Build
        </h2>
        <p
          class="m-0 max-w-[540px] text-[#0D1B15] text-[15px] md:text-[18px] font-['Inter'] font-normal leading-relaxed opacity-80"
        >
          Check out our portfolio featuring high-fidelity startup launches, from
          complex dashboards to intelligent AI workflows.
        </p>
      </div>
    </div>

    <!-- Button -->
    <div class="flex flex-col justify-start items-start">
      <a
        href="/contact/"
        class="btn-premium-morph btn-green-bg px-8 py-4 bg-[#D1FC71] rounded-full text-[#0D1B15] font-['Inter'] text-base font-medium no-underline transition-all ring-1 ring-black/5"
      >
        <span>Plan Your Product</span>
      </a>
    </div>
  </div>

  <!-- Bottom Marquee Row (Reverse Staggered) -->
  <div class="marquee-container h-[210px] md:h-[270px]">
    <div class="marquee-track reverse">
      {
        Array(3)
          .fill(galleryImages.reverse())
          .flat()
          .map((img, i) => {
            const offsets = [
              "mt-[160px]",
              "mt-[120px]",
              "mt-[80px]",
              "mt-[40px]",
              "mt-0",
              "mt-[40px]",
              "mt-[80px]",
              "mt-[120px]",
            ];
            const topOffset = offsets[i % offsets.length];
            return (
              <div class={`gallery-item ${topOffset}`}>
                <img src={img} alt="Technical workplace clone" loading="lazy" />
              </div>
            );
          })
      }
    </div>
  </div>
</section>

<style>
  .marquee-container {
    width: 100%;
    overflow: hidden;
    position: relative;
    mask-image: linear-gradient(
      to right,
      transparent,
      black 10%,
      black 90%,
      transparent
    );
  }

  .marquee-track {
    display: flex;
    gap: 16px;
    width: max-content;
    animation: scroll 60s linear infinite;
  }

  .marquee-track.reverse {
    animation: scroll-reverse 60s linear infinite;
  }

  .gallery-item {
    width: 90px;
    height: 85px;
    flex-shrink: 0;
    border-radius: 12px;
    overflow: hidden;
    background: #eee;
  }

  @media (min-width: 768px) {
    .gallery-item {
      width: 135px;
      height: 130px;
    }
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @keyframes scroll-reverse {
    0% {
      transform: translateX(-50%);
    }
    100% {
      transform: translateX(0);
    }
  }
</style>
