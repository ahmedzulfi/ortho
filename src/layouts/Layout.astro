---
import "../styles/global.css";
import ClickSpark from "../components/ClickSpark.jsx";
import Analytics from "@vercel/analytics/astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  canonicalUrl?: string;
}

const {
  title = "ValidMVPs | Fast-Execution Development Partner for Founders",
  description = "Turn ideas into investor-ready products in record time. We build scalable MVPs with MERN stack, AI integration, and production-ready architecture.",
  ogImage = "/images/og-image.png", // Default OG image
  ogType = "website",
  canonicalUrl = new URL(Astro.url.pathname.replace(/\/$/, "") + "/", Astro.site)
    .href,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="MVP development agency, startup technical partner, fast software execution, Replit to production, MERN stack developers, AI startup MVP, functional prototype to product, scalable MVP architecture"
    />
    <meta name="author" content="ValidMVPs" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph / Facebook -->
    <meta property="og:site_name" content="ValidMVPs" />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.url)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(ogImage, Astro.url)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Jost:ital,wght@0,100..900;1,100..900&family=Gilda+Display&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "ValidMVPs",
        "alternateName": "Valid MVPs",
        "url": "https://validmvps.vercel.app",
        "logo": "https://validmvps.vercel.app/images/LOGO.png",
        "sameAs": [
          "https://www.linkedin.com/company/validmvps",
          "https://www.instagram.com/validmvps",
          "https://x.com/validmvps"
        ],
        "contactPoint": {
          "@type": "ContactPoint",
          "telephone": "+92-321-9473647",
          "contactType": "Technical Support",
          "availableLanguage": ["English"]
        },
        "description": "ValidMVPs is a fast-execution technical partner for founders. we transform hand-drawn ideas and loose prototypes into scalable, investor-ready MVPs using production-grade architecture and AI integration."
      }
    </script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "ValidMVPs",
        "url": "https://validmvps.vercel.app",
        "potentialAction": {
          "@type": "SearchAction",
          "target": "https://validmvps.vercel.app/search?q={search_term_string}",
          "query-input": "required name=search_term_string"
        }
      }
    </script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "https://validmvps.vercel.app/"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "Blog",
            "item": "https://validmvps.vercel.app/blog/"
          }
        ]
      }
    </script>
    <meta name="google-site-verification" content="lP5cYOD4ohFYk02IhvRJ3cmApwBnBSxSJBf1Ag6Egg4" />
    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-to-content">Skip to content</a>
    <ClickSpark
      client:load
      sparkColor="#D1FC71"
      sparkSize={15}
      sparkRadius={20}
      sparkCount={10}
      duration={500}
    >
      <slot />
    </ClickSpark>

    <script>
      import Lenis from "lenis";

      // Initialize Lenis with optimized settings
      const lenis = new Lenis({
        duration: 1.0, // Snappier duration
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        lerp: 0.12, // More responsive lerp
        wheelMultiplier: 1.0,
        smoothWheel: true,
      });

      function raf(time: number) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }

      requestAnimationFrame(raf);

      /* Optimized IntersectionObserver for Scroll Reveal */
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            revealObserver.unobserve(entry.target);
          }
        });
      }, {
        root: null,
        rootMargin: "0px 0px -5% 0px",
        threshold: 0.05,
      });

      /* IntersectionObserver for Premium Button Initialization (Lazy Init) */
      const buttonObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            initSingleButton(el);
            buttonObserver.unobserve(el);
          }
        });
      }, {
        root: null,
        rootMargin: "100px", // Init slightly before they enter the viewport
      });

      const initSingleButton = (el: HTMLElement) => {
        if (el.classList.contains("premium-init-done")) return;
        
        // Re-apply the base class if missing
        if (!el.classList.contains("btn-premium-morph")) {
          el.classList.add("btn-premium-morph");
        }
        
        // Robust color detection (only if not already specified)
        if (!el.classList.contains("btn-green-bg")) {
          const style = window.getComputedStyle(el);
          const bgColor = style.backgroundColor;
          if (
            bgColor &&
            (bgColor.includes("209, 252, 113") ||
              bgColor.includes("rgb(209, 252, 113)") ||
              el.classList.contains('bg-[#D1FC71]'))
          ) {
            el.classList.add("btn-green-bg");
          }
        }

        // WRAP RAW TEXT NODES - Only if needed
        const nodes = Array.from(el.childNodes);
        const hasUnwrappedText = nodes.some(node => 
          node.nodeType === Node.TEXT_NODE && node.textContent?.trim()
        );

        if (hasUnwrappedText) {
          const span = document.createElement("span");
          span.style.cssText = "z-index: 10; position: relative; pointer-events: none;";
          while (el.firstChild) {
            span.appendChild(el.firstChild);
          }
          el.appendChild(span);
        }
        
        el.classList.add("premium-init-done");
      };

      const initUI = () => {
        // Scroll Reveal
        document.querySelectorAll(".reveal-on-scroll:not(.is-visible)").forEach((el) => {
          revealObserver.observe(el);
        });

        // Lazy Button Init
        const buttonSelectors = '.btn-premium-morph, .btn-primary, button:not(.no-morph), a.hover-lift';
        document.querySelectorAll(buttonSelectors).forEach((el) => {
          buttonObserver.observe(el);
        });
      };

      // Initial run
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initUI);
      } else {
        initUI();
      }

      // Re-run after page transitions
      document.addEventListener("astro:after-swap", initUI);
    </script>
    <Analytics />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
