---
import "../styles/global.css";
import ClickSpark from "../components/ClickSpark.jsx";
import Analytics from "@vercel/analytics/astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const {
  title = "ValidMVPs - Fast-Execution Development for Founders",
  description = "Turn your ideas into functional, investor-ready products in record time. We build scalable MVPs with MERN stack, AI integration, and production-ready architecture.",
  ogImage = "/images/og-image.png", // Default OG image
  canonicalUrl = Astro.url.href,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="MVP development agency, startup technical partner, fast software execution, Replit to production, MERN stack developers, AI startup MVP, functional prototype to product, scalable MVP architecture"
    />
    <meta name="author" content="ValidMVPs" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph / Facebook -->
    <meta property="og:site_name" content="ValidMVPs" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.url)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(ogImage, Astro.url)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Jost:ital,wght@0,100..900;1,100..900&family=Gilda+Display&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "ValidMVPs",
        "alternateName": "Valid MVPs",
        "url": "https://validmvps.com",
        "logo": "https://validmvps.com/images/LOGO.png",
        "sameAs": [
          "https://www.linkedin.com/company/validmvps",
          "https://www.instagram.com/validmvps",
          "https://x.com/validmvps"
        ],
        "contactPoint": {
          "@type": "ContactPoint",
          "telephone": "+92-321-9473647",
          "contactType": "Technical Support",
          "availableLanguage": ["English"]
        },
        "description": "ValidMVPs is a fast-execution technical partner for founders. we transform hand-drawn ideas and loose prototypes into scalable, investor-ready MVPs using production-grade architecture and AI integration."
      }
    </script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "ValidMVPs",
        "url": "https://validmvps.com",
        "potentialAction": {
          "@type": "SearchAction",
          "target": "https://validmvps.com/search?q={search_term_string}",
          "query-input": "required name=search_term_string"
        }
      }
    </script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "https://validmvps.com/"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "Blog",
            "item": "https://validmvps.com/blog"
          }
        ]
      }
    </script>
    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-to-content">Skip to content</a>
    <ClickSpark
      client:load
      sparkColor="#D1FC71"
      sparkSize={15}
      sparkRadius={20}
      sparkCount={10}
      duration={500}
    >
      <slot />
    </ClickSpark>

    <script>
      import Lenis from "lenis";

      // Initialize Lenis with optimized settings
      const lenis = new Lenis({
        duration: 1.2,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        lerp: 0.1, // Increased lerp slightly for responsiveness
        wheelMultiplier: 1.1,
        smoothWheel: true,
      });

      function raf(time: number) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }

      requestAnimationFrame(raf);

      /* Optimized IntersectionObserver */
      const observerOptions = {
        root: null,
        rootMargin: "0px 0px -10% 0px", // Use percentage for better responsiveness
        threshold: 0.05, // Lower threshold for faster trigger
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        });
      }, observerOptions);

      const initScrollReveal = () => {
        document.querySelectorAll(".reveal-on-scroll:not(.is-visible)").forEach((el) => {
          observer.observe(el);
        });
      };

      /* Optimized Premium Button Animation Initialization */
      const initPremiumButtons = () => {
        const elements = document.querySelectorAll('.btn-premium-morph, .btn-primary, button:not(.no-morph), a.hover-lift');
        
        if (elements.length === 0) return;

        const task = () => {
          elements.forEach((el) => {
            if (el.classList.contains("premium-init-done")) return;
            
            // Re-apply the base class if missing
            if (!el.classList.contains("btn-premium-morph")) {
              el.classList.add("btn-premium-morph");
            }
            
            // Robust color detection
            const style = window.getComputedStyle(el);
            const bgColor = style.backgroundColor;
            
            if (
              bgColor &&
              (bgColor.includes("209, 252, 113") ||
                bgColor.includes("rgb(209, 252, 113)") ||
                el.classList.contains('bg-[#D1FC71]'))
            ) {
              el.classList.add("btn-green-bg");
            }

            // WRAP RAW TEXT NODES
            const nodes = Array.from(el.childNodes);
            const hasUnwrappedText = nodes.some(node => 
              node.nodeType === Node.TEXT_NODE && node.textContent?.trim()
            );

            if (hasUnwrappedText) {
              const span = document.createElement("span");
              span.style.cssText = "z-index: 10; position: relative; pointer-events: none;";
              
              while (el.firstChild) {
                span.appendChild(el.firstChild);
              }
              el.appendChild(span);
            }
            
            el.classList.add("premium-init-done");
          });
        };

        if ('requestIdleCallback' in window) {
          window.requestIdleCallback(task, { timeout: 2000 });
        } else {
          setTimeout(task, 100); // Small delay to avoid blocking initial paint
        }
      };

      // Initial run
      initScrollReveal();
      initPremiumButtons();

      // Re-run after page transitions
      document.addEventListener("astro:after-swap", () => {
        initScrollReveal();
        initPremiumButtons();
      });
    </script>
    <Analytics />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
