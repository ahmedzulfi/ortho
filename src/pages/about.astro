---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import AboutHero from '../components/AboutHero.astro';
import AboutBrief from '../components/AboutBrief.astro';
import AboutTestimonials from '../components/AboutTestimonials.astro';
import AboutCulture from '../components/AboutCulture.astro';
import AboutVideoScroll from '../components/AboutVideoScroll.astro';
import Footer from '../components/Footer.astro';
import Team from '../components/Team.astro';
import Process from '../components/Process.astro';
---

<Layout 
	title="About Our Aligner Manufacturing & Planning | Orthodontics Align" 
	description="Learn about Orthodontics Align's expertise in high-precision dental aligner manufacturing and 3D treatment planning for global dental practices."
>
	<script type="application/ld+json" slot="head">
		{
			"@context": "https://schema.org",
			"@type": "AboutPage",
			"name": "About Orthodontics Align",
			"description": "Learn about Orthodontics Align's mission, our 10,000+ completed cases, and our team of expert dental professionals providing rapid clear aligner manufacturing and 3D treatment planning.",
			"url": "https://orthodonticsalign.com/about"
		}
	</script>
	<main class="min-h-screen bg-[#F6F7FF]">
		<Navbar />
		
		<div id="main-content" class="sr-only">Main Content Starts Here</div>
		
		<AboutHero />

		<AboutBrief />

		<AboutTestimonials />

		<AboutCulture />

		<AboutVideoScroll />

        <Process />

        <Team />
		
		<Footer />
	</main>
</Layout>
