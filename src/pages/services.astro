---
/**
 * Services Page
 * Detailed list of fast-execution development services.
 */
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import ServicesHero from '../components/ServicesHero.astro';
import ServicesSection from '../components/Services.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
	title="Our Services | ValidMVPs - Fast-Execution Development" 
	description="We focus on delivering complete MVPs that are usable products. From technical strategy to AI integration and scalable tech stacks."
>
	<script type="application/ld+json" slot="head">
		{
			"@context": "https://schema.org",
			"@type": "WebPage",
			"name": "Fast-Execution Development & MVP Construction",
			"description": "We focus on delivering complete MVPs that are usable products. From technical strategy to AI integration and scalable tech stacks.",
			"url": "https://validmvps.vercel.app/services"
		}
	</script>
	<main class="min-h-screen bg-[#F6F7FF]">
		<Navbar />
		
		<div id="main-content" class="sr-only">Main Content Starts Here</div>
		
		<ServicesHero />

		<ServicesSection />

		<FAQ />

		<Footer />
	</main>
</Layout>

<style is:global>
  /* Page specific transitions or overrides if needed */
</style>
