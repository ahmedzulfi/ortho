---

<Layout title="AI App Development Services | ValidMVPs">
  <main class="min-h-screen">
    <Navbar />
    <div id="main-content" class="sr-only">Main Content Starts Here</div>
    
    <Hero {...heroProps} />
    <About {...aboutProps} />
    <Services {...servicesProps} />
    <Process {...processProps} />
    
    <Team />
    <Gallery />
    <Testimonials />
    <FAQ />
    <Contact />
    <Footer />
  </main>
</Layout>
