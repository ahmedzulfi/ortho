---
import Layout from '../../layouts/Layout.astro';
import AdminSidebar from '../../components/admin/AdminSidebar.astro';
import StatusBadge from '../../components/admin/StatusBadge.astro';
import { connectToDatabase } from '../../lib/mongodb';
import { Appointment } from '../../models/Appointment';
import { autoClosePastAppointments } from '../../lib/appointments';
import { Check, X, Eye, FileText, Search } from 'lucide-astro';

export const prerender = false;

await connectToDatabase();
await autoClosePastAppointments();

// Fetch all appointments (latest first)
const appointments = await Appointment.find().sort({ createdAt: -1 });

// Safely serialize appointments for client-side JS
const serializedAppointments = appointments.map(app => ({
  _id: app._id.toString(),
  name: app.name,
  phone: app.phone,
  email: app.email || '',
  service: app.service,
  preferredDate: app.preferredDate ? app.preferredDate.toISOString() : null,
  preferredTime: app.preferredTime || '',
  message: app.message || '',
  status: app.status,
  notes: app.notes || ''
}));
---
<Layout title="Appointments | Admin">
  <div class="flex min-h-screen bg-[#F8FAF9]">
    <AdminSidebar currentPath="/admin/appointments" />
    
    <main class="flex-1 p-8 overflow-auto font-['Inter'] relative">
      <header class="mb-8 flex justify-between items-center">
        <div>
          <h1 class="text-2xl font-bold text-[#0D1B15] tracking-tight">Manage Appointments</h1>
          <p class="text-[#595E5C] text-sm mt-1">Review patient requests, accept or decline bookings, and add clinical notes.</p>
        </div>
      </header>

      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <!-- Search bar header -->
        <div class="p-4 border-b border-gray-100 flex items-center justify-between bg-gray-50/30">
          <div class="relative w-64">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
              <Search class="w-4 h-4 text-gray-400" />
            </span>
            <input 
              type="text" 
              id="search-input"
              placeholder="Search by name, phone, email..." 
              class="pl-9 pr-4 py-2 border border-gray-200 rounded-xl text-sm w-full focus:outline-none focus:border-[#D1FC71] focus:ring-1 focus:ring-[#D1FC71]"
            />
          </div>
        </div>

        <div class="overflow-x-auto min-h-[500px]">
          <table class="w-full text-left border-collapse" id="appointments-table">
            <thead>
              <tr class="bg-gray-50/30 text-[#595E5C] text-xs uppercase tracking-wider border-b border-gray-100">
                <th class="p-4 font-semibold">Patient & Contact</th>
                <th class="p-4 font-semibold">Requested Service</th>
                <th class="p-4 font-semibold">Date & Time</th>
                <th class="p-4 font-semibold">Status</th>
                <th class="p-4 font-semibold text-right">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 text-sm">
              {appointments.length === 0 ? (
                <tr>
                  <td colspan="5" class="p-8 text-center text-gray-400 font-medium">No appointments found in database.</td>
                </tr>
              ) : (
                appointments.map((app) => (
                  <tr class="hover:bg-gray-50/30 transition-colors app-row" data-name={app.name.toLowerCase()} data-phone={app.phone} data-email={app.email?.toLowerCase() || ''}>
                    <td class="p-4">
                      <div class="font-bold text-[#0D1B15]">{app.name}</div>
                      <div class="text-[#595E5C] text-xs mt-0.5">{app.phone} {app.email ? `• ${app.email}` : ''}</div>
                    </td>
                    <td class="p-4 text-[#595E5C] font-medium max-w-[220px] truncate" title={app.service}>{app.service}</td>
                    <td class="p-4 text-[#595E5C]">
                      <div>{app.preferredDate ? new Date(app.preferredDate).toLocaleDateString() : 'N/A'}</div>
                      <span class="text-xs text-gray-400">{app.preferredTime || ''}</span>
                    </td>
                    <td class="p-4" id={`status-cell-${app._id}`}>
                      <StatusBadge status={app.status as any} />
                    </td>
                    <td class="p-4 text-right">
                      <div class="inline-flex gap-1.5 justify-end items-center">
                        {app.status === 'pending' && (
                          <>
                            <button 
                              class="inline-flex items-center justify-center p-1.5 bg-emerald-50 hover:bg-emerald-100 border border-emerald-200 text-emerald-700 rounded-lg transition-colors inline-accept-btn"
                              data-id={app._id.toString()}
                              title="Accept Appointment"
                            >
                              <Check class="w-4 h-4" />
                            </button>
                            <button 
                              class="inline-flex items-center justify-center p-1.5 bg-rose-50 hover:bg-rose-100 border border-rose-200 text-rose-700 rounded-lg transition-colors inline-decline-btn"
                              data-id={app._id.toString()}
                              title="Decline Appointment"
                            >
                              <X class="w-4 h-4" />
                            </button>
                          </>
                        )}
                        <button 
                          class="px-2.5 py-1.5 bg-gray-50 hover:bg-gray-100 border border-gray-200 text-gray-700 text-xs font-semibold rounded-lg transition-all view-details-btn"
                          data-id={app._id.toString()}
                          title="View Details"
                        >
                          Details
                        </button>
                      </div>
                    </td>
                  </tr>
                ))
              )}
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>

  <!-- Global Appointment Detail Modal (Reused) -->
  <div id="appointment-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-[#0D1B15]/40 backdrop-blur-sm opacity-0 pointer-events-none transition-all duration-200">
    <div class="bg-white w-full max-w-lg rounded-2xl shadow-xl border border-gray-100 overflow-hidden transform scale-95 transition-transform duration-200">
      <!-- Modal Header -->
      <div class="p-6 border-b border-gray-100 flex justify-between items-center bg-gray-50/50">
        <h3 class="text-lg font-bold text-[#0D1B15]" id="modal-title">Appointment Details</h3>
        <button id="modal-close-btn" class="p-1 text-gray-400 hover:text-gray-600 rounded-lg hover:bg-gray-100 transition-colors">
          <X class="w-5 h-5" />
        </button>
      </div>

      <!-- Modal Body -->
      <div class="p-6 space-y-4 max-h-[70vh] overflow-y-auto">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="text-[11px] font-bold text-gray-400 uppercase tracking-wider">Patient Name</label>
            <p class="text-sm font-semibold text-[#0D1B15] mt-0.5" id="modal-name">Sarah Connor</p>
          </div>
          <div>
            <label class="text-[11px] font-bold text-gray-400 uppercase tracking-wider">Contact Phone</label>
            <p class="text-sm font-semibold text-[#0D1B15] mt-0.5" id="modal-phone">+1 (555) 019-9281</p>
          </div>
          <div class="col-span-2">
            <label class="text-[11px] font-bold text-gray-400 uppercase tracking-wider">Email Address</label>
            <p class="text-sm font-semibold text-[#0D1B15] mt-0.5" id="modal-email">sarah.connor@example.com</p>
          </div>
          <div>
            <label class="text-[11px] font-bold text-gray-400 uppercase tracking-wider">Requested Service</label>
            <p class="text-sm font-semibold text-[#0D1B15] mt-0.5" id="modal-service">Aligners Treatment Planning</p>
          </div>
          <div>
            <label class="text-[11px] font-bold text-gray-400 uppercase tracking-wider">Date & Time</label>
            <p class="text-sm font-semibold text-[#0D1B15] mt-0.5" id="modal-datetime">June 25, 2026 at 10:00 AM</p>
          </div>
        </div>

        <div>
          <label class="text-[11px] font-bold text-gray-400 uppercase tracking-wider">Patient Message</label>
          <div class="text-sm text-gray-600 bg-gray-50 border border-gray-100 rounded-xl p-3 mt-1 min-h-[60px]" id="modal-message">
            Patient submitted request messages will appear here.
          </div>
        </div>

        <div class="border-t border-gray-100 pt-4">
          <label class="text-xs font-bold text-[#0D1B15] block mb-1">Clinical Notes & Email Message</label>
          <p class="text-xs text-gray-400 mb-2">These notes are saved and will be emailed to the patient upon review.</p>
          <textarea 
            id="modal-notes" 
            rows="3" 
            placeholder="E.g., Please remember to bring your 3D scan files. The clinic will open 10 mins prior."
            class="w-full text-sm px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:border-[#D1FC71] focus:ring-1 focus:ring-[#D1FC71] resize-none"
          ></textarea>
        </div>

        <div class="flex items-center gap-2 pt-2" id="modal-status-container">
          <span class="text-xs font-semibold text-gray-500">Current Status:</span>
          <div id="modal-status-badge">
            <span class="px-2 py-0.5 text-xs font-semibold rounded-full bg-yellow-100 text-yellow-800">Pending Review</span>
          </div>
        </div>
      </div>

      <!-- Modal Footer -->
      <div class="p-6 border-t border-gray-100 bg-gray-50/50 flex gap-3 justify-end">
        <button 
          id="decline-action-btn"
          class="flex items-center justify-center gap-2 px-4 py-2 border border-rose-200 bg-rose-50 hover:bg-rose-100 text-rose-700 text-sm font-semibold rounded-xl transition-all"
        >
          <X class="w-4 h-4" />
          Decline Request
        </button>
        <button 
          id="accept-action-btn"
          class="flex items-center justify-center gap-2 px-4 py-2 bg-[#D1FC71] hover:bg-[#c0ec60] text-[#0D1B15] text-sm font-bold rounded-xl transition-all shadow-sm"
        >
          <Check class="w-4 h-4 text-[#0D1B15]" />
          Accept & Confirm
        </button>
      </div>
    </div>
  </div>

  <!-- Serialized JSON for JavaScript search and modals -->
  <div id="appointments-data" data-json={JSON.stringify(serializedAppointments)} class="hidden"></div>
</Layout>

<script>
  // Extract and parse appointments list
  const dataEl = document.getElementById('appointments-data');
  const appointmentsList = JSON.parse(dataEl?.getAttribute('data-json') || '[]');

  // Search filtering
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const rows = document.querySelectorAll('.app-row');

  searchInput?.addEventListener('input', (e) => {
    const term = (e.target as HTMLInputElement).value.toLowerCase();
    rows.forEach(row => {
      const name = row.getAttribute('data-name') || '';
      const phone = row.getAttribute('data-phone') || '';
      const email = row.getAttribute('data-email') || '';
      if (name.includes(term) || phone.includes(term) || email.includes(term)) {
        (row as HTMLElement).style.display = '';
      } else {
        (row as HTMLElement).style.display = 'none';
      }
    });
  });

  // Modal elements
  const modalEl = document.getElementById('appointment-modal');
  const modalCloseBtn = document.getElementById('modal-close-btn');
  const modalName = document.getElementById('modal-name');
  const modalPhone = document.getElementById('modal-phone');
  const modalEmail = document.getElementById('modal-email');
  const modalService = document.getElementById('modal-service');
  const modalDateTime = document.getElementById('modal-datetime');
  const modalMessage = document.getElementById('modal-message');
  const modalNotes = document.getElementById('modal-notes') as HTMLTextAreaElement;
  const modalStatusBadge = document.getElementById('modal-status-badge');
  const acceptActionBtn = document.getElementById('accept-action-btn') as HTMLButtonElement;
  const declineActionBtn = document.getElementById('decline-action-btn') as HTMLButtonElement;

  let activeModalAppId = '';

  function openModal(id: string) {
    const app = appointmentsList.find((a: any) => a._id === id);
    if (!app || !modalEl) return;

    activeModalAppId = id;

    if (modalName) modalName.textContent = app.name;
    if (modalPhone) modalPhone.textContent = app.phone;
    if (modalEmail) {
      modalEmail.textContent = app.email || 'N/A';
      modalEmail.parentElement!.style.display = app.email ? 'block' : 'none';
    }
    if (modalService) modalService.textContent = app.service;
    if (modalDateTime) {
      const dateText = app.preferredDate ? new Date(app.preferredDate).toLocaleDateString() : 'N/A';
      modalDateTime.textContent = `${dateText} at ${app.preferredTime || 'N/A'}`;
    }
    if (modalMessage) {
      modalMessage.textContent = app.message || 'No additional message submitted.';
    }
    if (modalNotes) {
      modalNotes.value = app.notes || '';
    }

    if (modalStatusBadge) {
      const labels: Record<string, string> = {
        pending: 'Pending Review',
        confirmed: 'Accepted',
        completed: 'Completed',
        cancelled: 'Declined'
      };
      const styles: Record<string, string> = {
        pending: 'bg-amber-50 text-amber-700 border border-amber-200/50',
        confirmed: 'bg-emerald-50 text-emerald-700 border border-emerald-200/50',
        completed: 'bg-gray-100 text-gray-700 border border-gray-200/50',
        cancelled: 'bg-rose-50 text-rose-700 border border-rose-200/50'
      };
      
      modalStatusBadge.innerHTML = `
        <span class="px-2.5 py-0.5 text-xs font-semibold rounded-full ${styles[app.status]}">
          ${labels[app.status]}
        </span>
      `;
    }

    // Modal Actions Visibility
    if (app.status === 'completed') {
      acceptActionBtn.style.display = 'none';
      declineActionBtn.style.display = 'none';
    } else {
      acceptActionBtn.style.display = '';
      declineActionBtn.style.display = '';
      
      if (app.status === 'confirmed') {
        acceptActionBtn.innerHTML = `
          <svg class="w-4 h-4 text-[#0D1B15]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-dasharray="none" d="M5 13l4 4L19 7"></path></svg>
          Update Notes
        `;
        declineActionBtn.style.display = ''; 
      } else if (app.status === 'cancelled') {
        declineActionBtn.style.display = 'none'; 
        acceptActionBtn.innerHTML = `
          <svg class="w-4 h-4 text-[#0D1B15]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-dasharray="none" d="M5 13l4 4L19 7"></path></svg>
          Accept Request
        `;
      } else {
        acceptActionBtn.innerHTML = `
          <svg class="w-4 h-4 text-[#0D1B15]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-dasharray="none" d="M5 13l4 4L19 7"></path></svg>
          Accept Request
        `;
        declineActionBtn.style.display = '';
      }
    }

    modalEl.classList.remove('opacity-0', 'pointer-events-none');
    modalEl.firstElementChild?.classList.remove('scale-95');
    modalEl.firstElementChild?.classList.add('scale-100');
  }

  function closeModal() {
    if (!modalEl) return;
    modalEl.classList.add('opacity-0', 'pointer-events-none');
    modalEl.firstElementChild?.classList.remove('scale-100');
    modalEl.firstElementChild?.classList.add('scale-95');
    activeModalAppId = '';
  }

  modalCloseBtn?.addEventListener('click', closeModal);
  modalEl?.addEventListener('click', (e) => {
    if (e.target === modalEl) closeModal();
  });

  // Attach event listener to detail buttons
  document.querySelectorAll('.view-details-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const id = (e.currentTarget as HTMLButtonElement).getAttribute('data-id');
      if (id) openModal(id);
    });
  });

  // Action: Accept Appointment
  acceptActionBtn?.addEventListener('click', async () => {
    if (!activeModalAppId) return;

    acceptActionBtn.disabled = true;
    const notesValue = modalNotes ? modalNotes.value : '';

    try {
      const res = await fetch(`/api/appointments/${activeModalAppId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status: 'confirmed', notes: notesValue })
      });
      if (res.ok) {
        closeModal();
        window.location.reload();
      } else {
        alert('Failed to accept appointment request.');
      }
    } catch(err) {
      console.error(err);
      alert('Error updating status.');
    } finally {
      acceptActionBtn.disabled = false;
    }
  });

  // Action: Decline Appointment
  declineActionBtn?.addEventListener('click', async () => {
    if (!activeModalAppId) return;
    if (!confirm('Are you sure you want to decline this appointment request?')) return;

    declineActionBtn.disabled = true;
    const notesValue = modalNotes ? modalNotes.value : '';

    try {
      const res = await fetch(`/api/appointments/${activeModalAppId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status: 'cancelled', notes: notesValue })
      });
      if (res.ok) {
        closeModal();
        window.location.reload();
      } else {
        alert('Failed to decline appointment request.');
      }
    } catch(err) {
      console.error(err);
      alert('Error updating status.');
    } finally {
      declineActionBtn.disabled = false;
    }
  });

  // Inline Quick Actions: Accept Button
  document.querySelectorAll('.inline-accept-btn').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      e.stopPropagation();
      const target = e.currentTarget as HTMLButtonElement;
      const id = target.getAttribute('data-id');
      if (!id) return;
      
      target.disabled = true;
      try {
        const res = await fetch(`/api/appointments/${id}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status: 'confirmed' })
        });
        if (res.ok) {
          window.location.reload();
        } else {
          alert('Failed to accept request.');
        }
      } catch (err) {
        console.error(err);
        alert('Error performing action.');
      } finally {
        target.disabled = false;
      }
    });
  });

  // Inline Quick Actions: Decline Button
  document.querySelectorAll('.inline-decline-btn').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      e.stopPropagation();
      const target = e.currentTarget as HTMLButtonElement;
      const id = target.getAttribute('data-id');
      if (!id) return;
      
      if (!confirm('Are you sure you want to decline this request?')) return;
      
      target.disabled = true;
      try {
        const res = await fetch(`/api/appointments/${id}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status: 'cancelled' })
        });
        if (res.ok) {
          window.location.reload();
        } else {
          alert('Failed to decline request.');
        }
      } catch (err) {
        console.error(err);
        alert('Error performing action.');
      } finally {
        target.disabled = false;
      }
    });
  });
</script>