---
import ServiceDetailTemplate from "../../components/ServiceDetailTemplate.astro";

const details = [
  "Our 3D Treatment Planning service is the cornerstone of successful clear aligner therapy. We utilize state-of-the-art software systems, including 3Shape and OnyxCeph, to simulate tooth movement with mathematical precision.",
  "Every plan is reviewed by our clinical experts who understand the biological limitations of orthodontic movement. We don't just move teeth on a screen; we ensure that every movement is safe, predictable, and achievable.",
  "With a 24-hour turnaround time for STL files, we help you reduce the wait time for your patients and start treatments faster than ever before."
];

const benefits = [
  "Clinically Validated Movement",
  "24-Hour STL File Delivery",
  "Expert Clinical Oversight",
  "Safe Root Control Simulation"
];

const specs = [
  { label: "Software", value: "3Shape, OnyxCeph, Archform" },
  { label: "Delivery Format", value: "STL, High-Res Digital Setup" },
  { label: "Turnaround", value: "Typically < 24 Hours" },
  { label: "Support", value: "Clinical Email Support included" }
];
---

<ServiceDetailTemplate 
  title="3D Treatment Planning"
  description="Expert 3D simulations that bridge the gap between digital precision and clinical reality."
  heroImage="https://framerusercontent.com/images/DjC5pMWJdlfxcNqmLKEPK4bycJk.jpg"
  details={details}
  benefits={benefits}
  specs={specs}
/>
