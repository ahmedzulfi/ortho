---
import ServiceDetailTemplate from "../../components/ServiceDetailTemplate.astro";

const details = [
  "Not every case is straightforward. For complex sequential distalization, skeletal abnormalities, and severe crowding, we offer targeted consultation services.",
  "Our experts analyze your digital models and provide a detailed strategic overview, explaining how to stage movements and where to position specific attachments for optimal torque.",
  "This clinical partnership ensures that you can take on even high-difficulty cases with confidence, knowing you have an expert clinical team behind you."
];

const benefits = [
  "Expert Clinical Supervision",
  "Tailored Biomechanics Strategy",
  "Move-by-Move Staging Analysis",
  "High-Difficulty Case Support"
];

const specs = [
  { label: "Clinical Team", value: "Post-Graduate Orthodontists" },
  { label: "Review Type", value: "3D-Video Consultation" },
  { label: "Case Level", value: "IGS 7-10 (Complex)" },
  { label: "Direct Support", value: "Zoom/Email Included" }
];
---

<ServiceDetailTemplate 
  title="Complex Case Consultation"
  description="Clinical expertise that scales with your most challenging cases."
  heroImage="https://framerusercontent.com/images/3fKqpTuR1TuGSP6iX2BAfRvmD4g.png?scale-down-to=512&width=1280&height=1180"
  details={details}
  benefits={benefits}
  specs={specs}
/>
