---
import ServiceDetailTemplate from "../../components/ServiceDetailTemplate.astro";

const details = [
  "Our Precision Fabrication center uses vacuum thermoforming to transform 3D models into incredibly durable, crystal-clear aligners. We exclusively use medical-grade materials like Zendura FLX.",
  "Every aligner undergoes laser edge trimming and ultrasonic cleaning, ensuring a smooth, comfortable surface that won't irritate the patient's soft tissues.",
  "By partnering with us for fabrication, you leverage industrial-scale quality control at a fraction of the cost of setting up an in-house lab."
];

const benefits = [
  "Zendura FLX Premium Material",
  "Laser Barcoded Identification",
  "High Crack Resistance",
  "High-Fidelity Transparency"
];

const specs = [
  { label: "Material", value: "Zendura FLX (Multilayer)" },
  { label: "Trimming", value: "Robotically Laser Trimmed" },
  { label: "Sterilization", value: "Ultrasonic Scaled" },
  { label: "Batch Size", value: "Single-Case to Mid-Batch" }
];
---

<ServiceDetailTemplate 
  title="Precision Fabrication"
  description="Manufacturing the ultimate in clear aligner clarity and comfort."
  heroImage="https://framerusercontent.com/images/pRfDLqmzu07eDPWmYEYmVlmqaXY.png?width=3472&height=3200"
  details={details}
  benefits={benefits}
  specs={specs}
/>
