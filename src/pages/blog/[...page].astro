---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import BlogHero from '../../components/BlogHero.astro';
import BlogGrid from '../../components/BlogGrid.astro';
import Contact from '../../components/Contact.astro';
import FAQ from '../../components/FAQ.astro';
import Footer from '../../components/Footer.astro';
import { posts as allPosts } from '../../data/posts';

export async function getStaticPaths({ paginate }) {
  // Sort posts by date descending
  const sortedPosts = allPosts.sort((a, b) => 
    new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
  );

  return paginate(sortedPosts, { pageSize: 6 });
}

const { page } = Astro.props;
---

<Layout 
  title={page.currentPage === 1 ? "Expert Startup Insights & MVP Development Blog | ValidMVPs" : `Blog - Page ${page.currentPage} | ValidMVPs`}
  description="Explore expert insights on startup execution, MVP development, AI integration, and production-ready architecture for founders."
  ogType="website"
>
	<main class="min-h-screen bg-[#F6F7FF]">
		<Navbar />
		
    <div id="main-content" class="sr-only">Main Content Starts Here</div>

		<BlogHero />

    <BlogGrid posts={page.data} page={page} />
    
    <Contact />
    <FAQ />

		<Footer />
	</main>
</Layout>
