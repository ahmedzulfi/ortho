---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import BlogDetailsHero from '../../components/BlogDetailsHero.astro';
import BlogProse from '../../components/BlogProse.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import Contact from '../../components/Contact.astro';
import FAQ from '../../components/FAQ.astro';
import Footer from '../../components/Footer.astro';

const post = {
  id: "benefits-of-early-orthodontic-evaluation",
  data: {
    title: "The Benefits of Early Orthodontic Evaluation",
    excerpt: "Why the American Association of Orthodontists recommends your child's first check-up by age 7.",
    publishDate: "2026-04-11",
    image: "https://framerusercontent.com/images/lhHhUnyKhPclLkxHyj2BcF6Ek.png",
    author: {
      name: "Mohammad Imran",
      image: "https://framerusercontent.com/images/et3GxfYry1OVFWCEFEwd2cMhjI.jpg"
    }
  }
};
---

<Layout title={`${post.data.title} | Orthodontics Align`} description={post.data.excerpt}>
  <div class="flex flex-col min-h-screen bg-[#F6F7FF]">
    <Navbar />

    <BlogDetailsHero 
      title={post.data.title}
      excerpt={post.data.excerpt}
      authorName={post.data.author.name}
      authorImage={post.data.author.image}
      publishDate={new Date(post.data.publishDate).toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric'
      })}
      featuredImage={post.data.image}
    />

    <BlogProse>
      <div class="flex flex-col items-center gap-20 w-full mx-auto text-[#0D1B15]">
        
        <div class="w-full">
          <p class="text-[22px] leading-[1.6em] mb-8 font-inter">
            Many parents assume that orthodontic checkups should wait until all baby teeth have fallen out. However, the American Association of Orthodontists strongly advises that pediatric evaluations should begin as early as age 7.
          </p>
          
          <h2 style="font-family: 'Bricolage Grotesque'; font-weight: 500; font-size: 48px; letter-spacing: -3px; line-height: 120%; margin-bottom: 16px; margin-top: 32px;">Spotting Problems Before They Mature</h2>
          <p class="text-[22px] leading-[1.6em] font-inter">
            By age 7, a child's jaw is still growing, and enough permanent teeth have erupted for an orthodontist to identify potential issues with jaw growth and emerging teeth, long before they become complex problems.
          </p>
        </div>

        <!-- Two Column Images Row -->
        <div 
          class="framer-1hkazoj"
          style="box-sizing: border-box; -webkit-font-smoothing: inherit; place-content: center; flex: 0 0 auto; flex-flow: row; gap: 24px; overflow: visible; padding: 0px; align-items: center; display: flex; height: min-content; position: relative; width: 100%;"
        >
          <figure
            class="framer-1lk8qrc"
            style="box-sizing: border-box; -webkit-font-smoothing: inherit; margin: 0px; border-radius: 20px; flex: 1 0 0px; overflow: clip; aspect-ratio: 0.97 / 1; position: relative; width: 1px; will-change: transform; opacity: 1; transform: none;"
          >
            <div style="box-sizing: border-box; -webkit-font-smoothing: inherit; border-radius: inherit; inset: 0px; position: absolute;">
              <img
                src="https://framerusercontent.com/images/zcgnQBMu4749dwi5AO2wK2UeJDk.png?width=1512&height=1600"
                alt="Modern Dental Clinic"
                style="box-sizing: border-box; -webkit-font-smoothing: inherit; border-radius: inherit; display: block; width: 100%; height: 100%; object-position: center center; object-fit: cover;"
              />
            </div>
          </figure>
          <figure
            class="framer-jatmll"
            style="box-sizing: border-box; -webkit-font-smoothing: inherit; margin: 0px; border-radius: 20px; flex: 1 0 0px; overflow: clip; aspect-ratio: 0.97 / 1; position: relative; width: 1px; will-change: transform; opacity: 1; transform: none;"
          >
            <div style="box-sizing: border-box; -webkit-font-smoothing: inherit; border-radius: inherit; inset: 0px; position: absolute;">
              <img
                src="https://framerusercontent.com/images/I0J7U9HzrLJBJ6C4GYCsAJ98vA.png?width=1512&height=1600"
                alt="Friendly Dental Professional"
                style="box-sizing: border-box; -webkit-font-smoothing: inherit; border-radius: inherit; display: block; width: 100%; height: 100%; object-position: center center; object-fit: cover;"
              />
            </div>
          </figure>
        </div>

        <div class="w-full">
          <h2 style="font-family: 'Bricolage Grotesque'; font-weight: 500; font-size: 48px; letter-spacing: -3px; line-height: 120%; margin-bottom: 16px; margin-top: 32px;">Phase One Interventions</h2>
          <p class="text-[22px] leading-[1.6em] font-inter">
            Sometimes, early intervention—often called Phase One treatment—can guide jaw development and create room for crowded, erupting teeth. This can significantly reduce the need for extractions or jaw surgery in the future.
          </p>

          <h2 style="font-family: 'Bricolage Grotesque'; font-weight: 500; font-size: 48px; letter-spacing: -3px; line-height: 120%; margin-bottom: 16px; margin-top: 48px;">Peace of Mind for Parents</h2>
          <p class="text-[22px] leading-[1.6em] font-inter">
             Even if immediate treatment isn't necessary, regular monitoring allows the orthodontist to determine the perfect time to begin treatment, giving parents peace of mind and planning time.
          </p>
        </div>

        <div class="w-full">
          <h2 style="font-family: 'Bricolage Grotesque'; font-weight: 500; font-size: 48px; letter-spacing: -3px; line-height: 120%; margin-bottom: 16px; margin-top: 48px;">Conclusion</h2>
          <p class="text-[22px] leading-[1.6em] font-inter mb-12">
            Don't wait until your child's teenage years to think about their bite. By scheduling an evaluation around age 7, you give them the best possible start toward a lifetime of healthy, beautiful smiles.
          </p>
        </div>

      </div>
    </BlogProse>

    <RelatedPosts currentSlug={post.id} />

    <Contact />
    <FAQ />
    <Footer />
  </div>
</Layout>
