---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import BlogDetailsHero from '../../components/BlogDetailsHero.astro';
import BlogProse from '../../components/BlogProse.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import Contact from '../../components/Contact.astro';
import FAQ from '../../components/FAQ.astro';
import Footer from '../../components/Footer.astro';

const post = {
  id: "10-tips-for-lifelong-oral-health",
  data: {
    title: "10 Simple Tips for Lifelong Oral Health",
    excerpt: "Maintain a powerful asset—your smile—with these 10 dentist-approved habits for long-term dental wellness.",
    publishDate: "2026-04-07",
    image: "https://framerusercontent.com/images/lhHhUnyKhPclLkxHyj2BcF6Ek.png",
    author: {
      name: "Dr. Ahmed Zulfi",
      image: "https://framerusercontent.com/images/et3GxfYry1OVFWCEFEwd2cMhjI.jpg"
    }
  }
};
---

<Layout title={`${post.data.title} | Orthodontics Align`} description={post.data.excerpt}>
  <div class="flex flex-col min-h-screen bg-[#F6F7FF]">
    <Navbar />

    <BlogDetailsHero 
      title={post.data.title}
      excerpt={post.data.excerpt}
      authorName={post.data.author.name}
      authorImage={post.data.author.image}
      publishDate={new Date(post.data.publishDate).toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric'
      })}
      featuredImage={post.data.image}
    />

    <BlogProse>
      <div class="flex flex-col items-center gap-20 w-full mx-auto text-[#0D1B15]">
        
        <div class="w-full">
          <p class="text-[22px] leading-[1.6em] mb-8 font-inter">
            Your smile is one of your most powerful assets. Whether you're greeting someone new or enjoying your favorite meal, strong and healthy teeth make all the difference. Here are the most effective dentist-approved habits for lifelong dental wellness.
          </p>
          
          <h2 style="font-family: 'Bricolage Grotesque'; font-weight: 500; font-size: 48px; letter-spacing: -3px; line-height: 120%; margin-bottom: 16px; margin-top: 32px;">The Foundation of Oral Health</h2>
          <p class="text-[22px] leading-[1.6em] font-inter">
            In our practice, we often see that the simplest habits yield the greatest results. Consistency and proper technique are the pillars of a healthy mouth, preventing common issues before they require complex treatments.
          </p>
        </div>

        <!-- Two Column Images Row -->
        <div 
          class="framer-1hkazoj"
          style="box-sizing: border-box; -webkit-font-smoothing: inherit; place-content: center; flex: 0 0 auto; flex-flow: row; gap: 24px; overflow: visible; padding: 0px; align-items: center; display: flex; height: min-content; position: relative; width: 100%;"
        >
          <figure
            class="framer-1lk8qrc"
            style="box-sizing: border-box; -webkit-font-smoothing: inherit; margin: 0px; border-radius: 20px; flex: 1 0 0px; overflow: clip; aspect-ratio: 0.97 / 1; position: relative; width: 1px; will-change: transform; opacity: 1; transform: none;"
          >
            <div style="box-sizing: border-box; -webkit-font-smoothing: inherit; border-radius: inherit; inset: 0px; position: absolute;">
              <img
                src="https://framerusercontent.com/images/zcgnQBMu4749dwi5AO2wK2UeJDk.png?width=1512&height=1600"
                alt="Modern Dental Clinic"
                style="box-sizing: border-box; -webkit-font-smoothing: inherit; border-radius: inherit; display: block; width: 100%; height: 100%; object-position: center center; object-fit: cover;"
              />
            </div>
          </figure>
          <figure
            class="framer-jatmll"
            style="box-sizing: border-box; -webkit-font-smoothing: inherit; margin: 0px; border-radius: 20px; flex: 1 0 0px; overflow: clip; aspect-ratio: 0.97 / 1; position: relative; width: 1px; will-change: transform; opacity: 1; transform: none;"
          >
            <div style="box-sizing: border-box; -webkit-font-smoothing: inherit; border-radius: inherit; inset: 0px; position: absolute;">
              <img
                src="https://framerusercontent.com/images/I0J7U9HzrLJBJ6C4GYCsAJ98vA.png?width=1512&height=1600"
                alt="Friendly Dental Professional"
                style="box-sizing: border-box; -webkit-font-smoothing: inherit; border-radius: inherit; display: block; width: 100%; height: 100%; object-position: center center; object-fit: cover;"
              />
            </div>
          </figure>
        </div>

        <div class="w-full">
          <h2 style="font-family: 'Bricolage Grotesque'; font-weight: 500; font-size: 48px; letter-spacing: -3px; line-height: 120%; margin-bottom: 16px; margin-top: 32px;">1. Brush Twice a Day But Do It Right</h2>
          <p class="text-[22px] leading-[1.6em] font-inter">
            Consistency is key. Use a soft-bristled brush and fluoride toothpaste. Spend a full two minutes reaching all surfaces, including the back of your mouth and your tongue.
          </p>

          <h2 style="font-family: 'Bricolage Grotesque'; font-weight: 500; font-size: 48px; letter-spacing: -3px; line-height: 120%; margin-bottom: 16px; margin-top: 48px;">2. Floss Daily</h2>
          <p class="text-[22px] leading-[1.6em] font-inter">
             Flossing removes plaque and food particles from between your teeth where your brush can’t reach. It’s a small step with big impact on preventing gum disease.
          </p>
        </div>

        <div class="w-full">
          <h2 style="font-family: 'Bricolage Grotesque'; font-weight: 500; font-size: 48px; letter-spacing: -3px; line-height: 120%; margin-bottom: 16px; margin-top: 48px;">Conclusion</h2>
          <p class="text-[22px] leading-[1.6em] font-inter mb-12">
            Maintaining your oral health is a lifelong journey, but it doesn't have to be complicated. By following these simple, daily habits, you're investing in a smile that will serve you well for decades. Consistency is key!
          </p>
        </div>

      </div>
    </BlogProse>

    <RelatedPosts currentSlug={post.id} />

    <Contact />
    <FAQ />
    <Footer />
  </div>
</Layout>
