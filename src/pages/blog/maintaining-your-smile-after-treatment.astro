---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import BlogDetailsHero from '../../components/BlogDetailsHero.astro';
import BlogProse from '../../components/BlogProse.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import Contact from '../../components/Contact.astro';
import FAQ from '../../components/FAQ.astro';
import Footer from '../../components/Footer.astro';

const post = {
  id: "maintaining-your-smile-after-treatment",
  data: {
    title: "Maintaining Your Smile After Treatment",
    excerpt: "Your treatment is complete! Here is how to keep your newly aligned teeth perfectly straight for the rest of your life.",
    publishDate: "2026-04-13",
    image: "https://framerusercontent.com/images/lhHhUnyKhPclLkxHyj2BcF6Ek.png",
    author: {
      name: "Mohammad Imran",
      image: "https://framerusercontent.com/images/et3GxfYry1OVFWCEFEwd2cMhjI.jpg"
    }
  }
};
---

<Layout title={`${post.data.title} | Orthodontics Align`} description={post.data.excerpt}>
  <div class="flex flex-col min-h-screen bg-[#F6F7FF]">
    <Navbar />

    <BlogDetailsHero 
      title={post.data.title}
      excerpt={post.data.excerpt}
      authorName={post.data.author.name}
      authorImage={post.data.author.image}
      publishDate={new Date(post.data.publishDate).toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric'
      })}
      featuredImage={post.data.image}
    />

    <BlogProse>
      <div class="flex flex-col items-center gap-10 md:gap-20 w-full mx-auto text-[#0D1B15]">
        
        <div class="w-full">
          <p class="text-lg md:text-[22px] leading-relaxed md:leading-[1.6em] mb-8 font-inter">
            Hearing that your braces are coming off or that you're on your final aligner is one of the best moments in your treatment journey. However, the process doesn't completely end the day the hardware comes off. The "retention phase" naturally begins.
          </p>
          
          <h2 class="font-['Bricolage_Grotesque'] font-medium text-3xl md:text-[48px] tracking-[-1px] md:tracking-[-3px] leading-[1.2] mb-4 mt-8">Why Teeth Shift</h2>
          <p class="text-lg md:text-[22px] leading-relaxed md:leading-[1.6em] font-inter">
            Teeth have a memory. Even after years of perfectly aligned treatment, the elastic ligaments holding your teeth in place will try to pull them back to their original, crooked positions. This phenomenon is known as "orthodontic relapse."
          </p>
        </div>

        <!-- Two Column Images Row -->
        <div 
          class="framer-1hkazoj flex flex-col md:flex-row justify-center items-center gap-6 overflow-visible p-0 h-min relative w-full box-border flex-none"
        >
          <figure
            class="m-0 rounded-[20px] flex-1 overflow-clip aspect-[0.97/1] relative w-full md:w-[1px] opacity-100 transform-none box-border"
          >
            <div class="rounded-[inherit] inset-0 absolute box-border">
              <img
                src="https://framerusercontent.com/images/zcgnQBMu4749dwi5AO2wK2UeJDk.png?width=1512&height=1600"
                alt="Modern Dental Clinic"
                class="rounded-[inherit] block w-full h-full object-center object-cover box-border"
              />
            </div>
          </figure>
          <figure
            class="m-0 rounded-[20px] flex-1 overflow-clip aspect-[0.97/1] relative w-full md:w-[1px] opacity-100 transform-none box-border"
          >
            <div class="rounded-[inherit] inset-0 absolute box-border">
              <img
                src="https://framerusercontent.com/images/I0J7U9HzrLJBJ6C4GYCsAJ98vA.png?width=1512&height=1600"
                alt="Friendly Dental Professional"
                class="rounded-[inherit] block w-full h-full object-center object-cover box-border"
              />
            </div>
          </figure>
        </div>

        <div class="w-full">
          <h2 class="font-['Bricolage_Grotesque'] font-medium text-3xl md:text-[48px] tracking-[-1px] md:tracking-[-3px] leading-[1.2] mb-4 mt-8">Wear Your Retainers</h2>
          <p class="text-lg md:text-[22px] leading-relaxed md:leading-[1.6em] font-inter">
            The absolute best way to protect your investment is to wear your retainers strictly as prescribed by your orthodontist. Usually, this means full-time wear for a few months followed by lifetime nighttime wear.
          </p>

          <h2 class="font-['Bricolage_Grotesque'] font-medium text-3xl md:text-[48px] tracking-[-1px] md:tracking-[-3px] leading-[1.2] mb-4 mt-12">Retainer Care</h2>
          <p class="text-lg md:text-[22px] leading-relaxed md:leading-[1.6em] font-inter">
             Keep your retainers clean and store them securely in their case when you aren't wearing them. If you lose or break them, contact your orthodontist right away for a replacement to ensure your teeth stay in place!
          </p>
        </div>

        <div class="w-full">
          <h2 class="font-['Bricolage_Grotesque'] font-medium text-3xl md:text-[48px] tracking-[-1px] md:tracking-[-3px] leading-[1.2] mb-4 mt-12">Conclusion</h2>
          <p class="text-lg md:text-[22px] leading-relaxed md:leading-[1.6em] font-inter mb-12">
            You've worked hard for your new smile. Committing to a simple retainer routine ensures that you get to enjoy beautiful, perfectly straight teeth for decades to come.
          </p>
        </div>

      </div>
    </BlogProse>

    <RelatedPosts currentSlug={post.id} />

    <Contact />
    <FAQ />
    <Footer />
  </div>
</Layout>
