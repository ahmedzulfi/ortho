---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import BlogDetailsHero from '../../components/BlogDetailsHero.astro';
import BlogProse from '../../components/BlogProse.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import Contact from '../../components/Contact.astro';
import FAQ from '../../components/FAQ.astro';
import Footer from '../../components/Footer.astro';

const post = {
  id: "clear-aligners-vs-braces",
  data: {
    title: "Clear Aligners vs. Traditional Braces",
    excerpt: "Wondering whether to choose clear aligners or traditional braces? Here's a comprehensive comparison to help you decide.",
    publishDate: "2026-04-09",
    image: "https://framerusercontent.com/images/lhHhUnyKhPclLkxHyj2BcF6Ek.png",
    author: {
      name: "Mohammad Imran",
      image: "https://framerusercontent.com/images/et3GxfYry1OVFWCEFEwd2cMhjI.jpg"
    }
  }
};
---

<Layout title={`${post.data.title} | Orthodontics Align`} description={post.data.excerpt}>
  <div class="flex flex-col min-h-screen bg-[#F6F7FF]">
    <Navbar />

    <BlogDetailsHero 
      title={post.data.title}
      excerpt={post.data.excerpt}
      authorName={post.data.author.name}
      authorImage={post.data.author.image}
      publishDate={new Date(post.data.publishDate).toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric'
      })}
      featuredImage={post.data.image}
    />

    <BlogProse>
      <div class="flex flex-col items-center gap-10 md:gap-20 w-full mx-auto text-[#0D1B15]">
        
        <div class="w-full">
          <p class="text-lg md:text-[22px] leading-relaxed md:leading-[1.6em] mb-8 font-inter">
            Choosing the right orthodontic treatment is a significant decision. With advancements in dental technology, patients now have multiple effective options for achieving their ideal smile. The two most popular choices are clear aligners and traditional braces.
          </p>
          
          <h2 class="font-['Bricolage_Grotesque'] font-medium text-3xl md:text-[48px] tracking-[-1px] md:tracking-[-3px] leading-[1.2] mb-4 mt-8">Aesthetic and Comfort Options</h2>
          <p class="text-lg md:text-[22px] leading-relaxed md:leading-[1.6em] font-inter">
            Clear aligners offer unparalleled discretion, making them a favorite among adults and image-conscious teens. Since they are removable, there are no dietary restrictions, and maintaining oral hygiene is as simple as brushing and flossing normally.
          </p>
        </div>

        <!-- Two Column Images Row -->
        <div 
          class="framer-1hkazoj flex flex-col md:flex-row justify-center items-center gap-6 overflow-visible p-0 h-min relative w-full box-border flex-none"
        >
          <figure
            class="m-0 rounded-[20px] flex-1 overflow-clip aspect-[0.97/1] relative w-full md:w-[1px] opacity-100 transform-none box-border"
          >
            <div class="rounded-[inherit] inset-0 absolute box-border">
              <img
                src="https://framerusercontent.com/images/zcgnQBMu4749dwi5AO2wK2UeJDk.png?width=1512&height=1600"
                alt="Modern Dental Clinic"
                class="rounded-[inherit] block w-full h-full object-center object-cover box-border"
              />
            </div>
          </figure>
          <figure
            class="m-0 rounded-[20px] flex-1 overflow-clip aspect-[0.97/1] relative w-full md:w-[1px] opacity-100 transform-none box-border"
          >
            <div class="rounded-[inherit] inset-0 absolute box-border">
              <img
                src="https://framerusercontent.com/images/I0J7U9HzrLJBJ6C4GYCsAJ98vA.png?width=1512&height=1600"
                alt="Friendly Dental Professional"
                class="rounded-[inherit] block w-full h-full object-center object-cover box-border"
              />
            </div>
          </figure>
        </div>

        <div class="w-full">
          <h2 class="font-['Bricolage_Grotesque'] font-medium text-3xl md:text-[48px] tracking-[-1px] md:tracking-[-3px] leading-[1.2] mb-4 mt-8">The Reliability of Braces</h2>
          <p class="text-lg md:text-[22px] leading-relaxed md:leading-[1.6em] font-inter">
            While braces are more noticeable, they remain the gold standard for treating severe bite issues and complex jaw alignment problems. They work around the clock without requiring the patient to remember to wear them, ensuring consistent progress.
          </p>

          <h2 class="font-['Bricolage_Grotesque'] font-medium text-3xl md:text-[48px] tracking-[-1px] md:tracking-[-3px] leading-[1.2] mb-4 mt-12">Making the Right Choice</h2>
          <p class="text-lg md:text-[22px] leading-relaxed md:leading-[1.6em] font-inter">
             Booking a consultation with our experienced orthodontic team is the best way to determine which option suits your lifestyle, budget, and clinical needs perfectly.
          </p>
        </div>

        <div class="w-full">
          <h2 class="font-['Bricolage_Grotesque'] font-medium text-3xl md:text-[48px] tracking-[-1px] md:tracking-[-3px] leading-[1.2] mb-4 mt-12">Conclusion</h2>
          <p class="text-lg md:text-[22px] leading-relaxed md:leading-[1.6em] font-inter mb-12">
            Whether you opt for the modern convenience of clear aligners or the proven effectiveness of braces, the final result will be the same: a stunning, confident smile that lasts a lifetime.
          </p>
        </div>

      </div>
    </BlogProse>

    <RelatedPosts currentSlug={post.id} />

    <Contact />
    <FAQ />
    <Footer />
  </div>
</Layout>
