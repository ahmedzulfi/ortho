---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import BlogDetailsHero from '../../components/BlogDetailsHero.astro';
import BlogProse from '../../components/BlogProse.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import Contact from '../../components/Contact.astro';
import FAQ from '../../components/FAQ.astro';
import Footer from '../../components/Footer.astro';

const post = {
  id: "future-of-3d-treatment-planning",
  data: {
    title: "The Future of 3D Treatment Planning in Orthodontics",
    excerpt: "Explore how AI and high-resolution 3D simulations are transforming clear aligner workflows, offering more predictable results in less time.",
    publishDate: "2026-04-06",
    image: "https://framerusercontent.com/images/DjC5pMWJdlfxcNqmLKEPK4bycJk.jpg",
    author: {
      name: "Dr. Ahmed Zulfi",
      image: "https://framerusercontent.com/images/et3GxfYry1OVFWCEFEwd2cMhjI.jpg"
    }
  }
};
---

<Layout title={`${post.data.title} | Orthodontics Align`} description={post.data.excerpt}>
  <div class="flex flex-col min-h-screen bg-[#F6F7FF]">
    <Navbar />

    <BlogDetailsHero 
      title={post.data.title}
      excerpt={post.data.excerpt}
      authorName={post.data.author.name}
      authorImage={post.data.author.image}
      publishDate={new Date(post.data.publishDate).toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric'
      })}
      featuredImage={post.data.image}
    />

    <BlogProse>
      <div class="flex flex-col items-center gap-20 w-full mx-auto text-[#0D1B15]">
        
        <div class="w-full">
          <p class="text-[22px] leading-[1.6em] mb-8 font-inter">
            The landscape of orthodontics is shifting rapidly from manual procedures to digital-first workflows. At the heart of this transformation is <strong>3D Treatment Planning</strong>, a process that combines advanced simulation software with clinical expertise to map out tooth movement with unprecedented precision.
          </p>
          
          <h2 style="font-family: 'Bricolage Grotesque'; font-weight: 500; font-size: 48px; letter-spacing: -3px; line-height: 120%; margin-bottom: 16px; margin-top: 32px;">Why 3D Planning Matters</h2>
          <p class="text-[22px] leading-[1.6em] font-inter">
            In the past, orthodontists relied on physical models and manual calculations. While effective, these methods were prone to small errors that could lead to longer treatment times or unexpected mid-course corrections. With modern 3D planning tools, we calculate movements down to the millimeter.
          </p>
        </div>

        <!-- Two Column Images Row -->
        <div 
          class="framer-1hkazoj"
          style="box-sizing: border-box; -webkit-font-smoothing: inherit; place-content: center; flex: 0 0 auto; flex-flow: row; gap: 24px; overflow: visible; padding: 0px; align-items: center; display: flex; height: min-content; position: relative; width: 100%;"
        >
          <figure
            class="framer-1lk8qrc"
            style="box-sizing: border-box; -webkit-font-smoothing: inherit; margin: 0px; border-radius: 20px; flex: 1 0 0px; overflow: clip; aspect-ratio: 0.97 / 1; position: relative; width: 1px; will-change: transform; opacity: 1; transform: none;"
          >
            <div style="box-sizing: border-box; -webkit-font-smoothing: inherit; border-radius: inherit; inset: 0px; position: absolute;">
              <img
                src="https://framerusercontent.com/images/zcgnQBMu4749dwi5AO2wK2UeJDk.png?width=1512&height=1600"
                alt="Modern Dental Clinic"
                style="box-sizing: border-box; -webkit-font-smoothing: inherit; border-radius: inherit; display: block; width: 100%; height: 100%; object-position: center center; object-fit: cover;"
              />
            </div>
          </figure>
          <figure
            class="framer-jatmll"
            style="box-sizing: border-box; -webkit-font-smoothing: inherit; margin: 0px; border-radius: 20px; flex: 1 0 0px; overflow: clip; aspect-ratio: 0.97 / 1; position: relative; width: 1px; will-change: transform; opacity: 1; transform: none;"
          >
            <div style="box-sizing: border-box; -webkit-font-smoothing: inherit; border-radius: inherit; inset: 0px; position: absolute;">
              <img
                src="https://framerusercontent.com/images/I0J7U9HzrLJBJ6C4GYCsAJ98vA.png?width=1512&height=1600"
                alt="Friendly Dental Professional"
                style="box-sizing: border-box; -webkit-font-smoothing: inherit; border-radius: inherit; display: block; width: 100%; height: 100%; object-position: center center; object-fit: cover;"
              />
            </div>
          </figure>
        </div>

        <div class="w-full">
          <h2 style="font-family: 'Bricolage Grotesque'; font-weight: 500; font-size: 48px; letter-spacing: -3px; line-height: 120%; margin-bottom: 16px; margin-top: 32px;">The Role of AI in Scaling Your Practice</h2>
          <p class="text-[22px] leading-[1.6em] font-inter">
            As clinics grow, the bottleneck often becomes the time required to sit down and plan each individual case. This is where AI-assisted planning comes in. By automating the initial segmentation and basic tooth movement recommendations, AI allows the expert planner to focus on the high-level clinical decisions.
          </p>

          <h2 style="font-family: 'Bricolage Grotesque'; font-weight: 500; font-size: 48px; letter-spacing: -3px; line-height: 120%; margin-bottom: 16px; margin-top: 48px;">What to Expect from Orthodontics Align</h2>
          <p class="text-[22px] leading-[1.6em] font-inter">
            At Orthodontics Align, we specialize in bridging the gap between digital technology and clinical excellence. Our planners are not just technicians; they are experts who understand the biological limits of tooth movement. When you send us an STL file, you get back a comprehensive 3D plan that you can trust.
          </p>
        </div>

        <div class="w-full">
          <h2 style="font-family: 'Bricolage Grotesque'; font-weight: 500; font-size: 48px; letter-spacing: -3px; line-height: 120%; margin-bottom: 16px; margin-top: 48px;">Conclusion</h2>
          <p class="text-[22px] leading-[1.6em] font-inter mb-12">
            Precision in planning is the difference between a good result and a perfect smile. Stay tuned for more updates as we continue to push the boundaries of what's possible in digital orthodontics!
          </p>
        </div>

      </div>
    </BlogProse>

    <RelatedPosts currentSlug={post.id} />

    <Contact />
    <FAQ />
    <Footer />
  </div>
</Layout>
